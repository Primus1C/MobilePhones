		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Рег.Фирма,
	Рег.Склад,
	Рег.Номенклатура,
	Рег.Партия,
	Рег.Партия.Валюта,
	Рег.Партия.Контрагент,
	Рег.Док,
	Рег.Док.Контрагент,
	Рег.Док.Контрагент.Менеджер,
	Рег.Док.Примечание,
	Рег.ОстатокОстаток,
	ВЫРАЗИТЬ(Рег.ОстатокОстаток * Рег.Партия.ЦенаЗакупки КАК ЧИСЛО(19, 2)) КАК СуммаВал
ИЗ
	РегистрНакопления.РезервыТовара.Остатки(, {Склад В (&amp;Склады)}) КАК Рег</query>
	</dataSet>
