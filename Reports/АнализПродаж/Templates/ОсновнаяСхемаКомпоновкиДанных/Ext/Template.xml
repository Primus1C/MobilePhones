		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЕСТЬNULL(Остатки.Номенклатура, Продажи.Номенклатура) КАК Номенклатура,
	ЕСТЬNULL(Остатки.Склад, Продажи.Склад) КАК Склад,
	ЕСТЬNULL(Остатки.Фирма, Продажи.Фирма) КАК Фирма,
	ЕСТЬNULL(Остатки.Партия, Продажи.Партия) КАК Партия,
	// Данные остатков и оборотов
	ЕСТЬNULL(Остатки.ОстатокНачальныйОстаток, 0) КАК НачальныйОстаток,
	ЕСТЬNULL(Остатки.ОстатокПриход, 0) КАК Приход,
	ЕСТЬNULL(Остатки.ОстатокРасход, 0) КАК Расход,
	ЕСТЬNULL(Остатки.ОстатокКонечныйОстаток, 0) КАК КонечныйОстаток,  
	выбор когда ЕСТЬNULL(Остатки.ОстатокКонечныйОстаток, 0) &gt; 0 Тогда Истина Иначе Ложь Конец КАК ЕстьОстатки,  
	// Данные продаж
	ЕСТЬNULL(Продажи.КоличествоОборот, 0) КАК КоличествоПродаж,
	ЕСТЬNULL(Продажи.СуммаВБазВалютеОборот, 0) КАК СуммаПродаж,
	ЕСТЬNULL(Продажи.НаценкаВБазВалютеОборот, 0) КАК Наценка,
	// Реквизит цены для расчетов сумм
	ЕСТЬNULL(Остатки.Партия.ЦенаЗакупкиВБазВалюте, Продажи.Партия.ЦенаЗакупкиВБазВалюте) КАК ЦенаЗакупки
ИЗ
	РегистрНакопления.ОстаткиТовара.ОстаткиИОбороты(&amp;НачалоПериода, &amp;КонецПериода, Авто, , {Номенклатура.*, Склад.*, Фирма.*, Партия.*}) КАК Остатки
		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Авто, {Номенклатура.*, Склад.*, Фирма.*, Партия.*}) КАК Продажи
		ПО Остатки.Номенклатура = Продажи.Номенклатура
			И Остатки.Склад = Продажи.Склад
			И Остатки.Фирма = Продажи.Фирма
			И Остатки.Партия = Продажи.Партия</query>
	</dataSet>
