&НаКлиенте
Процедура ИнвойсыПередНачаломИзменения(Элемент, Отказ)
	
	ТекДанные = Элемент.ТекущиеДанные;
	
	Если ТекДанные.Состояние = ПредопределенноеЗначение("Перечисление.Долги.Полностью") Тогда 
		Сообщить("" + текДанные.Инвойс + " оплачен полностью!");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если Элемент.ТекущийЭлемент.Имя = "ИнвойсыДолг" Тогда 
		Если СуммаНеПривязано > 0 Тогда
			лПривяз = Мин(ТекДанные.Долг, СуммаНеПривязано);
			ТекДанные.Долг 		= лПривяз;                     
			ТекДанные.Остаток 	= ТекДанные.ДолгДоПривязки - ТекДанные.Долг;
			СуммаПривязано 		= СуммаПривязано + лПривяз;
			СуммаНеПривязано 	= СуммаНеПривязано - лПривяз;
			ОбновитьИтоги();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры
 
