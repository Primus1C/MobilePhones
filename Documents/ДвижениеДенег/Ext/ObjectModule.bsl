		Если ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ОбменВалюты И СубДВалюта.ВестиПартионныйУчет Тогда
			// приход только при покупке валюты (обмен)
			Движение = Движения.ПартииВалюты.ДобавитьПриход(); 
			Движение.Период					= Дата;
			Движение.Касса 					= ДСчет;
			Движение.Валюта 				= СубДВалюта;
			Движение.Сумма					= СубДСумма;
			Движение.СуммаВБазовойВалюте	= Сумма; 
			
		ИначеЕсли ПриходРасход = Перечисления.ПриходРасход.Расход И СубДВалюта.ВестиПартионныйУчет Тогда
			Запр = Новый Запрос;
			Запр.УстановитьПараметр("Дата", 	МоментВремени());
			Запр.УстановитьПараметр("Валюта", 	Валюта);
			Запр.УстановитьПараметр("Касса", 	ДСчет);
			Запр.Текст = "ВЫБРАТЬ
			             |	ПартииВалютыОстатки.СуммаОстаток КАК Сумма,
			             |	ПартииВалютыОстатки.СуммаВБазовойВалютеОстаток КАК СуммаВБазовойВалюте
			             |ИЗ
			             |	РегистрНакопления.ПартииВалюты.Остатки(
			             |			&Дата,
			             |			Валюта = &Валюта
			             |				И Касса = &Касса) КАК ПартииВалютыОстатки";
			Выборка = Запр.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда 
				Если Выборка.Сумма <> 0 Тогда
					к = Сумма / Выборка.Сумма;
					Движение = Движения.ПартииВалюты.ДобавитьРасход(); 
					Движение.Период					= Дата;
					Движение.Касса 					= ДСчет;
					Движение.Валюта 				= СубДВалюта;
					Движение.Сумма					= Сумма;
					Движение.СуммаВБазовойВалюте	= Выборка.СуммаВБазовойВалюте * к; 
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ПриходРасход = Перечисления.ПриходРасход.Расход И Валюта.ВестиПартионныйУчет Тогда
			Запр = Новый Запрос;
			Запр.УстановитьПараметр("Дата", 	МоментВремени());
			Запр.УстановитьПараметр("Валюта", 	Валюта);
			Запр.УстановитьПараметр("Касса", 	ДСчет);
			Запр.Текст = "ВЫБРАТЬ
			             |	ПартииВалютыОстатки.СуммаОстаток КАК Сумма,
			             |	ПартииВалютыОстатки.СуммаВБазовойВалютеОстаток КАК СуммаВБазовойВалюте
			             |ИЗ
			             |	РегистрНакопления.ПартииВалюты.Остатки(
			             |			&Дата,
			             |			Валюта = &Валюта
			             |				И Касса = &Касса) КАК ПартииВалютыОстатки";
			Выборка = Запр.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда 
				Если Выборка.Сумма <> 0 Тогда
					к = Сумма / Выборка.Сумма;
					Движение = Движения.ПартииВалюты.ДобавитьРасход(); 
					Движение.Период					= Дата;
					Движение.Касса 					= ДСчет;
					Движение.Валюта 				= Валюта;
					Движение.Сумма					= Сумма;
					Движение.СуммаВБазовойВалюте	= Выборка.СуммаВБазовойВалюте * к; 
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		//Если ПриходРасход = Перечисления.ПриходРасход.Пход Тогда
		//	Движение = Движения.ПартииВалюты.ДобавитьПриход(); 
		//	Движение.Период					= Дата;
		//	Движение.Касса 					= ДСчет;
		//	Движение.Валюта 				= СубДВалюта;
		//	Движение.Сумма					= Сумма;
		//	Движение.СуммаВБазовойВалюте	= СубДСумма;
		//Иначе		
		//	Запр = Новый Запрос;
		//	Запр.Текст = "ВЫБРАТЬ
		//	             |	ПартииВалютыОстатки.СуммаОстаток КАК Сумма,
		//	             |	ПартииВалютыОстатки.СуммаВБазовойВалютеОстаток КАК СуммаВБазовойВалюте
		//	             |ИЗ
		//	             |	РегистрНакопления.ПартииВалюты.Остатки(
		//	             |			&Дата,
		//	             |			Валюта = &Валюта
		//	             |				И Касса = &Касса) КАК ПартииВалютыОстатки
		//	             |ИТОГИ
		//	             |	СУММА(Сумма),
		//	             |	СУММА(СуммаВБазовойВалютеОстаток)
		//	             |ПО
		//	             |	ОБЩИЕ";
		//	Запр.УстановитьПараметр("Дата", МоментВремени());
		//	Запр.УстановитьПараметр("Валюта", Валюта);
		//	Запр.УстановитьПараметр("Касса", ДСчет);  
		//	Выборка = Запр.Выполнить().Выбрать();
		//	Если Выборка.Следующий() Тогда
		//		Движение = Движения.ПартииВалюты.ДобавитьРасход(); 
		//		Движение.Период	= Дата;
		//		Движение.Касса 	= ДСчет;
		//		Движение.Валюта = Валюта;
		//		
		//	КонецЕсли;
		//КонецЕсли;
	КонецЕсли;    
	
	// статусы инвойсов	
	Если ДополнительныеСвойства.Свойство("ИнвойсыДляЗаписиСтатусов") Тогда
		МассивИнвойсов = ДополнительныеСвойства.ИнвойсыДляЗаписиСтатусов;
		Если МассивИнвойсов <> Неопределено И МассивИнвойсов.Количество() > 0 Тогда
			РассчитатьИЗаписатьСтатусыИнвойсов(МассивИнвойсов);
		КонецЕсли;
	КонецЕсли;
	
    // Последовательность
	лВалюта = Неопределено;
	лКасса = Неопределено;
	Если Валюта.ВестиПартионныйУчет Тогда
		лВалюта = Валюта;
	КонецЕсли;
	Если СубДВалюта.ВестиПартионныйУчет Тогда
		лВалюта = СубДВалюта;
	КонецЕсли;
	Если ДСчет.ВестиПартионныйУчет Тогда
		лКасса = ДСчет;
	КонецЕсли;
	Если СубДСчет.ВестиПартионныйУчет Тогда
		лКасса = СубДСчет;
	КонецЕсли;
	
	НаборПоследовательности = Последовательности.ПартииВалют.СоздатьНаборЗаписей();
	НаборПоследовательности.Отбор.Регистратор.Установить(Ссылка); 
	
	Если ЗначениеЗаполнено(лВалюта) И ЗначениеЗаполнено(лКасса) Тогда
		Запись = НаборПоследовательности.Добавить();
		Запись.Регистратор = Ссылка; // Для последовательности это поле обязательно
		Запись.Период      = Дата;   // Для последовательности это поле обязательно
		// Заполняем измерения
		Запись.Касса  = лКасса;
		Запись.Валюта = лВалюта;
	КонецЕсли;
	
	// Метод Записать() внутри транзакции проведения отработает идеально:
	// - Если условие выше выполнилось, он перезапишет старую регистрацию на новую.
	// - Если условие НЕ выполнилось (набор остался пустым), метод сотрет старую запись 
	//   этого документа из последовательности, корректно сняв его с учета.
	НаборПоследовательности.Записать();

	// © Primus1C  ОКОНЧАНИЕ ◄

