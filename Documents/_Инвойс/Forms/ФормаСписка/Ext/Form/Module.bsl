&НаСервереБезКонтекста
Функция СтруктураОснования(ИнвойсСсылка)
	
	лОснование = ИнвойсСсылка.ДокументОснование;
	Возврат Новый Структура("ОбъектУИД,Владелец", лОснование.УникальныйИдентификатор(), лОснование);	

КонецФункции 

&НаСервере
Процедура УстановитьСтатусНаСервере(ИнвойсСсылка, НовСтатус)

	ОбщегоНазначенияСервер.ЗаписатьСтатусыИнвойса(ИнвойсСсылка, НовСтатус, , , , "Форма списка");

КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатус(Команда) 

	Спис = Новый СписокЗначений;
	Спис.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыИнвойса.ВПути"),,,БиблиотекаКартинок.ИндикаторЖелтый16);
	Спис.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыИнвойса.ЧастичноПрибыл"),,,БиблиотекаКартинок.ИндикаторЖелтый16);
	Спис.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыИнвойса.Прибыл"),,,БиблиотекаКартинок.ИндикаторЗеленый16);
	ВыбСтатус = ВыбратьИзМеню(Спис, ЭтаФорма.ТекущийЭлемент);
	Если ВыбСтатус <> Неопределено Тогда
		УстановитьСтатусНаСервере(ЭтаФорма.Элементы.Список.ТекущаяСтрока, ВыбСтатус.Значение); 
		Элементы.Список.Обновить();
	КонецЕсли;

КонецПроцедуры


