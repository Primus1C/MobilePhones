Процедура ЗаполнитьПоГруппеТоваров(Команда)

	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбораГруппы",,ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура Подбор(Команда) 
	
	Номенклатура = Новый СписокЗначений;
	Для каждого СтрокаТЗ Из Товары Цикл
		Номенклатура.Добавить(СтрокаТЗ.Номенклатура);	
	КонецЦикла;

	///Создаем структуру с отбором и добавляем значения
	ПараметрыОтбора = Новый Структура;
	//ПараметрыОтбора.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.ВидыОперацийРеализацияТоваров.Товары"));
	//ПараметрыОтбора.Вставить("Дата", ТекущаяДата());   ///Дополнительный отбор
 
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", ПараметрыОтбора); ///Добавляем отбор в параметры формы

	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыФормы.Вставить("ВыбраннаяНоменклатура", Номенклатура);

	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбора", ЭтаФорма,"Подбор");

	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора", ПараметрыФормы, ЭтаФорма, , , , ОбработкаВыбора); 
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьНезаполненные(Команда)
	
	Ном = Товары.Количество() - 1;
	Пока Ном >= 0 Цикл     
		ЕстьДанные = Ложь;
		Для каждого ТипЦены Из АктуальныеТипыЦен Цикл
			Префикс = ТипЦены.Значение;
			СтрокаТЗ = Товары[Ном];
			Если СтрокаТЗ[Префикс+"_ЦенаНовая"] > 0 ИЛИ СтрокаТЗ[Префикс+"_ЦенаКНовая"] > 0 ИЛИ СтрокаТЗ[Префикс+"_Количество"] > 0 Тогда
				ЕстьДанные = Истина;
			КонецЕсли;	
		КонецЦикла; 	
		Если НЕ ЕстьДанные Тогда
			Товары.Удалить(Ном); 
			Модифицированность = Истина;
		КонецЕсли;
		Ном = Ном - 1;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)  
	
	Номенклатура = Новый Массив;
	Для каждого СтрокаТЗ Из Товары Цикл
		Номенклатура.Добавить(СтрокаТЗ.Номенклатура);	
	КонецЦикла;
	ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(Номенклатура); 
	
КонецПроцедуры
	
#КонецОбласти    


&НаСервере
Процедура ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(Номенклатура)
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Номенклатура", Номенклатура);
	Запр.УстановитьПараметр("ДатаОстатков", ?(Объект.Дата=Дата(1,1,1), ТекущаяДатаСеанса(), Объект.Дата));   
	//Запр.УстановитьПараметр("ДатаОстатков", Объект.Ссылка.МоментВремени());     
	Запр.Текст = "ВЫБРАТЬ
	             |	СпрНоменклатура.Ссылка КАК Номенклатура,
	             |	ЗначенияСвойств.ЗначениеСвойства.Наименование КАК Картинка,
	             |	ОстаткиТовараОстатки.ОстатокОстаток КАК Остаток,
	             |	ЦеныПродажи.ВидЦены КАК ВидЦены,
	             |	ЦеныПродажи.Цена КАК Цена,
	             |	ЦеныПродажи.ЦенаОтКоличества КАК ЦенаОтКоличества,
	             |	ЦеныПродажи.Количество КАК Количество,
	             |	ЦеныЗакупки.Цена КАК ЦенаЗакупки,
	             |	ЦеныЗакупки.Валюта КАК ВалютаЗакупки
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		Номенклатура.Ссылка КАК Ссылка
	             |	ИЗ
	             |		Справочник.Номенклатура КАК Номенклатура
	             |	ГДЕ
	             |		Номенклатура.Ссылка В(&Номенклатура)) КАК СпрНоменклатура
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			ЗначенияСвойствОбъектов.Объект КАК Объект,
	             |			ЗначенияСвойствОбъектов.ЗначениеСвойства КАК ЗначениеСвойства
	             |		ИЗ
	             |			РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	             |		ГДЕ
	             |			ЗначенияСвойствОбъектов.ЗначениеСвойства.Владелец.Наименование = ""Спецификация"") КАК ЗначенияСвойств
	             |		ПО СпрНоменклатура.Ссылка = ЗначенияСвойств.Объект
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(&ДатаОстатков, Номенклатура В (&Номенклатура)) КАК ОстаткиТовараОстатки
	             |		ПО СпрНоменклатура.Ссылка = ОстаткиТовараОстатки.Номенклатура
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныПродажи.СрезПоследних(&ДатаОстатков, Номенклатура В (&Номенклатура)) КАК ЦеныПродажи
	             |		ПО СпрНоменклатура.Ссылка = ЦеныПродажи.Номенклатура
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныЗакупки.СрезПоследних КАК ЦеныЗакупки
	             |		ПО СпрНоменклатура.Ссылка = ЦеныЗакупки.Номенклатура";
	ОбщегоНазначения.ДополнитьТекстЗапросаСпецификациями(Запр.Текст, "ЗначенияСвойств.ЗначениеСвойства.Наименование");
	Выгрузка = Запр.Выполнить().Выгрузить();
	
	Для Каждого СтрокаДанных ИЗ Выгрузка Цикл
		СтрокаТЗ = Товары.НайтиСтроки(Новый Структура("Номенклатура", СтрокаДанных.Номенклатура))[0];
		СтрокаТЗ.Картинка 					= СтрокаДанных.Картинка; 
		СтрокаТЗ.Остаток 					= СтрокаДанных.Остаток; 
		СтрокаТЗ.Закупка 					= СтрШаблон("%1 %2", Формат(СтрокаДанных.ЦенаЗакупки, "ЧДЦ=2"), СтрокаДанных.ВалютаЗакупки); 
		Если СтрокаДанных.ВидЦены <> Null Тогда
			Префикс = ИмяЗначенияПеречисления(СтрокаДанных.ВидЦены);  
			СтрокаТЗ[Префикс+"_ЦенаДо"]		= СтрокаДанных.Цена;
			СтрокаТЗ[Префикс+"_ЦенаКДо"]	= СтрШаблон("%1 %2 %3", Формат(СтрокаДанных.ЦенаОтКоличества, "ЧДЦ=2"), НСтр("ru = 'от'; en = 'from'"), СтрокаДанных.Количество);
		КонецЕсли;
	КонецЦикла;  	

КонецПроцедуры

