&НаКлиенте
Процедура ОтобразитьСтатусДокумента()

	Если Объект.Передан = Дата(1,1,1) Тогда
		Если Объект.Проведен Тогда
			Статус = НСтр("ru = 'Ожидает передачи в Telegram'; en = ''")
		Иначе 
			Статус = НСтр("ru = 'Редактируется'; en = ''")
		КонецЕсли;	
	Иначе
		Статус = НСтр("ru = 'Передан в Telegram'; en = ''")
	КонецЕсли;
	Статус = СтрШаблон("%1 %2",
						омСервер.Фрмт(НСтр("ru = 'Статус:'; en = 'Status:'"), "НАДПИСЬ_ЦВ1"),
						омСервер.Фрмт(Статус, "НАДПИСЬ_ЦВ2"));
	Элементы.ДекорацияСтатус.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначения.ТекстHTMLВФорматированнуюСтроку(Статус));
	
КонецПроцедуры

