#Область ДействияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПоказыватьСпецификацию		= Истина;
	ПоказыватьДействующуюЦену	= Истина;
	ПоказыватьИзменениеЦен		= Ложь;
	ПоказыватьЦенуЗакупки		= Истина;
	
	Для каждого ЗначениеПеречисления Из Метаданные.Перечисления.ВидыЦен.ЗначенияПеречисления Цикл
		АктуальныеТипыЦен.Добавить(ЗначениеПеречисления.Имя, ЗначениеПеречисления.Синоним);		
	КонецЦикла;

	Для каждого ТипЦены Из АктуальныеТипыЦен Цикл
		ДобавитьРеквизитыИЭлементыТабличнойЧастиПоВидуЦен(ТипЦены);
	КонецЦикла; 
	
	КэшДанных = Новый Структура("ЗначенияПодбора", Новый Соответствие());

	// создадим меню заполнения по группам подбора
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	Номенклатура.ГруппаПодбора
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	НЕ Номенклатура.ГруппаПодбора ЕСТЬ NULL
	             |	И Номенклатура.ГруппаПодбора <> ЗНАЧЕНИЕ(Справочник.ГруппыПодбораНоменклатуры.ПустаяСсылка)";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Истина Тогда 
			
			Представление = СтрокаБуквами(Выборка.ГруппаПодбора);
			ЭлементПодменю = ЭтаФорма.Элементы.Добавить("Подменю_" + Представление, Тип("ГруппаФормы"), Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ТоварыГруппаЗаполнениеПодменю.ПодчиненныеЭлементы.ПодменюЗаполнитьПоТоварнойГруппе);
			ЭлементПодменю.Вид = ВидГруппыФормы.Подменю;   
			ЭлементПодменю.Заголовок = Выборка.ГруппаПодбора;
			запрВлож = Новый Запрос;  
			запрВлож.УстановитьПараметр("Ссылка", Выборка.ГруппаПодбора);
			запрВлож.Текст = "ВЫБРАТЬ
			             |	Номенклатура.Ссылка КАК Ссылка
			             |ИЗ
			             |	Справочник.Номенклатура КАК Номенклатура
			             |ГДЕ
			             |	Номенклатура.ЭтоГруппа
			             |	И НЕ Номенклатура.ПометкаУдаления
			             |	И Номенклатура.ГруппаПодбора В ИЕРАРХИИ(&Ссылка)";   
			ВыборкаВлож = запрВлож.Выполнить().Выбрать();
			Пока ВыборкаВлож.Следующий() Цикл 
				ПредставлениеВлож = СтрокаБуквами(ВыборкаВлож.Ссылка);
				Кмд = ЭтаФорма.Команды.Добавить("Команда_" + ПредставлениеВлож);
				Кмд.Действие = "НажатиеКнопкиПодбораМеню";
				Кмд.Заголовок = ВыборкаВлож.Ссылка;
				Элемент = ЭтаФорма.Элементы.Добавить("Кнопка_" + ПредставлениеВлож, Тип("КнопкаФормы"), ЭлементПодменю);
				Элемент.Вид 		= ВидКнопкиФормы.КнопкаКоманднойПанели;
				Элемент.ИмяКоманды 	= "Команда_" + ПредставлениеВлож;
				КэшДанных.ЗначенияПодбора.Вставить(Элемент.ИмяКоманды, ВыборкаВлож.Ссылка); 
			КонецЦикла;
			
		Иначе
			
			Представление = СтрокаБуквами(Выборка.ГруппаПодбора);
			Кмд = ЭтаФорма.Команды.Добавить("Команда_" + Представление);
			Кмд.Действие = "НажатиеКнопкиГруппыПодбора";
			Кмд.Заголовок = Выборка.ГруппаПодбора;

			Элемент = ЭтаФорма.Элементы.Добавить("Кнопка_"+Представление, Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ТоварыГруппаЗаполнение);
			Элемент.Вид 		= ВидКнопкиФормы.ОбычнаяКнопка;
			Элемент.ИмяКоманды 	= "Команда_" + Представление;
			Элемент.Картинка 	= БиблиотекаКартинок.ПерейтиНазад; 
			Элемент.Отображение = ОтображениеКнопки.КартинкаИТекст;
		
			запр = Новый Запрос;  
			запр.УстановитьПараметр("Ссылка", Выборка.ГруппаПодбора);
			запр.Текст = "ВЫБРАТЬ
			             |	Номенклатура.Ссылка КАК Ссылка
			             |ИЗ
			             |	Справочник.Номенклатура КАК Номенклатура
			             |ГДЕ
			             |	Номенклатура.ЭтоГруппа
			             |	И НЕ Номенклатура.ПометкаУдаления
			             |	И Номенклатура.ГруппаПодбора В ИЕРАРХИИ(&Ссылка)";
			МассивГрупп = Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
			КэшДанных.ГруппыПодбора.Вставить(Элемент.ИмяКоманды, Новый Структура("ГруппаПодбора, ГруппыНоменклатуры", Выборка.ГруппаПодбора, МассивГрупп));  
			
		КонецЕсли;
		
	КонецЦикла;

	// создадим меню заполнения по производителям
	Запр2 = Новый Запрос;
	Запр2.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	Номенклатура.Производитель КАК Производитель
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	Номенклатура.Производитель <> ЗНАЧЕНИЕ(Справочник.Производители.ПустаяСсылка)
	             |	И НЕ Номенклатура.ПометкаУдаления";
	Выборка2 = запр2.Выполнить().Выбрать();
	Пока Выборка2.Следующий() Цикл 
		Представление2 = СтрокаБуквами(Выборка2.Производитель);
		Кмд = ЭтаФорма.Команды.Добавить("Команда2_" + Представление2);
		Кмд.Действие = "НажатиеКнопкиПодбораМеню";
		Кмд.Заголовок = Выборка2.Производитель;
		Элемент = ЭтаФорма.Элементы.Добавить("Кнопка2_" + Представление2, Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ТоварыГруппаЗаполнениеПодменю.ПодчиненныеЭлементы.ПодменюЗаполнитьПоБренду);
		Элемент.Вид 		= ВидКнопкиФормы.КнопкаКоманднойПанели;
		Элемент.ИмяКоманды 	= "Команда2_" + Представление2;
		КэшДанных.ЗначенияПодбора.Вставить(Элемент.ИмяКоманды, Выборка2.Производитель); 
	КонецЦикла;

	// заполним ТЗ на форме 
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.Текст = "ВЫБРАТЬ
	             |	МИНИМУМ(УстановкаЦенТовары.НомерСтроки) КАК НомерСтроки,
	             |	УстановкаЦенТовары.Номенклатура
	             |ИЗ
	             |	Документ.УстановкаЦен.Товары КАК УстановкаЦенТовары
	             |ГДЕ
	             |	УстановкаЦенТовары.Ссылка = &Ссылка
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	УстановкаЦенТовары.Номенклатура
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	НомерСтроки
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	УстановкаЦенТовары.Номенклатура,
	             |	УстановкаЦенТовары.ВидЦены,
	             |	УстановкаЦенТовары.Цена,
	             |	УстановкаЦенТовары.Количество,
	             |	УстановкаЦенТовары.РазрешитьПродажу
	             |ИЗ
	             |	Документ.УстановкаЦен.Товары КАК УстановкаЦенТовары
	             |ГДЕ
	             |	УстановкаЦенТовары.Ссылка = &Ссылка
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	УстановкаЦенТовары.Номенклатура,
	             |	УстановкаЦенТовары.ВидЦены,
	             |	УстановкаЦенТовары.Цена,
	             |	УстановкаЦенТовары.Количество,
	             |	УстановкаЦенТовары.РазрешитьПродажу";
	Результат = Запр.ВыполнитьПакет();
	Выборка = Результат[0].Выбрать(); 
	Ном = 0;
	Пока Выборка.Следующий() Цикл  
		Ном = Ном + 1;
		НовСтрока = Товары.Добавить();  
		НовСтрока.Ном 			= Ном;
		НовСтрока.Номенклатура 	= Выборка.Номенклатура;
	КонецЦикла;  
	Выборка = Результат[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТЗ = Товары.НайтиСтроки(Новый Структура("Номенклатура", Выборка.Номенклатура))[0];
		Префикс = ИмяЗначенияПеречисления(Выборка.ВидЦены);
		Если Выборка.Количество = -1 Тогда
			СтрокаТЗ[Префикс + "_ЦенаНовая"] 	= Выборка.Цена;
		Иначе
			СтрокаТЗ[Префикс + "_ЦенаКНовая"] 	= Выборка.Цена;
			СтрокаТЗ[Префикс + "_Количество"] 	= Выборка.Количество;
		КонецЕсли;
		Если Выборка.РазрешитьПродажу <> 0 Тогда
			СтрокаТЗ.Продавать = Выборка.РазрешитьПродажу;
		КонецЕсли;
	КонецЦикла;	
	
	ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(Результат[0].Выгрузить().ВыгрузитьКолонку("Номенклатура"));
	
КонецПроцедуры

