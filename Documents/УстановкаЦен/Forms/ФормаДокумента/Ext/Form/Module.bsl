&НаСервереБезКонтекста
Функция ИмяЗначенияПеречисления(ЗначениеПеречисления)

	ИмяПеречисления = ЗначениеПеречисления.Метаданные().Имя;
	ИндексЗначенияПеречисления = Перечисления[ИмяПеречисления].Индекс(ЗначениеПеречисления);
	Возврат Метаданные.Перечисления[ИмяПеречисления].ЗначенияПеречисления[ИндексЗначенияПеречисления].Имя;

КонецФункции 

&НаСервереБезКонтекста
Функция ОтобраннаяНоменклатура(ВариантОтбора, ЗначениеОтбора)
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	Номенклатура.Ссылка
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	НЕ Номенклатура.ПометкаУдаления
	             |	И НЕ Номенклатура.ЭтоГруппа
	             |	И ИСТИНА = ИСТИНА";
	Если ВариантОтбора = "ГруппаНоменклатуры" Тогда
		Условие = "Номенклатура.Ссылка В ИЕРАРХИИ(&Ссылка)";
	ИначеЕсли ВариантОтбора = "Менеджер" Тогда
		//Условие = "Номенклатура.Ссылка В ИЕРАРХИИ(&Ссылка)";	
	
	КонецЕсли;
	Запр.Текст = СтрЗаменить(Запр.Текст, "ИСТИНА = ИСТИНА", Условие);
	Выгрузка = Запр.Выполнить().Выгрузить();
	Возврат Выгрузка.ВыгрузитьКолонку(0);

КонецФункции 

