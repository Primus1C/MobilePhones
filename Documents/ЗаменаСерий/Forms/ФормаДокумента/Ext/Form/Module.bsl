#Область СобытияФормы      

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяДокумента = Объект.Ссылка.Метаданные().Синоним;
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента);  
	
	ЭтоСтараяСерия = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);

	мСканерШК.СканерШКПодключить(); 
	
	УстановитьВидимость();

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)

	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 

КонецПроцедуры

#КонецОбласти    


#Область РеквизитыФормы
	
&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	Если  Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацииЗаменаСерий.ЗаменаНоменклатурыВОднойСерии") Тогда
		ЭтоСтараяСерия = Истина;
	КонецЕсли;
	
	УстановитьВидимость();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимость()
	
	Режим = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацииЗаменаСерий.ЗаменаНоменклатурыВОднойСерии");
	Элементы.ТоварыНоменклатураНовая.Видимость = Режим;
	Элементы.ТоварыСерияНовая.Видимость = НЕ Режим;
	Элементы.ЭтоСтараяСерия.Видимость = НЕ Режим;
	
КонецПроцедуры

#КонецОбласти


