
// ─── Поиск контрагента ───────────────────────────────────────────────────────

// Поиск контрагента по коду или наименованию (поддержка legacy-полей customer/customerCode).
Функция НайтиКонтрагента(ДанныеЗапроса, УчетнаяЗапись, Ошибка) Экспорт
	
	ГруппаКонтрагентов = УчетнаяЗапись.ГруппаКонтрагентов;
	Если НЕ ЗначениеЗаполнено(ГруппаКонтрагентов) Тогда
		Ошибка = "В 1С не указана группа контрагентов учетной записи интеграции.";
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	КодПоиска = "";
	ШаблонПоиска = ""; 
	
	Если ДанныеЗапроса.Свойство("counterpartyCode") И СокрЛП(ДанныеЗапроса.counterpartyCode) <> "" Тогда
		КодПоиска = СокрЛП(ДанныеЗапроса.counterpartyCode);	
	КонецЕсли;
	Если КодПоиска = "" И ДанныеЗапроса.Свойство("customerCode") И СокрЛП(ДанныеЗапроса.customerCode) <> "" Тогда
		КодПоиска = СокрЛП(ДанныеЗапроса.customerCode);	
	КонецЕсли;  
	Если КодПоиска = "" И ДанныеЗапроса.Свойство("code") И СокрЛП(ДанныеЗапроса.code) <> "" Тогда
		КодПоиска = СокрЛП(ДанныеЗапроса.code);	
	КонецЕсли;  
	Если КодПоиска <> "" Тогда 
		Попытка
			КодПоиска = Число(КодПоиска);
		Исключение
		    Ошибка = СтрШаблон("Значение кода контрагента не числовое: '%1'.", КодПоиска);
			Возврат Справочники.Контрагенты.ПустаяСсылка();
		КонецПопытки;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("counterparty") И СокрЛП(ДанныеЗапроса.counterparty) <> "" Тогда
		ШаблонПоиска = СокрЛП(ДанныеЗапроса.counterparty);	
	КонецЕсли;
	Если ШаблонПоиска = "" И ДанныеЗапроса.Свойство("customer") И СокрЛП(ДанныеЗапроса.customer) <> "" Тогда
		ШаблонПоиска = СокрЛП(ДанныеЗапроса.customer);	
	КонецЕсли;
	Если ШаблонПоиска = "" И ДанныеЗапроса.Свойство("name") И СокрЛП(ДанныеЗапроса.name) <> "" Тогда
		ШаблонПоиска = СокрЛП(ДанныеЗапроса.name);	
	КонецЕсли;
	
	Если КодПоиска = "" И ШаблонПоиска = "" Тогда
		Ошибка = "В запросе нет кода и/или наименования контрагента (counterpartyCode или customerCode или code, counterparty или customer или name).";
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли; 
	
    Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Код", 					КодПоиска);
	Запр.УстановитьПараметр("Наименование", 		ШаблонПоиска);
	Запр.УстановитьПараметр("ГруппаКонтрагентов", 	ГруппаКонтрагентов);
	Запр.Текст = "ВЫБРАТЬ
	             |	Контрагенты.Ссылка КАК Контрагент
	             |ИЗ
	             |	Справочник.Контрагенты КАК Контрагенты
	             |ГДЕ
	             |	НЕ Контрагенты.ПометкаУдаления
	             |	И ВЫБОР
	             |			КОГДА &Код = """"
	             |				ТОГДА ИСТИНА
	             |			ИНАЧЕ Контрагенты.Код = &Код
	             |		КОНЕЦ
	             |	И ВЫБОР
	             |			КОГДА &Наименование = """"
	             |				ТОГДА ИСТИНА
	             |			ИНАЧЕ Контрагенты.Наименование = &Наименование
	             |		КОНЕЦ
	             |	И Контрагенты.Ссылка В ИЕРАРХИИ(&ГруппаКонтрагентов)";
	Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Контрагент;
	Иначе
		Ошибка = "Контрагент не найден.";
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// ─── Список контрагентов и CRUD ───────────────────────────────────────────── 

Функция НаименованиеКонтрагентаИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("counterparty") И СокрЛП(ДанныеЗапроса.counterparty) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.counterparty);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("name") И СокрЛП(ДанныеЗапроса.name) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.name);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("customer") И СокрЛП(ДанныеЗапроса.customer) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.customer);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция СтруктураКонтрагентаJSON(Стр)
	
	Элемент = Новый Структура;
	Элемент.Вставить("counterparty", 		Стр.Наименование);
	Элемент.Вставить("counterpartyCode", 	StockAPI_Утилиты.КодВСтроку(Стр.Код));
	Элемент.Вставить("email", 				Стр.email);
	Элемент.Вставить("phone",				Стр.Телефоны);
	Элемент.Вставить("city", 				Строка(Стр.Город));
	Элемент.Вставить("cityCode", 			StockAPI_Утилиты.КодВСтроку(Стр.ГородКод));
	Элемент.Вставить("address", 			Стр.Адрес);
	Элемент.Вставить("priceType", 			Строка(Стр.ВидЦены));
	Элемент.Вставить("currency", 			Строка(Стр.Валюта));
	Возврат Элемент;
	
КонецФункции

Функция КоличествоКонтрагентов(СтрокаПоиска, СтрокаКода, Группа)
	
	ШаблонПоиска 	= ?(ЗначениеЗаполнено(СтрокаПоиска), "%" + СтрокаПоиска + "%", Неопределено);
	КодЧисло 		= ?(ЗначениеЗаполнено(СтрокаКода), Число(СтрокаКода), Неопределено);
	
	Зап = Новый Запрос;
	Зап.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(Конт.Ссылка) КАК Количество
		|ИЗ
		|	Справочник.Контрагенты КАК Конт
		|ГДЕ
		|	НЕ Конт.ЭтоГруппа
		|	И НЕ Конт.ПометкаУдаления
		|	И Конт.Ссылка В ИЕРАРХИИ(&Группа)
		|{ГДЕ
		|	(Конт.Код = &Код
		|			ИЛИ Конт.Наименование ПОДОБНО &ШаблонПоиска)}";
	Зап.УстановитьПараметр("Группа", 		Группа);
	Зап.УстановитьПараметр("ШаблонПоиска", 	ШаблонПоиска);
	Зап.УстановитьПараметр("Код", 			КодЧисло);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Количество;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция КонтрагентыСтраница(СтрокаПоиска, СтрокаКода, РазмерСтраницы, Пропустить, Группа)
	
	ШаблонПоиска 	= ?(ЗначениеЗаполнено(СтрокаПоиска), "%" + СтрокаПоиска + "%", "");
	КодЧисло 		= ?(ЗначениеЗаполнено(СтрокаКода), Число(СтрокаКода), Неопределено);
	
	Если РазмерСтраницы <= 0 Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ " + РазмерСтраницы + ?(Пропустить > 0, " ПРОПУСТИТЬ " + Пропустить, "") + "
		//"ВЫБРАТЬ
		|	Конт.Ссылка КАК Ссылка,
		|	Конт.Код КАК Код,
		|	Конт.Наименование КАК Наименование,
		|	Конт.Email КАК email,
		|	Конт.Телефоны КАК Телефоны,
		|	Конт.Город.Наименование КАК Город,
		|	Конт.Город.Код КАК ГородКод,
		|	Конт.Адрес КАК Адрес,
		|	Конт.ВидЦены.Наименование КАК ВидЦены,
		|	Конт.ВидЦены.Валюта.Наименование КАК Валюта
		|ИЗ
		|	Справочник.Контрагенты КАК Конт
		|ГДЕ
		|	НЕ Конт.ЭтоГруппа
		|	И НЕ Конт.ПометкаУдаления
		|	И Конт.Ссылка В ИЕРАРХИИ(&Группа)
		|	И ВЫБОР
		|			КОГДА &Код = НЕОПРЕДЕЛЕНО
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ Конт.Код = &Код
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &ШаблонПоиска = """"
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ Конт.Наименование ПОДОБНО &ШаблонПоиска
		|		КОНЕЦ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Конт.Наименование";
	Зап.УстановитьПараметр("Группа", 		Группа);
	Зап.УстановитьПараметр("ШаблонПоиска", 	ШаблонПоиска);
	Зап.УстановитьПараметр("Код", 			КодЧисло);
	
	Возврат Зап.Выполнить().Выгрузить();
	
КонецФункции

// GET /counterparties — список контрагентов с пагинацией; type=customer|supplier — фильтр по типу. 
//
Функция ПолучитьСписокКонтрагентов(Запрос, Группа) Экспорт
	
	Результат = Новый Структура("Тело, Ошибка", Неопределено, "");
	
	Если НЕ ЗначениеЗаполнено(Группа) Тогда
		Результат.Ошибка = "В 1С не указана группа контрагентов в учетной записи интеграции.";
		Возврат Результат;
	КонецЕсли;

	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Результат.Ошибка = Пагинация.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	СтрокаПоиска = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "search");
	СтрокаКода = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "counterpartyCode");
	Если СтрокаКода = "" Тогда
		СтрокаКода = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "code");
	КонецЕсли;
	
	ВсегоКонтрагентов = КоличествоКонтрагентов(СтрокаПоиска, СтрокаКода, Группа);
	ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоКонтрагентов, Пагинация.pageSize);
	Пропустить = (Пагинация.page - 1) * Пагинация.pageSize;
	Таблица = КонтрагентыСтраница(СтрокаПоиска, СтрокаКода, Пагинация.pageSize, Пропустить, Группа);
	
	Массив = Новый Массив;
	Для Каждого Стр Из Таблица Цикл
		Массив.Добавить(СтруктураКонтрагентаJSON(Стр));
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("page", 		Пагинация.page);
	ТелоОтвета.Вставить("pageSize", 	Пагинация.pageSize);
	ТелоОтвета.Вставить("totalItems", 	ВсегоКонтрагентов);
	ТелоОтвета.Вставить("totalPages", 	ВсегоСтраниц);
	ТелоОтвета.Вставить("items", 		Массив);
	Результат.Тело = ТелоОтвета;
	Возврат Результат;
	
КонецФункции

// POST /counterparties — создание контрагента в справочнике.
//
Функция СоздатьКонтрагента(ДанныеЗапроса, Группа) Экспорт
	
	Результат = Новый Структура("success, error, counterparty, counterpartyCode", Ложь, "", "", "");
	
	Если НЕ ЗначениеЗаполнено(Группа) Тогда
		Результат.error = "В 1С не указана группа контрагентов в учетной записи интеграции.";
		Возврат Результат;
	КонецЕсли;

	Наименование = НаименованиеКонтрагентаИзЗапроса(ДанныеЗапроса);
	Если Наименование = "" Тогда
		Результат.error = "Укажите наименование контрагента (counterparty, name или customer).";
		Возврат Результат;
	КонецЕсли;
	
	Существующий = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина, Группа);
	Если ЗначениеЗаполнено(Существующий) Тогда
		Результат.error = СтрШаблон("Контрагент '%1' уже существует (код %2).",
									Наименование,
									StockAPI_Утилиты.КодВСтроку(Существующий.Код));
		Возврат Результат;
	КонецЕсли;

	Объект = Справочники.Контрагенты.СоздатьЭлемент(); 
	Объект.УстановитьНовыйКод();
	Объект.Наименование = Наименование; 
	Объект.Псевдоним = "API-" + StockAPI_Утилиты.КодВСтроку(Объект.Код);
	Объект.Родитель = Группа;
	
	Если ДанныеЗапроса.Свойство("email") Тогда
		Объект.Email = СокрЛП(ДанныеЗапроса.email);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("phone") Тогда
		Объект.Телефоны = СокрЛП(ДанныеЗапроса.phone);
	ИначеЕсли ДанныеЗапроса.Свойство("phones") Тогда
		Объект.Телефоны = СокрЛП(ДанныеЗапроса.phones);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("city") Тогда
		Объект.Город = Справочники.Города.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.city));
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("address") Тогда
		Объект.Адрес = СокрЛП(ДанныеЗапроса.address);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("note") Тогда
		Объект.Примечание = СокрЛП(ДанныеЗапроса.note);
	ИначеЕсли ДанныеЗапроса.Свойство("comment") Тогда
		Объект.Примечание = СокрЛП(ДанныеЗапроса.comment);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("priceType") Тогда
		Объект.ВидЦены = Справочники.ВидыЦен.НайтиПоНаименованию(ДанныеЗапроса.priceType, Истина);
	КонецЕсли;

	Попытка
		Объект.Записать();
	Исключение
		Результат.error = "Не удалось создать контрагента: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	КодСтрокой = StockAPI_Утилиты.КодВСтроку(Объект.Код);
	
	Результат.success = Истина;
	Результат.counterparty = Объект.Наименование;
	Результат.counterpartyCode = КодСтрокой;
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСписокГородов(Запрос) Экспорт

	Результат = Новый Структура("Тело, Ошибка", Неопределено, "");
	
	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Результат.Ошибка = Пагинация.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	СтрокаПоиска = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "search");
	СтрокаКода = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "cityCode");
	Если СтрокаКода = "" Тогда
		СтрокаКода = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "code");
	КонецЕсли;
	
	ТаблицаГородов = ТаблицаГородов(СтрокаПоиска, СтрокаКода);
	ВсегоГородов = ТаблицаГородов.Количество();   
	РазмерСтраницы = Пагинация.pageSize;
	ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоГородов, РазмерСтраницы);
	Пропустить = (Пагинация.page - 1) * РазмерСтраницы;
	
	МассивСтрок = Новый Массив;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("ТЗ", ТаблицаГородов);
	Запр.Текст = "ВЫБРАТЬ
				|	ТЗ.ГородКод КАК ГородКод,
				|	ТЗ.Город КАК Город,
				|	ТЗ.Страна КАК Страна,
				|	ТЗ.СтранаКод КАК СтранаКод
	             |ПОМЕСТИТЬ ВТ
	             |ИЗ
	             |	&ТЗ КАК ТЗ
	             |;
	             |
				|ВЫБРАТЬ ПЕРВЫЕ " + РазмерСтраницы + ?(Пропустить > 0, " ПРОПУСТИТЬ " + Пропустить, "") + "
	            //|ВЫБРАТЬ
	             |	ВТ.ГородКод КАК ГородКод,
	             |	ВТ.Город КАК Город,
	             |	ВТ.Страна КАК Страна,
	             |	ВТ.СтранаКод КАК СтранаКод
	             |ИЗ
	             |	ВТ КАК ВТ
				 |УПОРЯДОЧИТЬ ПО
				 |	ВТ.Страна, ВТ.Город";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Элемент = Новый Структура; 
		Элемент.Вставить("city", 		Выборка.Город);
		Элемент.Вставить("cityCode", 	Формат(Выборка.ГородКод,"ЧГ="));
		Элемент.Вставить("country",		Строка(Выборка.Страна));
		Элемент.Вставить("countryCode",	Формат(Выборка.СтранаКод,"ЧГ="));
		МассивСтрок.Добавить(Элемент);
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("page", 		Пагинация.page);
	ТелоОтвета.Вставить("pageSize", 	РазмерСтраницы);
	ТелоОтвета.Вставить("totalItems", 	ВсегоГородов);
	ТелоОтвета.Вставить("totalPages", 	ВсегоСтраниц);
	ТелоОтвета.Вставить("items", 		МассивСтрок);
	
	Возврат Новый Структура("КодОтвета, Тело, Ошибка", 200, ТелоОтвета, "");
		

КонецФункции // ПолучитьСписокГородов()

Функция ТаблицаГородов(СтрокаПоиска, СтрокаКода)
	
	ШаблонПоиска 	= ?(ЗначениеЗаполнено(СтрокаПоиска), "%" + СтрокаПоиска + "%", "");
	КодЧисло 		= ?(ЗначениеЗаполнено(СтрокаКода), Число(СтрокаКода), Неопределено);
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	Города.Код КАК ГородКод,
	             |	Города.Наименование КАК Город,
	             |	Города.Страна.Наименование КАК Страна,
	             |	Города.Страна.Код КАК СтранаКод
	             |ИЗ
	             |	Справочник.Города КАК Города
	             |ГДЕ
	             |	НЕ Города.ПометкаУдаления
	             |	И ВЫБОР
	             |			КОГДА &Код = НЕОПРЕДЕЛЕНО
	             |				ТОГДА ИСТИНА
	             |			ИНАЧЕ Города.Код = &Код
	             |		КОНЕЦ
	             |	И ВЫБОР
	             |			КОГДА &ШаблонПоиска = """"
	             |				ТОГДА ИСТИНА
	             |			ИНАЧЕ Города.Наименование ПОДОБНО &ШаблонПоиска
	             |		КОНЕЦ";
	Запр.УстановитьПараметр("ШаблонПоиска", 	ШаблонПоиска);
	Запр.УстановитьПараметр("Код", 			КодЧисло);
	
	Возврат Запр.Выполнить().Выгрузить();
	
КонецФункции