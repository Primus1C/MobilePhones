// Контрагенты StockAPI: поиск, группы покупателей/поставщиков, CRUD.
// Зависимости: StockAPI_Справочники.КодКонтрагентаВСтроку

// ─── Поиск контрагента ───────────────────────────────────────────────────────

// Поиск контрагента по коду или наименованию (поддержка legacy-полей customer/customerCode).
Функция НайтиКонтрагента(ДанныеЗапроса) Экспорт
	
	Если ДанныеЗапроса.Свойство("counterpartyCode") И СокрЛП(ДанныеЗапроса.counterpartyCode) <> "" Тогда
		Контрагент = Справочники.Контрагенты.НайтиПоКоду(СокрЛП(ДанныеЗапроса.counterpartyCode));
		Если ЗначениеЗаполнено(Контрагент) Тогда
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("customerCode") И СокрЛП(ДанныеЗапроса.customerCode) <> "" Тогда
		Контрагент = Справочники.Контрагенты.НайтиПоКоду(СокрЛП(ДанныеЗапроса.customerCode));
		Если ЗначениеЗаполнено(Контрагент) Тогда
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("counterparty") И СокрЛП(ДанныеЗапроса.counterparty) <> "" Тогда
		Возврат Справочники.Контрагенты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.counterparty), Истина);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("customer") И СокрЛП(ДанныеЗапроса.customer) <> "" Тогда
		Возврат Справочники.Контрагенты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.customer), Истина);
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

// ─── Группы контрагентов ─────────────────────────────────────────────────────

Функция ГруппаПокупателей()
	Возврат ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("КонтрагентыПокупатели");
КонецФункции

Функция ГруппаПоставщиков()
	Возврат ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("КонтрагентыПоставщики");
КонецФункции

Функция ТипКонтрагентаИзПараметра(ЗначениеТипа) Экспорт
	
	ТипКонтрагента = НРег(СокрЛП(Строка(ЗначениеТипа)));
	
	Если ТипКонтрагента = "supplier"
		Или ТипКонтрагента = "поставщик"
		Или ТипКонтрагента = "suppliers" Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Возврат "customer";
	
КонецФункции

Функция ТипКонтрагентаИзЗапроса(ДанныеЗапроса) Экспорт
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат "customer";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("type") Тогда
		Возврат ТипКонтрагентаИзПараметра(ДанныеЗапроса.type);
	КонецЕсли;
	
	Возврат "customer";
	
КонецФункции

Функция ИмяНастройкиГруппыКонтрагентов(ТипКонтрагента) Экспорт
	
	Если ТипКонтрагента = "supplier" Тогда
		Возврат "КонтрагентыПоставщики";
	КонецЕсли;
	
	Возврат "КонтрагентыПокупатели";
	
КонецФункции

Функция ГруппаКонтрагентовИзНастройки(ТипКонтрагента)
	
	Если ТипКонтрагента = "supplier" Тогда
		Возврат ГруппаПоставщиков();
	КонецЕсли;
	
	Возврат ГруппаПокупателей();
	
КонецФункции

Функция ИмяГруппыПоУмолчанию(ТипКонтрагента)
	
	Если ТипКонтрагента = "supplier" Тогда
		Возврат "Поставщики API";
	КонецЕсли;
	
	Возврат "Покупатели API";
	
КонецФункции

Функция ИменаГруппДляПоиска(ТипКонтрагента) Экспорт
	
	МассивИмен = Новый Массив;
	МассивИмен.Добавить(ИмяГруппыПоУмолчанию(ТипКонтрагента));
	
	Если ТипКонтрагента = "supplier" Тогда
		МассивИмен.Добавить("Поставщики");
		МассивИмен.Добавить("Контрагенты поставщики");
	Иначе
		МассивИмен.Добавить("Покупатели");
		МассивИмен.Добавить("Контрагенты покупатели");
	КонецЕсли;
	
	Возврат МассивИмен;
	
КонецФункции

Функция НайтиГруппуКонтрагентовПоИмени(ИмяГруппы)
	
	Имя = СокрЛП(ИмяГруппы);
	Если Имя = "" Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Конт.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|	И Конт.Наименование = &Наименование";
	Зап.УстановитьПараметр("Наименование", Имя);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция НайтиГруппуКонтрагентовПоКоду(КодГруппы)
	
	КодСтрока = СокрЛП(Строка(КодГруппы));
	Если КодСтрока = "" Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Группа = Справочники.Контрагенты.НайтиПоКоду(Число(КодСтрока));
	Если ЗначениеЗаполнено(Группа) И Группа.ЭтоГруппа Тогда
		Возврат Группа;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция ИмяГруппыИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("group") И СокрЛП(ДанныеЗапроса.group) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.group);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("parent") И СокрЛП(ДанныеЗапроса.parent) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.parent);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("groupName") И СокрЛП(ДанныеЗапроса.groupName) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.groupName);
	КонецЕсли;
	
	// name — только для POST /counterparty-groups (создание группы).
	Если ДанныеЗапроса.Свойство("name") И СокрЛП(ДанныеЗапроса.name) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.name);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Группа только из явных полей запроса (group / groupCode) — без настроек и автопоиска.
Функция ГруппаКонтрагентовИзЗапросаСоздания(ДанныеЗапроса)
	
	Результат = Новый Структура("Группа, Ошибка", Справочники.Контрагенты.ПустаяСсылка(), "");
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.Ошибка = "Укажите group (наименование) или groupCode (код группы).";
		Возврат Результат;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("groupCode") И СокрЛП(Строка(ДанныеЗапроса.groupCode)) <> "" Тогда
		Группа = НайтиГруппуКонтрагентовПоКоду(ДанныеЗапроса.groupCode);
		Если ЗначениеЗаполнено(Группа) Тогда
			Результат.Группа = Группа;
			Возврат Результат;
		КонецЕсли;
		Результат.Ошибка = СтрШаблон("Группа с кодом %1 не найдена.", СокрЛП(Строка(ДанныеЗапроса.groupCode)));
		Возврат Результат;
	КонецЕсли;
	
	ИмяГруппы = ИмяГруппыИзЗапроса(ДанныеЗапроса);
	Если ИмяГруппы <> "" Тогда
		Группа = НайтиГруппуКонтрагентовПоИмени(ИмяГруппы);
		Если ЗначениеЗаполнено(Группа) Тогда
			Результат.Группа = Группа;
			Возврат Результат;
		КонецЕсли;
		Результат.Ошибка = СтрШаблон("Группа ""%1"" не найдена.", ИмяГруппы);
		Возврат Результат;
	КонецЕсли;
	
	Результат.Ошибка = "Укажите group (наименование) или groupCode (код группы).";
	Возврат Результат;
	
КонецФункции

Функция ТипГруппыКонтрагентов(Группа)
	
	Если НЕ ЗначениеЗаполнено(Группа) Тогда
		Возврат "";
	КонецЕсли;
	
	ТипПоИмени = ТипКонтрагентаПоИмениГруппы(Группа);
	Если ТипПоИмени <> "" Тогда
		Возврат ТипПоИмени;
	КонецЕсли;
	
	Если ПринадлежитЛюбойГруппе(Группа, КорневыеГруппыТипа("supplier")) Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Если ПринадлежитЛюбойГруппе(Группа, КорневыеГруппыТипа("customer")) Тогда
		Возврат "customer";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция АвтоСозданиеГруппыРазрешено(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("autoCreateGroup") Тогда
		Возврат ДанныеЗапроса.autoCreateGroup = Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Процедура УстановитьГруппуВНастройках(ТипКонтрагента, Группа)
	РегистрыСведений.НастройкиПользователей.Установить(Группа, ИмяНастройкиГруппыКонтрагентов(ТипКонтрагента));
КонецПроцедуры

Функция СоздатьГруппуКонтрагентовВСправочнике(ИмяГруппы)
	
	Объект = Справочники.Контрагенты.СоздатьГруппу();
	Объект.Наименование = СокрЛП(ИмяГруппы);
	Объект.Записать();
	Возврат Объект.Ссылка;
	
КонецФункции

// Разрешает группу контрагентов: по коду, имени, настройке или автосоздаёт.
Функция РазрешитьГруппуКонтрагентов(ДанныеЗапроса, АвтоСоздать = Ложь) Экспорт
	
	ТипКонтрагента = ТипКонтрагентаИзЗапроса(ДанныеЗапроса);
	
	Если ДанныеЗапроса <> Неопределено И ДанныеЗапроса.Свойство("groupCode") Тогда
		Группа = НайтиГруппуКонтрагентовПоКоду(ДанныеЗапроса.groupCode);
		Если ЗначениеЗаполнено(Группа) Тогда
			Возврат Группа;
		КонецЕсли;
	КонецЕсли;
	
	ИмяГруппы = ИмяГруппыИзЗапроса(ДанныеЗапроса);
	Если ИмяГруппы <> "" Тогда
		Группа = НайтиГруппуКонтрагентовПоИмени(ИмяГруппы);
		Если ЗначениеЗаполнено(Группа) Тогда
			Возврат Группа;
		КонецЕсли;
	КонецЕсли;
	
	Группа = ГруппаКонтрагентовИзНастройки(ТипКонтрагента);
	Если ЗначениеЗаполнено(Группа) Тогда
		Возврат Группа;
	КонецЕсли;
	
	Для Каждого ИмяПоиска Из ИменаГруппДляПоиска(ТипКонтрагента) Цикл
		Группа = НайтиГруппуКонтрагентовПоИмени(ИмяПоиска);
		Если ЗначениеЗаполнено(Группа) Тогда
			УстановитьГруппуВНастройках(ТипКонтрагента, Группа);
			Возврат Группа;
		КонецЕсли;
	КонецЦикла;
	
	Если АвтоСоздать Тогда
		Группа = СоздатьГруппуКонтрагентовВСправочнике(ИмяГруппыПоУмолчанию(ТипКонтрагента));
		УстановитьГруппуВНастройках(ТипКонтрагента, Группа);
		Возврат Группа;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция ГруппаКонтрагентовПоТипу(ДанныеЗапроса) Экспорт
	Возврат РазрешитьГруппуКонтрагентов(ДанныеЗапроса, АвтоСозданиеГруппыРазрешено(ДанныеЗапроса));
КонецФункции

// ─── Списки и сведения о группах ─────────────────────────────────────────────

Функция ПолучитьСписокГруппКонтрагентов()
	
	Массив = Новый Массив;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Конт.Наименование КАК group,
	|	Конт.Код КАК Код
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Конт.Наименование";
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("group", Строка(Выборка.group));
		Элемент.Вставить("groupCode", StockAPI_Справочники.КодКонтрагентаВСтроку(Выборка.Код));
		Массив.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Массив;
	
КонецФункции

// GET /counterparty-groups — список групп контрагентов (type=customer|supplier).
Функция ПолучитьСведенияОГруппахКонтрагентов(Запрос) Экспорт
	
	ТипКонтрагента = "customer";
	ПараметрТипа = Запрос.ПараметрыЗапроса.Получить("type");
	Если ПараметрТипа <> Неопределено Тогда
		ТипКонтрагента = ТипКонтрагентаИзПараметра(ПараметрТипа);
	КонецЕсли;
	
	ГруппаПоУмолчанию = ГруппаКонтрагентовИзНастройки(ТипКонтрагента);
	Настроена = ЗначениеЗаполнено(ГруппаПоУмолчанию);
	
	Элементы = Новый Массив;
	Для Каждого СтрГруппы Из ПолучитьСписокГруппКонтрагентов() Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("group", СтрГруппы.group);
		Элемент.Вставить("groupCode", СтрГруппы.groupCode);
		Элементы.Добавить(Элемент);
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("type", ТипКонтрагента);
	ТелоОтвета.Вставить("configured", Настроена);
	ТелоОтвета.Вставить("items", Элементы);
	
	Возврат ТелоОтвета;
	
КонецФункции

// POST /counterparty-groups — создать или найти группу, назначить как дефолтную.
Функция СоздатьГруппуКонтрагентовAPI(ДанныеЗапроса) Экспорт
	
	Результат = Новый Структура("success, error, type, group, groupCode, configured",
		Ложь, "", "", "", "", Ложь);
	
	ИмяГруппы = ИмяГруппыИзЗапроса(ДанныеЗапроса);
	Если ИмяГруппы = "" Тогда
		Результат.error = "Укажите name или group (наименование группы).";
		Возврат Результат;
	КонецЕсли;
	
	ТипКонтрагента = ТипКонтрагентаИзЗапроса(ДанныеЗапроса);
	Существующая = НайтиГруппуКонтрагентовПоИмени(ИмяГруппы);
	Если ЗначениеЗаполнено(Существующая) Тогда
		Группа = Существующая;
	Иначе
		Попытка
			Группа = СоздатьГруппуКонтрагентовВСправочнике(ИмяГруппы);
		Исключение
			Результат.error = "Не удалось создать группу: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			Возврат Результат;
		КонецПопытки;
	КонецЕсли;
	
	УстановитьПоУмолчанию = Истина;
	Если ДанныеЗапроса.Свойство("setAsDefault") Тогда
		УстановитьПоУмолчанию = ДанныеЗапроса.setAsDefault = Истина;
	ИначеЕсли ДанныеЗапроса.Свойство("configure") Тогда
		УстановитьПоУмолчанию = ДанныеЗапроса.configure = Истина;
	КонецЕсли;
	
	Если УстановитьПоУмолчанию Тогда
		УстановитьГруппуВНастройках(ТипКонтрагента, Группа);
	КонецЕсли;
	
	Результат.success = Истина;
	Результат.type = ТипКонтрагента;
	Результат.group = Строка(Группа);
	Результат.groupCode = StockAPI_Справочники.КодКонтрагентаВСтроку(Группа.Код);
	Результат.configured = УстановитьПоУмолчанию;
	Возврат Результат;
	
КонецФункции

// ─── Список контрагентов и CRUD ─────────────────────────────────────────────

Функция ТипКонтрагентаИзПараметраЗапроса(Запрос)
	
	ПараметрТипа = Запрос.ПараметрыЗапроса.Получить("type");
	Если ПараметрТипа = Неопределено Или СокрЛП(Строка(ПараметрТипа)) = "" Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ТипКонтрагентаИзПараметра(ПараметрТипа);
	
КонецФункции

Функция КорневыеГруппыТипа(ТипКонтрагента)
	
	МассивГрупп = Новый Массив;
	Уникальные = Новый Соответствие;
	
	ГруппаНастройки = ГруппаКонтрагентовИзНастройки(ТипКонтрагента);
	Если ЗначениеЗаполнено(ГруппаНастройки) Тогда
		Уникальные.Вставить(ГруппаНастройки, Истина);
		МассивГрупп.Добавить(ГруппаНастройки);
	КонецЕсли;
	
	Для Каждого ИмяПоиска Из ИменаГруппДляПоиска(ТипКонтрагента) Цикл
		Группа = НайтиГруппуКонтрагентовПоИмени(ИмяПоиска);
		Если ЗначениеЗаполнено(Группа) И Уникальные.Получить(Группа) = Неопределено Тогда
			Уникальные.Вставить(Группа, Истина);
			МассивГрупп.Добавить(Группа);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивГрупп;
	
КонецФункции

Функция ПринадлежитЛюбойГруппе(СсылкаКонтрагента, МассивГрупп)
	
	Для Каждого Группа Из МассивГрупп Цикл
		Если СсылкаКонтрагента.ПринадлежитЭлементу(Группа) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ТипКонтрагентаПоИмениГруппы(ИмяГруппы)
	
	Имя = НРег(СокрЛП(Строка(ИмяГруппы)));
	Если Имя = "" Тогда
		Возврат "";
	КонецЕсли;
	
	Если СтрНайти(Имя, "поставщ") > 0
		Или СтрНайти(Имя, "supplier") > 0 Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Если СтрНайти(Имя, "покупател") > 0
		Или СтрНайти(Имя, "customer") > 0 Тогда
		Возврат "customer";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ТипКонтрагентаПоСсылке(СсылкаКонтрагента, ГруппыПоставщиков = Неопределено, ГруппыПокупателей = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ГруппыПоставщиков = Неопределено Тогда
		ГруппыПоставщиков = КорневыеГруппыТипа("supplier");
	КонецЕсли;
	
	Если ГруппыПокупателей = Неопределено Тогда
		ГруппыПокупателей = КорневыеГруппыТипа("customer");
	КонецЕсли;
	
	Если ПринадлежитЛюбойГруппе(СсылкаКонтрагента, ГруппыПоставщиков) Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Если ПринадлежитЛюбойГруппе(СсылкаКонтрагента, ГруппыПокупателей) Тогда
		Возврат "customer";
	КонецЕсли;
	
	Возврат ТипКонтрагентаПоИмениГруппы(СсылкаКонтрагента.Родитель);
	
КонецФункции

Функция НаименованиеКонтрагентаИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("counterparty") И СокрЛП(ДанныеЗапроса.counterparty) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.counterparty);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("name") И СокрЛП(ДанныеЗапроса.name) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.name);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("customer") И СокрЛП(ДанныеЗапроса.customer) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.customer);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ТипКонтрагентаДляОтвета(Группа, ТипКонтрагента = "customer")
	
	Если ТипКонтрагента = "supplier" Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Группа) И ЗначениеЗаполнено(ГруппаПоставщиков()) И Группа = ГруппаПоставщиков() Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Возврат "customer";
	
КонецФункции

Функция СтруктураКонтрагентаJSON(Стр, ТипКонтрагента = "", ГруппыПоставщиков = Неопределено, ГруппыПокупателей = Неопределено)
	
	Элемент = Новый Структура;
	Элемент.Вставить("type", ?(ТипКонтрагента = "",
		ТипКонтрагентаПоСсылке(Стр.Ссылка, ГруппыПоставщиков, ГруппыПокупателей),
		ТипКонтрагента));
	Элемент.Вставить("counterparty", Строка(Стр.Наименование));
	Элемент.Вставить("counterpartyCode", StockAPI_Справочники.КодКонтрагентаВСтроку(Стр.Код));
	Элемент.Вставить("alias", Строка(Стр.alias));
	Элемент.Вставить("email", Строка(Стр.email));
	Элемент.Вставить("phone", Строка(Стр.phone));
	Элемент.Вставить("city", Строка(Стр.city));
	Элемент.Вставить("address", Строка(Стр.address));
	Элемент.Вставить("group", Строка(Стр.group));
	Элемент.Вставить("groupCode", StockAPI_Справочники.КодКонтрагентаВСтроку(Стр.groupCode));
	Возврат Элемент;
	
КонецФункции

Функция КоличествоКонтрагентов(ГруппаТипа, СтрокаПоиска, СтрокаКода)
	
	БезФильтраПоТипу = НЕ ЗначениеЗаполнено(ГруппаТипа);
	БезПоиска = СтрокаПоиска = "";
	ШаблонПоиска = "%" + СтрокаПоиска + "%";
	БезКода = СтрокаКода = "";
	КодЧисло = ?(БезКода, 0, Число(СтрокаКода));
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(Конт.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	НЕ Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|	И (&БезФильтраПоТипу
	|		ИЛИ Конт.Ссылка В ИЕРАРХИИ (&ГруппаТипа))
	|	И (&БезПоиска
	|		ИЛИ Конт.Наименование ПОДОБНО &ШаблонПоиска
	|		ИЛИ Конт.Псевдоним ПОДОБНО &ШаблонПоиска)
	|	И (&БезКода
	|		ИЛИ Конт.Код = &Код)";
	Зап.УстановитьПараметр("БезФильтраПоТипу", БезФильтраПоТипу);
	Зап.УстановитьПараметр("ГруппаТипа", ГруппаТипа);
	Зап.УстановитьПараметр("БезПоиска", БезПоиска);
	Зап.УстановитьПараметр("ШаблонПоиска", ШаблонПоиска);
	Зап.УстановитьПараметр("БезКода", БезКода);
	Зап.УстановитьПараметр("Код", КодЧисло);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Количество;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция КонтрагентыСтраница(ГруппаТипа, СтрокаПоиска, СтрокаКода, РазмерСтраницы, Пропустить)
	
	БезФильтраПоТипу = НЕ ЗначениеЗаполнено(ГруппаТипа);
	БезПоиска = СтрокаПоиска = "";
	ШаблонПоиска = "%" + СтрокаПоиска + "%";
	БезКода = СтрокаКода = "";
	КодЧисло = ?(БезКода, 0, Число(СтрокаКода));
	
	Если РазмерСтраницы <= 0 Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ " + РазмерСтраницы + ?(Пропустить > 0, " ПРОПУСТИТЬ " + Пропустить, "") + "
	|	Конт.Ссылка КАК Ссылка,
	|	Конт.Код КАК Код,
	|	Конт.Наименование КАК Наименование,
	|	Конт.Псевдоним КАК alias,
	|	Конт.Email КАК email,
	|	Конт.Телефоны КАК phone,
	|	Конт.Город КАК city,
	|	Конт.Адрес КАК address,
	|	Конт.Родитель.Наименование КАК group,
	|	Конт.Родитель.Код КАК groupCode
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	НЕ Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|	И (&БезФильтраПоТипу
	|		ИЛИ Конт.Ссылка В ИЕРАРХИИ (&ГруппаТипа))
	|	И (&БезПоиска
	|		ИЛИ Конт.Наименование ПОДОБНО &ШаблонПоиска
	|		ИЛИ Конт.Псевдоним ПОДОБНО &ШаблонПоиска)
	|	И (&БезКода
	|		ИЛИ Конт.Код = &Код)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Конт.Наименование";
	Зап.УстановитьПараметр("БезФильтраПоТипу", БезФильтраПоТипу);
	Зап.УстановитьПараметр("ГруппаТипа", ГруппаТипа);
	Зап.УстановитьПараметр("БезПоиска", БезПоиска);
	Зап.УстановитьПараметр("ШаблонПоиска", ШаблонПоиска);
	Зап.УстановитьПараметр("БезКода", БезКода);
	Зап.УстановитьПараметр("Код", КодЧисло);
	
	Возврат Зап.Выполнить().Выгрузить();
	
КонецФункции

// GET /counterparties — список контрагентов с пагинацией; type=customer|supplier — фильтр по типу.
Функция ПолучитьСписокКонтрагентов(Запрос) Экспорт
	
	Результат = Новый Структура("Тело, Ошибка", Неопределено, "");
	
	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Результат.Ошибка = Пагинация.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ТипФильтра = ТипКонтрагентаИзПараметраЗапроса(Запрос);
	ГруппаТипа = Справочники.Контрагенты.ПустаяСсылка();
	Если ТипФильтра <> "" Тогда
		ГруппаТипа = РазрешитьГруппуКонтрагентов(Новый Структура("type", ТипФильтра), Ложь);
	КонецЕсли;
	
	СтрокаПоиска = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "search");
	СтрокаКода = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "counterpartyCode");
	Если СтрокаКода = "" Тогда
		СтрокаКода = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "code");
	КонецЕсли;
	
	ВсегоКонтрагентов = КоличествоКонтрагентов(ГруппаТипа, СтрокаПоиска, СтрокаКода);
	ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоКонтрагентов, Пагинация.pageSize);
	Пропустить = (Пагинация.page - 1) * Пагинация.pageSize;
	Таблица = КонтрагентыСтраница(ГруппаТипа, СтрокаПоиска, СтрокаКода, Пагинация.pageSize, Пропустить);
	
	ГруппыПоставщиков = КорневыеГруппыТипа("supplier");
	ГруппыПокупателей = КорневыеГруппыТипа("customer");
	
	Массив = Новый Массив;
	Для Каждого Стр Из Таблица Цикл
		Массив.Добавить(СтруктураКонтрагентаJSON(Стр, ТипФильтра, ГруппыПоставщиков, ГруппыПокупателей));
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	Если ТипФильтра <> "" Тогда
		ТелоОтвета.Вставить("type", ТипФильтра);
	КонецЕсли;
	ТелоОтвета.Вставить("page", Пагинация.page);
	ТелоОтвета.Вставить("pageSize", Пагинация.pageSize);
	ТелоОтвета.Вставить("totalItems", ВсегоКонтрагентов);
	ТелоОтвета.Вставить("totalPages", ВсегоСтраниц);
	ТелоОтвета.Вставить("items", Массив);
	Результат.Тело = ТелоОтвета;
	Возврат Результат;
	
КонецФункции

// POST /counterparties — создание контрагента в справочнике.
Функция СоздатьКонтрагента(ДанныеЗапроса) Экспорт
	
	Результат = Новый Структура("success, error, type, counterparty, counterpartyCode, group, groupCode",
		Ложь, "", "", "", "", "", "");
	
	Наименование = НаименованиеКонтрагентаИзЗапроса(ДанныеЗапроса);
	Если Наименование = "" Тогда
		Результат.error = "Укажите counterparty, name или customer (наименование контрагента).";
		Возврат Результат;
	КонецЕсли;
	
	Существующий = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина);
	Если ЗначениеЗаполнено(Существующий) Тогда
		Результат.error = СтрШаблон("Контрагент ""%1"" уже существует (код %2).",
			Наименование,
			StockAPI_Справочники.КодКонтрагентаВСтроку(Существующий.Код));
		Возврат Результат;
	КонецЕсли;
	
	ТипЗапроса = ТипКонтрагентаИзЗапроса(ДанныеЗапроса);
	
	РазрешениеГруппы = ГруппаКонтрагентовИзЗапросаСоздания(ДанныеЗапроса);
	Если РазрешениеГруппы.Ошибка <> "" Тогда
		Результат.error = РазрешениеГруппы.Ошибка;
		Возврат Результат;
	КонецЕсли;
	Группа = РазрешениеГруппы.Группа;
	
	ТипГруппы = ТипГруппыКонтрагентов(Группа);
	Если ТипГруппы <> "" И ТипГруппы <> ТипЗапроса Тогда
		Результат.error = СтрШаблон(
			"Группа ""%1"" относится к типу %2, а в запросе указан type=%3.",
			Группа,
			ТипГруппы,
			ТипЗапроса);
		Возврат Результат;
	КонецЕсли;
	
	Объект = Справочники.Контрагенты.СоздатьЭлемент();
	Объект.Наименование = Наименование;
	Объект.Родитель = Группа;
	
	Если ДанныеЗапроса.Свойство("alias") Тогда
		Объект.Псевдоним = СокрЛП(ДанныеЗапроса.alias);
	ИначеЕсли ДанныеЗапроса.Свойство("pseudonym") Тогда
		Объект.Псевдоним = СокрЛП(ДанныеЗапроса.pseudonym);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("email") Тогда
		Объект.Email = СокрЛП(ДанныеЗапроса.email);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("phone") Тогда
		Объект.Телефоны = СокрЛП(ДанныеЗапроса.phone);
	ИначеЕсли ДанныеЗапроса.Свойство("phones") Тогда
		Объект.Телефоны = СокрЛП(ДанныеЗапроса.phones);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("city") Тогда
		Объект.Город = СокрЛП(ДанныеЗапроса.city);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("address") Тогда
		Объект.Адрес = СокрЛП(ДанныеЗапроса.address);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("note") Тогда
		Объект.Примечание = СокрЛП(ДанныеЗапроса.note);
	ИначеЕсли ДанныеЗапроса.Свойство("comment") Тогда
		Объект.Примечание = СокрЛП(ДанныеЗапроса.comment);
	КонецЕсли;
	
	Попытка
		Объект.Записать();
	Исключение
		Результат.error = "Не удалось создать контрагента: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	КодСтрокой = StockAPI_Справочники.КодКонтрагентаВСтроку(Объект.Код);
	
	Результат.success = Истина;
	Результат.type = ТипЗапроса;
	Результат.counterparty = Объект.Наименование;
	Результат.counterpartyCode = КодСтрокой;
	Результат.group = Строка(Группа);
	Результат.groupCode = StockAPI_Справочники.КодКонтрагентаВСтроку(Группа.Код);
	Возврат Результат;
	
КонецФункции
