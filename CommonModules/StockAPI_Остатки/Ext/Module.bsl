Функция ТаблицаОстатков(Склады, ВидЦены)

	запр = Новый Запрос;
	запр.УстановитьПараметр("Склады",	Склады);
	запр.УстановитьПараметр("ВидЦены",	ВидЦены);
    запр.Текст = "ВЫБРАТЬ
                 |	ОстаткиТовара.Номенклатура КАК Номенклатура,
                 |	ОстаткиТовара.Склад КАК Склад,
                 |	ОстаткиТовара.ОстатокОстаток КАК Остаток,
                 |	ОстаткиТовара.РезервОстаток КАК Резерв,
                 |	ЦеныПродажи.Цена0 КАК Цена0,
                 |	ЦеныПродажи.Цена1 КАК Цена1,
                 |	ЦеныПродажи.Цена2 КАК Цена2,
                 |	ЦеныПродажи.Цена3 КАК Цена3,
                 |	ЦеныПродажи.Порог1 КАК Порог1,
                 |	ЦеныПродажи.Порог2 КАК Порог2,
                 |	ЦеныПродажи.Порог3 КАК Порог3,
                 |	ЦеныПродажи.РазрешитьПродажу КАК РазрешитьПродажу
                 |ИЗ
                 |	РегистрНакопления.ОстаткиТовара.Остатки(, Склад В (&Склады)) КАК ОстаткиТовара
                 |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныПродажи.СрезПоследних(, ВидЦены = &ВидЦены) КАК ЦеныПродажи
                 |		ПО ОстаткиТовара.Склад = ЦеныПродажи.Склад
                 |			И ОстаткиТовара.Номенклатура = ЦеныПродажи.Номенклатура
                 |ГДЕ
                 |	ОстаткиТовара.ОстатокОстаток > 0
                 |	И НЕ ОстаткиТовара.Номенклатура.ЗапретОтгрузки
                 |	И ОстаткиТовара.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
                 |
                 |УПОРЯДОЧИТЬ ПО
                 |	Склад,
                 |	Номенклатура";
	Выгрузка = Запр.Выполнить().Выгрузить();
	Возврат Выгрузка;
	
КонецФункции // ТаблицаОстатков()


// ─── Фильтр и пагинация ───────────────────────────────────────────────────────

Функция ВидЦеныИзЗапроса(Запрос)

	Результат = Новый Структура("ВидЦены, Ошибка", Неопределено, "");

	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("priceType");
	Если ПараметрКода = Неопределено Тогда
		Результат.Ошибка = "Параметр priceType не найден.";
		Возврат Результат;
	КонецЕсли;
	
	ВидЦены = Справочники.ВидыЦен.НайтиПоНаименованию(ПараметрКода, Истина);
	Если ВидЦены = Справочники.ВидыЦен.ПустаяСсылка() Тогда
		Результат.Ошибка = СтрШаблон("Не найден вид цены %1.", ПараметрКода);
	Иначе
	    Результат.ВидЦены = ВидЦены;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ВидЦеныизЗапроса()


// Фильтр по складу: warehouseId, warehouseCode или code (числовой код из /warehouses). 
// Если код задан, возвращает склад по коду из перечня разрешенных
// Если код не задан, возвращает массив разрешенных складов
//
Функция РазрешенныйСкладИзЗапроса(Запрос, УчетаяЗапись)
	
	Результат = Новый Структура("Склады, Ошибка", Неопределено, "");
	
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseId");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseCode");
	КонецЕсли;
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода = Неопределено Тогда  
		КодЧисло = Неопределено;
	Иначе	
		Попытка
			КодЧисло = Число(СокрЛП(Строка(ПараметрКода)));
			//Результат.warehouseId = Строка(ПараметрКода);
		Исключение
			Результат.Ошибка = "Параметр warehouseId (или warehouseCode) должен быть числовым кодом склада.";
			Возврат Результат;
		КонецПопытки;
	КонецЕсли;
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("УчетаяЗапись",	УчетаяЗапись);
	Запр.УстановитьПараметр("Код",			КодЧисло);
	Запр.Текст = "ВЫБРАТЬ
	             |	Склады.Склад КАК Склад
	             |ИЗ
	             |	Справочник.УчетныеЗаписиИнтеграции.Склады КАК Склады
	             |ГДЕ
	             |	Склады.Ссылка = &УчетаяЗапись
	             |	И НЕ Склады.Склад.ПометкаУдаления
	             |	И ВЫБОР
	             |			КОГДА &Код = НЕОПРЕДЕЛЕНО
	             |				ТОГДА ИСТИНА
	             |			ИНАЧЕ Склады.Склад.Код = &Код
	             |		КОНЕЦ"; 
	РезультатЗапроса = Запр.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Результат.Ошибка = "Нет доступа к указанному складу.";
	Иначе	
		Результат.Склады = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Склад");
	КонецЕсли;  
	
 	Возврат Результат;
	
	//Склад = Справочники.Склады.НайтиПоКоду(КодЧисло);
	//Если НЕ ЗначениеЗаполнено(Склад) Или Склад.ПометкаУдаления Тогда
