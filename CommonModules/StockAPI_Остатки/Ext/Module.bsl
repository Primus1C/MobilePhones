// Остатки StockAPI: обработчик GET /balances, запросы к ОстаткиТовара, серии из приходных.
// Зависимости: StockAPI_Утилиты, StockAPI_Цены, StockAPI_Справочники

// ─── Точка входа ─────────────────────────────────────────────────────────────

// Главная логика GET /balances.
// Возвращает Структура("КодОтвета, Тело") — Module.bsl преобразует в HTTP-ответ.
Функция ПолучитьОстатки(Запрос, КонтекстАвторизации) Экспорт
	
	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Возврат Новый Структура("КодОтвета, Тело", 400, Новый Структура("error", Пагинация.Ошибка));
	КонецЕсли;
	
	ФильтрСклад = РазрешенныйСкладИзЗапроса(Запрос, КонтекстАвторизации.УчетнаяЗапись);
	Если ФильтрСклад.Ошибка <> "" Тогда
		Возврат Новый Структура("КодОтвета, Тело", 400, Новый Структура("error", ФильтрСклад.Ошибка));
	КонецЕсли;
	
	ФильтрВидЦены = ВидЦеныИзЗапроса(Запрос); 
	Если ФильтрВидЦены.Ошибка <> "" Тогда
		Возврат Новый Структура("КодОтвета, Тело", 400, Новый Структура("error", ФильтрВидЦены.Ошибка));
	КонецЕсли;
	
	ТаблицаОстатков = ТаблицаОстатков(ФильтрСклад.Склады, ФильтрВидЦены.ВидЦены);
	ВсегоНоменклатуры = ТаблицаОстатков.Количество();   
	РазмерСтраницы = Пагинация.pageSize;
	ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоНоменклатуры, РазмерСтраницы);
	Пропустить = (Пагинация.page - 1) * РазмерСтраницы;
	
	РезультатВидЦены = ФильтрВидЦены.ВидЦены.Наименование;
	РезультатВалюта = ФильтрВидЦены.ВидЦены.Валюта.Наименование;
	
	МассивСтрок = Новый Массив;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("ТЗ", ТаблицаОстатков);
	Запр.Текст = "ВЫБРАТЬ
	             |	ТЗ.Номенклатура КАК Номенклатура,
	             |	ТЗ.Склад КАК Склад,
	             |	ТЗ.Остаток КАК Остаток,
	             |	ТЗ.Резерв КАК Резерв,
	             |	ТЗ.Цена0 КАК Цена0,
	             |	ТЗ.Цена1 КАК Цена1,
	             |	ТЗ.Цена2 КАК Цена2,
	             |	ТЗ.Цена3 КАК Цена3,
	             |	ТЗ.Порог1 КАК Порог1,
	             |	ТЗ.Порог2 КАК Порог2,
	             |	ТЗ.Порог3 КАК Порог3,
	             |	ТЗ.РазрешитьПродажу КАК РазрешитьПродажу
	             |ПОМЕСТИТЬ ВТ
	             |ИЗ
	             |	&ТЗ КАК ТЗ
	             |;
	             |
				|ВЫБРАТЬ ПЕРВЫЕ " + РазмерСтраницы + ?(Пропустить > 0, " ПРОПУСТИТЬ " + Пропустить, "") + "
	            //|ВЫБРАТЬ
	             |	ВТ.Номенклатура.Код КАК КодНоменклатуры,
	             |	ВТ.Номенклатура.Наименование КАК Номенклатура,
	             |	ВТ.Номенклатура.SKU КАК SKU,
	             |	ВТ.Номенклатура.Производитель.Наименование КАК Производитель,
	             |	ВТ.Склад.Код КАК Склад,
	             |	ВТ.Остаток КАК Остаток,
	             |	ВТ.Резерв КАК Резерв,
	             |	isnull(ВТ.Цена0,0) КАК Цена0,
	             |	isnull(ВТ.Цена1,0) КАК Цена1,
	             |	isnull(ВТ.Цена2,0) КАК Цена2,
	             |	isnull(ВТ.Цена3,0) КАК Цена3,
	             |	isnull(ВТ.Порог1,0) КАК Порог1,
	             |	isnull(ВТ.Порог2,0) КАК Порог2,
	             |	isnull(ВТ.Порог3,0) КАК Порог3,
	             |	isnull(ВТ.РазрешитьПродажу,0) КАК РазрешитьПродажу
	             |ИЗ
	             |	ВТ КАК ВТ
				 |УПОРЯДОЧИТЬ ПО 
				 |	ВТ.Склад,
				 |	ВТ.Номенклатура";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("priceType", 	РезультатВидЦены);
		Элемент.Вставить("currency",	РезультатВалюта);
		Элемент.Вставить("warehouse", 	Выборка.Склад);
		Элемент.Вставить("item", 		Выборка.Номенклатура);
		Элемент.Вставить("itemCode", 	StockAPI_Утилиты.КодВСтроку(Выборка.КодНоменклатуры));
		Элемент.Вставить("itemSku", 	Выборка.SKU);
		Элемент.Вставить("manufacturer",Строка(Выборка.Производитель));
		Элемент.Вставить("balance",		Выборка.Остаток);
		Элемент.Вставить("reserve", 	Выборка.Резерв); 
		мас = Новый Массив; 
		мас.Добавить(Новый Структура("priceQty,qty", Выборка.Цена0, 0));
		Для Порог = 1 По 3 Цикл
			Если Выборка["Цена" + Порог] > 0 Тогда
				мас.Добавить(Новый Структура("priceQty,qty", Выборка["Цена"+Порог], Выборка["Порог"+Порог]));
			КонецЕсли;
		КонецЦикла; 
		Элемент.Вставить("price",		мас);
		//Элемент.Вставить("allow",		Выборка.РазрешитьПродажу);
		МассивСтрок.Добавить(Элемент);
