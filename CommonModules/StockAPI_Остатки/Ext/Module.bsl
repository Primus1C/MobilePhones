// Остатки StockAPI: обработчик GET /balances, запросы к ОстаткиТовара, серии из приходных.
// Зависимости: StockAPI_Утилиты, StockAPI_Цены, StockAPI_Справочники

// ─── Точка входа ─────────────────────────────────────────────────────────────

// Главная логика GET /balances.
// serials=with|without (по умолчанию without). prices — МелкийОпт и КрупныйОпт.
// Возвращает Структура("КодОтвета, Тело") — Module.bsl преобразует в HTTP-ответ.
Функция ПолучитьОстатки(Запрос) Экспорт
	
	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Возврат Новый Структура("КодОтвета, Тело", 400, Новый Структура("error", Пагинация.Ошибка));
	КонецЕсли;
	
	ФильтрСклада = СкладОстатковИзЗапроса(Запрос);
	Если ФильтрСклада.Ошибка <> "" Тогда
		Возврат Новый Структура("КодОтвета, Тело", 400, Новый Структура("error", ФильтрСклада.Ошибка));
	КонецЕсли;
	
	ПараметрСерий = StockAPI_Утилиты.ПараметрSerialsЗапроса(Запрос, Ложь);
	Если ПараметрСерий.Ошибка <> "" Тогда
		Возврат Новый Структура("КодОтвета, Тело", 400, Новый Структура("error", ПараметрСерий.Ошибка));
	КонецЕсли;
	ССериями = ПараметрСерий.ССериями;
	
	ДатаОстатков = КонецДня(ТекущаяДатаСеанса());
	
	СтрокаДаты = Запрос.ПараметрыЗапроса.Получить("date");
	Если СтрокаДаты <> Неопределено И СтрокаДаты <> "" Тогда
		ДатаОстатков = КонецДня(Дата(СтрокаДаты));
	КонецЕсли;
	
	ВидЦены = StockAPI_Цены.ВидЦеныИзПараметра(Запрос.ПараметрыЗапроса.Получить("priceType"));
	
	ВсегоНоменклатуры = КоличествоНоменклатурыНаОстатках(ДатаОстатков, ФильтрСклада.Склад);
	ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоНоменклатуры, Пагинация.pageSize);
	Пропустить = (Пагинация.page - 1) * Пагинация.pageSize;
	НоменклатураСтраницы = НоменклатураНаОстаткахСтраница(ДатаОстатков, Пагинация.pageSize, Пропустить, ФильтрСклада.Склад);
	
	Таблица = ТаблицаОстатковПоНоменклатуре(ДатаОстатков, НоменклатураСтраницы, ФильтрСклада.Склад);
	
	МассивНоменклатуры = StockAPI_Цены.УникальнаяНоменклатураИзТаблицы(Таблица);
	ЦеныПоНоменклатуре = StockAPI_Цены.ЗагрузитьЦеныПродажиВсехВидов(ДатаОстатков, МассивНоменклатуры);
	
	Если ССериями Тогда
		СерииПоПартиям = СерииИзСтрокПриходных(Таблица);
		СерииПоГруппе = СерииИзСтрокПриходныхПоГруппе(ДатаОстатков, НоменклатураСтраницы, ФильтрСклада.Склад);
	Иначе
		СерииПоПартиям = Новый Соответствие;
		СерииПоГруппе = Новый Соответствие;
	КонецЕсли;
	
	Группы = Новый Соответствие;
	
	Для Каждого Стр Из Таблица Цикл
		
		Если ССериями Тогда
			Ключ = КлючГруппыОстатков(Стр.warehouse, Стр.itemCode, Стр.batch);
		Иначе
			Ключ = КлючГруппыОстатковСводно(Стр.warehouse, Стр.itemCode);
		КонецЕсли;
		Элемент = Группы.Получить(Ключ);
		
		Если Элемент = Неопределено Тогда
			Элемент = Новый Структура;
			Элемент.Вставить("warehouse", Строка(Стр.warehouse));
			Элемент.Вставить("item", Строка(Стр.item));
			Элемент.Вставить("itemCode", Строка(Стр.itemCode));
			Элемент.Вставить("sku", Строка(Стр.sku));
			Элемент.Вставить("itemType", Строка(Стр.itemType));
			Элемент.Вставить("manufacturer", Строка(Стр.manufacturer));
			Если ССериями Тогда
				Элемент.Вставить("batch", Строка(Стр.batch));
				Элемент.Вставить("serials", Новый Массив);
				Элемент.Вставить("units", Новый Массив);
			КонецЕсли;
			Элемент.Вставить("qty", 0);
			Элемент.Вставить("reserve", 0);
			Элемент.Вставить("Номенклатура", Стр.Номенклатура);
			Группы.Вставить(Ключ, Элемент);
		КонецЕсли;
		
		Элемент.qty = Элемент.qty + Стр.qty;
		Элемент.reserve = Элемент.reserve + Стр.reserve;
		
		Если ССериями Тогда
			
			Серия = СокрЛП(Стр.serialParty);
			Если Серия = "" Тогда
				МассивСерийПартии = СерииПоПартиям.Получить(Стр.Партия);
				Если МассивСерийПартии <> Неопределено И МассивСерийПартии.Количество() > 0 Тогда
					Серия = МассивСерийПартии[0];
				КонецЕсли;
			КонецЕсли;
			
			Единица = Новый Структура;
			Единица.Вставить("batchCode", Строка(Стр.batchCode));
			Единица.Вставить("sku", Строка(Стр.sku));
			Единица.Вставить("itemType", Строка(Стр.itemType));
			Единица.Вставить("manufacturer", Строка(Стр.manufacturer));
			Единица.Вставить("serial", Серия);
			Единица.Вставить("qty", Стр.qty);
			Элемент.units.Добавить(Единица);
			
			ДобавитьСерийникВМассив(Элемент.serials, Серия);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ССериями Тогда
		Для Каждого КлючИЗначение Из Группы Цикл
			Элемент = КлючИЗначение.Значение;
			МассивДоп = СерииПоГруппе.Получить(КлючИЗначение.Ключ);
			Если МассивДоп <> Неопределено Тогда
				Для Каждого Серия Из МассивДоп Цикл
					ДобавитьСерийникВМассив(Элемент.serials, Серия);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из Группы Цикл
		Элемент = КлючИЗначение.Значение;
		ЦеныНоменклатуры = ЦеныПоНоменклатуре.Получить(Элемент.Номенклатура);
		StockAPI_Цены.ДобавитьЦеныВСтруктуру(Элемент, ЦеныНоменклатуры, Элемент.qty, ВидЦены);
		Если ССериями Тогда
			Для Каждого Единица Из Элемент.units Цикл
				StockAPI_Цены.ДобавитьЦеныВСтруктуру(Единица, ЦеныНоменклатуры, Единица.qty, ВидЦены);
			КонецЦикла;
		КонецЕсли;
		Элемент.Удалить("Номенклатура");
	КонецЦикла;
	
	МассивСтрок = Новый Массив;
	Для Каждого КлючИЗначение Из Группы Цикл
		МассивСтрок.Добавить(КлючИЗначение.Значение);
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("page", Пагинация.page);
	ТелоОтвета.Вставить("pageSize", Пагинация.pageSize);
	ТелоОтвета.Вставить("totalItems", ВсегоНоменклатуры);
	ТелоОтвета.Вставить("totalPages", ВсегоСтраниц);
	ТелоОтвета.Вставить("items", МассивСтрок);
	Если ЗначениеЗаполнено(ФильтрСклада.Склад) Тогда
		ТелоОтвета.Вставить("warehouse", Строка(ФильтрСклада.Склад));
		ТелоОтвета.Вставить("warehouseCode", ФильтрСклада.warehouseCode);
	КонецЕсли;
	
	Возврат Новый Структура("КодОтвета, Тело", 200, ТелоОтвета);
	
КонецФункции

// ─── Фильтр и пагинация ───────────────────────────────────────────────────────

// Фильтр по складу: warehouseId, warehouseCode или code (числовой код из /warehouses).
Функция СкладОстатковИзЗапроса(Запрос)
	
	Результат = Новый Структура("Склад, warehouseCode, Ошибка", Справочники.Склады.ПустаяСсылка(), "", "");
	
	СтрокаКода = "";
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseId");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseCode");
	КонецЕсли;
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода <> Неопределено Тогда
		СтрокаКода = СокрЛП(Строка(ПараметрКода));
	КонецЕсли;
	
	Если СтрокаКода = "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		КодЧисло = Число(СтрокаКода);
	Исключение
		Результат.Ошибка = "Параметр warehouseId (или warehouseCode) должен быть числовым кодом склада.";
		Возврат Результат;
	КонецПопытки;
	
	Склад = Справочники.Склады.НайтиПоКоду(КодЧисло);
	Если НЕ ЗначениеЗаполнено(Склад) Или Склад.ПометкаУдаления Тогда
		Результат.Ошибка = СтрШаблон("Склад с кодом %1 не найден.", СтрокаКода);
		Возврат Результат;
	КонецЕсли;
	
	МассивДоступных = омСервер.МассивСкладов();
	Если МассивДоступных.Количество() > 0 Тогда
		Доступен = Ложь;
		Для Каждого ДоступныйСклад Из МассивДоступных Цикл
			Если ДоступныйСклад = Склад Тогда
				Доступен = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если НЕ Доступен Тогда
			Результат.Ошибка = "Нет доступа к указанному складу.";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Результат.Склад = Склад;
	Результат.warehouseCode = StockAPI_Справочники.КодСкладаВСтроку(КодЧисло);
	Возврат Результат;
	
КонецФункции

// ─── Запросы к РН ОстаткиТовара ──────────────────────────────────────────────

Функция КоличествоНоменклатурыНаОстатках(ДатаОстатков, Склад = Неопределено)
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ост.Номенклатура) КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И Ост.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И (&БезСклада
	|		ИЛИ Ост.Склад = &Склад)";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Количество;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция НоменклатураНаОстаткахСтраница(ДатаОстатков, РазмерСтраницы, Пропустить, Склад = Неопределено)
	
	МассивНоменклатуры = Новый Массив;
	
	Если РазмерСтраницы <= 0 Тогда
		Возврат МассивНоменклатуры;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ " + РазмерСтраницы + ?(Пропустить > 0, " ПРОПУСТИТЬ " + Пропустить, "") + "
	|	Вложенный.Номенклатура КАК Номенклатура
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		Ост.Номенклатура КАК Номенклатура,
	|		Ост.Номенклатура.Код КАК КодСортировки,
	|		Ост.Номенклатура.Наименование КАК НаименованиеСортировки
	|	ИЗ
	|		РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|	ГДЕ
	|		Ост.ОстатокОстаток > 0
	|		И Ост.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|		И (&БезСклада
	|			ИЛИ Ост.Склад = &Склад)) КАК Вложенный
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вложенный.КодСортировки,
	|	Вложенный.НаименованиеСортировки";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивНоменклатуры.Добавить(Выборка.Номенклатура);
	КонецЦикла;
	
	Возврат МассивНоменклатуры;
	
КонецФункции

Функция ТаблицаОстатковПоНоменклатуре(ДатаОстатков, НоменклатураСтраницы, Склад = Неопределено)
	
	ПустаяТаблица = Новый ТаблицаЗначений;
	ПустаяТаблица.Колонки.Добавить("warehouse");
	ПустаяТаблица.Колонки.Добавить("Склад");
	ПустаяТаблица.Колонки.Добавить("item");
	ПустаяТаблица.Колонки.Добавить("itemCode");
	ПустаяТаблица.Колонки.Добавить("sku");
	ПустаяТаблица.Колонки.Добавить("itemType");
	ПустаяТаблица.Колонки.Добавить("manufacturer");
	ПустаяТаблица.Колонки.Добавить("Номенклатура");
	ПустаяТаблица.Колонки.Добавить("batch");
	ПустаяТаблица.Колонки.Добавить("batchCode");
	ПустаяТаблица.Колонки.Добавить("serialParty");
	ПустаяТаблица.Колонки.Добавить("Партия");
	ПустаяТаблица.Колонки.Добавить("qty", Новый ОписаниеТипов("Число"));
	ПустаяТаблица.Колонки.Добавить("reserve", Новый ОписаниеТипов("Число"));
	
	Если НоменклатураСтраницы.Количество() = 0 Тогда
		Возврат ПустаяТаблица;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Ост.Склад.Наименование КАК warehouse,
	|	Ост.Склад КАК Склад,
	|	Ост.Номенклатура.Наименование КАК item,
	|	Ост.Номенклатура.Код КАК itemCode,
	|	Ост.Номенклатура.КодВендора.Наименование КАК sku,
	|	Ост.Номенклатура.ВидНоменклатуры.Наименование КАК itemType,
	|	Ост.Номенклатура.Производитель.Наименование КАК manufacturer,
	|	Ост.Номенклатура КАК Номенклатура,
	|	Ост.Партия.Наименование КАК batch,
	|	Ост.Партия.Код КАК batchCode,
	|	Ост.Партия.Серия КАК serialParty,
	|	Ост.Партия КАК Партия,
	|	Ост.ОстатокОстаток КАК qty,
	|	Ост.РезервОстаток КАК reserve
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И Ост.Номенклатура В (&Номенклатура)
	|	И (&БезСклада
	|		ИЛИ Ост.Склад = &Склад)";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("Номенклатура", НоменклатураСтраницы);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Возврат Зап.Выполнить().Выгрузить();
	
КонецФункции

Функция КлючГруппыОстатков(Склад, КодТовара, Партия)
	Возврат Строка(Склад) + "|" + Строка(КодТовара) + "|" + Строка(Партия);
КонецФункции

Функция КлючГруппыОстатковСводно(Склад, КодТовара)
	Возврат Строка(Склад) + "|" + Строка(КодТовара);
КонецФункции

// ─── Серийные номера из приходных накладных ───────────────────────────────────

Процедура ДобавитьСерийникВМассив(МассивСерий, ЗначениеСерии)
	
	Серия = СокрЛП(ЗначениеСерии);
	Если Серия = "" Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Существующая Из МассивСерий Цикл
		Если Существующая = Серия Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	МассивСерий.Добавить(Серия);
	
КонецПроцедуры

// Серии по партиям из строк приходных накладных.
// Возвращает Соответствие: Партия → [Серия, ...].
Функция СерииИзСтрокПриходных(ТаблицаОстатков)
	
	Результат = Новый Соответствие;
	МассивПартий = Новый Массив;
	
	Для Каждого Стр Из ТаблицаОстатков Цикл
		Если ЗначениеЗаполнено(Стр.Партия) Тогда
			МассивПартий.Добавить(Стр.Партия);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивПартий.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Товары.Партия КАК Партия,
	|	Товары.Серия КАК Серия
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК Товары
	|ГДЕ
	|	Товары.Партия В (&Партии)
	|	И Товары.Серия <> """"
	|	И Товары.Ссылка.Проведен";
	Зап.УстановитьПараметр("Партии", МассивПартий);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивСерий = Результат.Получить(Выборка.Партия);
		Если МассивСерий = Неопределено Тогда
			МассивСерий = Новый Массив;
			Результат.Вставить(Выборка.Партия, МассивСерий);
		КонецЕсли;
		ДобавитьСерийникВМассив(МассивСерий, Выборка.Серия);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Серии сгруппированные по ключу (склад|код_товара|партия) из приходных накладных.
// Возвращает Соответствие: КлючГруппы → [Серия, ...].
Функция СерииИзСтрокПриходныхПоГруппе(ДатаОстатков, НоменклатураСтраницы = Неопределено, Склад = Неопределено)
	
	Результат = Новый Соответствие;
	
	Если НоменклатураСтраницы <> Неопределено И НоменклатураСтраницы.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Ост.Склад.Наименование КАК warehouse,
	|	Ост.Номенклатура.Код КАК itemCode,
	|	Ост.Партия.Наименование КАК batch,
	|	Товары.Серия КАК Серия
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная.Товары КАК Товары
	|		ПО Ост.Партия = Товары.Партия
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И Товары.Серия <> """"
	|	И Товары.Ссылка.Проведен
	|	И (&БезСклада
	|		ИЛИ Ост.Склад = &Склад)";
	
	Если НоменклатураСтраницы <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	И Ост.Номенклатура В (&Номенклатура)";
		Зап.УстановитьПараметр("Номенклатура", НоменклатураСтраницы);
	КонецЕсли;
	
	Зап.Текст = ТекстЗапроса;
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Ключ = КлючГруппыОстатков(Выборка.warehouse, Выборка.itemCode, Выборка.batch);
		МассивСерий = Результат.Получить(Ключ);
		Если МассивСерий = Неопределено Тогда
			МассивСерий = Новый Массив;
			Результат.Вставить(Ключ, МассивСерий);
		КонецЕсли;
		ДобавитьСерийникВМассив(МассивСерий, Выборка.Серия);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции
