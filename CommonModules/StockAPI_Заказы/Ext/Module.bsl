Функция НайтиИнвойсДляРедактирования(ДанныеЗапроса, Результат)
	
	НомерЗаказа = НомерЗаказаИзДанных(ДанныеЗапроса);
	Если НомерЗаказа = "" Тогда
		Результат.error = "Укажите orderNumber (номер заказа).";
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	КонецЕсли;
	
	ДатаЗаказа = ДатаЗаказаИзДанных(ДанныеЗапроса);
	СсылкаЗаказ = НайтиИнвойсПродажи(НомерЗаказа, ДатаЗаказа, Результат.error);
	//Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
	//	Результат.error = СтрШаблон("Заказ %1 не найден.", НомерЗаказа);
	//	Результат.НеНайден = Истина;
	//	Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	//КонецЕсли;
	
	
	
	Если ЕстьРасходнаяНакладнаяПоИнвойсу(СсылкаЗаказ) Тогда
		Результат.error = "Невозможно изменить отгруженный заказ: к инвойсу уже создана расходная накладная.";
		Результат.Отгружен = Истина;
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	КонецЕсли;
	
	Возврат СсылкаЗаказ;
	
КонецФункции

Функция РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса)
	
	Если НЕ ЗначениеЗаполнено(СсылкаИнвойса) Тогда
		Возврат Документы.РасходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РН.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РН
	|ГДЕ
	|	РН.ДокументОснование = &Инвойс
	|	И НЕ РН.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	РН.Дата УБЫВ";
	Зап.УстановитьПараметр("Инвойс", СсылкаИнвойса);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Документы.РасходнаяНакладная.ПустаяСсылка();
	
КонецФункции

Функция ЕстьРасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса)
	
	Возврат ЗначениеЗаполнено(РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса));
	
КонецФункции

Функция ПрименитьЗаголовокИнвойсаИзЗапроса(Док, ДанныеЗапроса, Результат)
	
	Если ДанныеЗапроса.Свойство("customer")
		Или ДанныеЗапроса.Свойство("customerCode")
		Или ДанныеЗапроса.Свойство("counterparty")
		Или ДанныеЗапроса.Свойство("counterpartyCode") Тогда
		
		Контрагент = StockAPI_Контрагенты.НайтиКонтрагента(ДанныеЗапроса);
		Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
			Результат.error = "Не найден покупатель. Укажите customer (наименование) или customerCode (код).";
			Возврат Ложь;
		КонецЕсли;
		Док.Контрагент = Контрагент;
		Док.Получатель = Контрагент;
	КонецЕсли;
	
	Фирма = Док.Фирма;
	Если ДанныеЗапроса.Свойство("firm") И СокрЛП(ДанныеЗапроса.firm) <> "" Тогда
		//Фирма = StockAPI_Справочники.НайтиФирму(ДанныеЗапроса);  
		Фирма = ПараметрыСеанса.Фирма;
		Если НЕ ЗначениеЗаполнено(Фирма) Тогда
			Результат.error = "Не найдена фирма. Укажите firm (наименование).";
			Возврат Ложь;
		КонецЕсли;
		Док.Фирма = Фирма;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("warehouse") И СокрЛП(ДанныеЗапроса.warehouse) <> "" Тогда
		Склад = StockAPI_Справочники.НайтиСклад(ДанныеЗапроса, Фирма);
		Если НЕ ЗначениеЗаполнено(Склад) Тогда
			Результат.error = "Не найден склад. Укажите warehouse (наименование склада).";
			Возврат Ложь;
		КонецЕсли;
		Док.Склад = Склад;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("currency") И СокрЛП(Строка(ДанныеЗапроса.currency)) <> "" Тогда
		Валюта = Справочники.Валюты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.currency), Истина);
		Если ЗначениеЗаполнено(Валюта) Тогда
			Док.Валюта = Валюта;
		КонецЕсли;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("reserve") Или ДанныеЗапроса.Свойство("reserved") Тогда
		Док.РезервироватьТовар = РезервированиеИзЗапроса(ДанныеЗапроса);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция СнятьПроведениеИнвойса(Док, БылПроведен, Результат)
	
	Если НЕ БылПроведен Тогда
		Возврат Истина;
	КонецЕсли;
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	Исключение
		Результат.error = "Не удалось снять проведение инвойса: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

Функция ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен)
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ВосстановитьИнвойсПослеОшибки(Док, СтарыеТовары, БылПроведен);
		Результат.error = "Не удалось провести инвойс: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success = Истина;
	Результат.orderNumber = Док.Номер;
	Результат.orderDate = StockAPI_Утилиты.ДатаВСтроку(Док.Дата);
	Результат.reserved = Док.РезервироватьТовар И Док.Проведен;
	Возврат Результат;
	
КонецФункции

Функция ПометитьИнвойсНаУдаление(СсылкаЗаказа, НомерЗаказа, Результат)
	
	// Только пометка на удаление (как вручную). Резерв снимается платформой автоматически.
	Попытка
		Док = СсылкаЗаказа.ПолучитьОбъект();
		Если НЕ Док.ПометкаУдаления Тогда
			Док.УстановитьПометкуУдаления(Истина);
		КонецЕсли;
	Исключение
		Результат.error = "Не удалось пометить инвойс на удаление: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success = Истина;
	Результат.deleted = Истина;
	Результат.orderNumber = НомерЗаказа;
	Результат.orderDate = "";
	Результат.reserved = Ложь;
	Возврат Результат;
	
КонецФункции

Функция ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиЗаказа, ДанныеЗапроса, Склад = Неопределено)
	
	ВидЦены = StockAPI_Цены.ВидЦеныИзПараметра(?(ДанныеЗапроса.Свойство("priceType"), ДанныеЗапроса.priceType, ""));
	ИмяВидаЦены = Строка(ВидЦены);
	ЦеныПродажи = StockAPI_Цены.ЗагрузитьЦеныПродажи(КонецДня(ТекущаяДатаСеанса()), НоменклатураИзСтрокЗаказа(СтрокиЗаказа), ВидЦены);
	Возврат StockAPI_Цены.ПроверитьЦеныСтрокЗаказа(СтрокиЗаказа, ЦеныПродажи, ИмяВидаЦены);
	
КонецФункции

Функция ТребуемыеКоличестваИзТабличнойЧасти(ТабличнаяЧасть)
	
	ТребуемыеКоличества = Новый Соответствие;
	
	Для Каждого СтрокаТЧ Из ТабличнаяЧасть Цикл
		
		Если СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = ТребуемыеКоличества.Получить(СтрокаТЧ.Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		ТребуемыеКоличества.Вставить(СтрокаТЧ.Номенклатура, ТекущееКоличество + СтрокаТЧ.Количество);
		
	КонецЦикла;
	
	Возврат ТребуемыеКоличества;
	
КонецФункции

Процедура ДобавитьТребуемыеКоличества(ТребуемыеКоличества, СтрокиЗаказа)
	
	Для Каждого Стр Из СтрокиЗаказа Цикл
		
		Если Стр.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = ТребуемыеКоличества.Получить(Стр.Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		ТребуемыеКоличества.Вставить(Стр.Номенклатура, ТекущееКоличество + Стр.Количество);
		
	КонецЦикла;
	
КонецПроцедуры

// Истина, если в запросе перечислены все номенклатуры инвойса — документ помечается на удаление.
Функция ВсеПозицииИнвойсаВЗапросе(СсылкаЗаказа, НоменклатурыУдаления)
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.ИнвойсПродажи.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &Ссылка";
	Зап.УстановитьПараметр("Ссылка", СсылкаЗаказа);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если НЕ Выборка.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	НоменклатурыИнвойса = Новый Соответствие;
	НоменклатурыИнвойса.Вставить(Выборка.Номенклатура, Истина);
	Пока Выборка.Следующий() Цикл
		НоменклатурыИнвойса.Вставить(Выборка.Номенклатура, Истина);
	КонецЦикла;
	
	НоменклатурыЗапроса = Новый Соответствие;
	Для Каждого Номенклатура Из НоменклатурыУдаления Цикл
		НоменклатурыЗапроса.Вставить(Номенклатура, Истина);
	КонецЦикла;
	
	Для Каждого КлючЗначение Из НоменклатурыИнвойса Цикл
		Если НоменклатурыЗапроса.Получить(КлючЗначение.Ключ) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КлючЗначение Из НоменклатурыЗапроса Цикл
		Если НоменклатурыИнвойса.Получить(КлючЗначение.Ключ) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция НоменклатурыДляУдаленияИзЗапроса(ДанныеЗапроса)
	
	Результат = Новый Структура("Номенклатуры, Ошибки", Новый Массив, Новый СписокЗначений);
	Уникальные = Новый Соответствие;
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.Ошибки.Добавить("В теле запроса нет массива items.");
		Возврат Результат;
	КонецЕсли;
	
	Позиции = ДанныеЗапроса.items;
	Если ТипЗнч(Позиции) <> Тип("Массив") Тогда
		Результат.Ошибки.Добавить("Поле items должно быть массивом.");
		Возврат Результат;
	КонецЕсли;
	
	НомерПозиции = 0;
	Для Каждого Позиция Из Позиции Цикл
		
		НомерПозиции = НомерПозиции + 1;
		
		Если ТипЗнч(Позиция) <> Тип("Структура") Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: неверный формат позиции.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоПозиции(Позиция);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите itemCode или item (наименование).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Если Уникальные.Получить(Номенклатура) = Неопределено Тогда
			Уникальные.Вставить(Номенклатура, Истина);
			Результат.Номенклатуры.Добавить(Номенклатура);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// ─── Строки инвойса из запроса ───────────────────────────────────────────────

Функция РезервированиеИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("reserve") Тогда
		Возврат ДанныеЗапроса.reserve = Истина;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("reserved") Тогда
		Возврат ДанныеЗапроса.reserved = Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗаполнитьТоварыИнвойса(Док, Строки)
	
	Док.Товары.Очистить();
	Для Каждого СтрЗаказа Из Строки Цикл
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрЗаказа.Номенклатура;
		НовСтр.Количество = СтрЗаказа.Количество;
		НовСтр.Цена = СтрЗаказа.Цена;
		НовСтр.Сумма = СтрЗаказа.Цена * НовСтр.Количество;
	КонецЦикла;
	
КонецПроцедуры

// Разбирает массив items: только номенклатура + qty + price, без серий и партий.
// ПроверятьОстатки = Ложь — для PUT, когда остатки проверяются отдельно по сумме строк.
Функция СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Фирма, Склад, ПроверятьОстатки = Истина)
	
	Результат = Новый Структура("Строки, Ошибки", Новый Массив, Новый СписокЗначений);
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.Ошибки.Добавить("В теле запроса нет массива items.");
		Возврат Результат;
	КонецЕсли;
	
	Позиции = ДанныеЗапроса.items;
	Если ТипЗнч(Позиции) <> Тип("Массив") Тогда
		Результат.Ошибки.Добавить("Поле items должно быть массивом.");
		Возврат Результат;
	КонецЕсли;
	
	ТребуемыеКоличества = Новый Соответствие;
	НомерПозиции = 0;
	
	Для Каждого Позиция Из Позиции Цикл
		
		НомерПозиции = НомерПозиции + 1;
		
		Если ТипЗнч(Позиция) <> Тип("Структура") Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: неверный формат позиции.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		//Если ПозицияСодержитПартиюИлиСерию(Позиция) Тогда
		//	Результат.Ошибки.Добавить(СтрШаблон("Строка %1: serial, batch и batchCode не поддерживаются. Укажите itemCode или item.", НомерПозиции));
		//	Продолжить;
		//КонецЕсли;
		
		Количество = 1;
		Если Позиция.Свойство("qty") Тогда
			Количество = Число(Позиция.qty);
		КонецЕсли;
		Если Количество <= 0 Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: qty должно быть больше 0.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Цена = StockAPI_Цены.ЦенаИзПозицииЗапроса(Позиция);
		Если Цена <= 0 Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите price (должна совпадать с salePrice из /balances).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоПозиции(Позиция);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите itemCode или item (наименование).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		СтрЗаказа = Новый Структура("НомерПозиции, Номенклатура, Количество, Цена",
									НомерПозиции, Номенклатура, Количество, Цена);
		Результат.Строки.Добавить(СтрЗаказа);
		
		Если Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = ТребуемыеКоличества.Получить(Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		ТребуемыеКоличества.Вставить(Номенклатура, ТекущееКоличество + Количество);
		
	КонецЦикла;
	
	Если Результат.Ошибки.Количество() = 0 И ПроверятьОстатки Тогда
		ОшибкиОстатков = ПроверитьОстаткиНоменклатуры(ТребуемыеКоличества, Фирма, Склад);
		Для Каждого Ошибка Из ОшибкиОстатков Цикл
			Результат.Ошибки.Добавить(Ошибка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПозицияСодержитПартиюИлиСерию(Позиция)
	
	Если Позиция.Свойство("serial") И СокрЛП(Позиция.serial) <> "" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Позиция.Свойство("batch") И СокрЛП(Позиция.batch) <> "" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Позиция.Свойство("batchCode") И СокрЛП(Строка(Позиция.batchCode)) <> "" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ПроверитьОстаткиНоменклатуры(ТребуемыеКоличества, Фирма, Склад)
	
	Ошибки = Новый Массив;
	
	Для Каждого Пара Из ТребуемыеКоличества Цикл
		
		Доступно = ДоступныйОстатокНоменклатуры(Фирма, Склад, Пара.Ключ);
		Если Пара.Значение > Доступно Тогда
			Ошибки.Добавить(СтрШаблон("Недостаточно остатка для %1: доступно %2, требуется %3.",
				Строка(Пара.Ключ), Доступно, Пара.Значение));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ошибки;
	
КонецФункции

Функция ДоступныйОстатокНоменклатуры(Фирма, Склад, Номенклатура)
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Ост.ОстатокОстаток - Ост.РезервОстаток), 0) КАК Доступно
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(
	|		,
	|		Фирма = &Фирма
	|			И Склад = &Склад
	|			И Номенклатура = &Номенклатура) КАК Ост";
	Зап.УстановитьПараметр("Фирма", Фирма);
	Зап.УстановитьПараметр("Склад", Склад);
	Зап.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Доступно = 0;
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Доступно = Выборка.Доступно;
	КонецЕсли;
	
	// Резерв проформ инвойса — регистр ТоварыВДороге (без привязки к партиям).
	//Доступно = Доступно - РезервНоменклатурыВТоварахВДороге(Склад, Номенклатура);
	
	Возврат Макс(0, Доступно);
	
КонецФункции

Функция РезервНоменклатурыВТоварахВДороге(Склад, Номенклатура)
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Ост.КоличествоОстаток), 0) КАК Резерв
	|ИЗ
	|	РегистрНакопления.ТоварыВДороге.Остатки(
	|		,
	|		(Склад = &Склад
	|			ИЛИ Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка))
	|			И Номенклатура = &Номенклатура
	|			И ВидДороги = ЗНАЧЕНИЕ(Перечисление.ВидДороги.Резерв)) КАК Ост";
	Зап.УстановитьПараметр("Склад", Склад);
	Зап.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Макс(0, Выборка.Резерв);
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция НайтиНоменклатуруПоПозиции(Позиция)
	
	Если Позиция.Свойство("itemCode") И СокрЛП(Строка(Позиция.itemCode)) <> "" Тогда
		Номенклатура = Справочники.Номенклатура.НайтиПоКоду(СокрЛП(Строка(Позиция.itemCode)));
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Если Позиция.Свойство("item") И СокрЛП(Позиция.item) <> "" Тогда
		Наименование = СокрЛП(Позиция.item);
		Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Ложь);
		КонецЕсли;
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция НоменклатураИзСтрокЗаказа(СтрокиЗаказа)
	
	Уникальные = Новый Соответствие;
	МассивНоменклатуры = Новый Массив;
	Для Каждого Стр Из СтрокиЗаказа Цикл
		Если Уникальные.Получить(Стр.Номенклатура) = Неопределено Тогда
			Уникальные.Вставить(Стр.Номенклатура, Истина);
			МассивНоменклатуры.Добавить(Стр.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	Возврат МассивНоменклатуры;
	
КонецФункции

// ─── Расходные накладные (GET /delivery-notes) ───────────────────────────────

// GET /delivery-notes — выгрузка расходной накладной в PDF или Excel.
// Параметры: number (или deliveryNoteNumber), date (опционально), format=pdf|excel, serials=with|without (по умолчанию with).
Функция ПолучитьРасходнуюНакладнуюФайл(Запрос) Экспорт
	
	Результат = Новый Структура("ДвоичныеДанные, ИмяФайла, ТипСодержимого, Ошибка, НеНайден", Неопределено, "", "", "", Ложь);
	
	НомерНакладной = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "number");
	Если НомерНакладной = "" Тогда
		НомерНакладной = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "deliveryNoteNumber");
	КонецЕсли;
	Если НомерНакладной = "" Тогда
		Результат.Ошибка = "Укажите number (или deliveryNoteNumber) — номер расходной накладной.";
		Возврат Результат;
	КонецЕсли;
	
	ДатаНакладной = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "date");
	Если ДатаНакладной = Неопределено Тогда
		ДатаНакладной = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "deliveryNoteDate");
	КонецЕсли;
	
	СсылкаНакладной = НайтиРасходнуюНакладную(НомерНакладной, ?(ДатаНакладной = Неопределено, '00010101', ДатаНакладной));
	Если НЕ ЗначениеЗаполнено(СсылкаНакладной) Тогда
		Результат.Ошибка = СтрШаблон("Расходная накладная %1 не найдена.", НомерНакладной);
		Результат.НеНайден = Истина;
		Возврат Результат;
	КонецЕсли;
	
	Формат = НРег(StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "format"));
	Если Формат = "" Тогда
		Формат = "pdf";
	КонецЕсли;
	
	ПараметрСерий = ПараметрВыгрузкиССериями(Запрос);
	Если ПараметрСерий.Ошибка <> "" Тогда
		Результат.Ошибка = ПараметрСерий.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Если Формат = "pdf" Тогда
			Результат.ДвоичныеДанные = СформироватьPDFРасходнойНакладной(СсылкаНакладной, ПараметрСерий.ССериями);
			Результат.ИмяФайла = ИмяФайлаРасходнойНакладной(СсылкаНакладной, "pdf");
			Результат.ТипСодержимого = "application/pdf";
		ИначеЕсли Формат = "excel" Или Формат = "xlsx" Или Формат = "xls" Тогда
			Результат.ДвоичныеДанные = СформироватьExcelРасходнойНакладной(СсылкаНакладной, ПараметрСерий.ССериями);
			Результат.ИмяФайла = ИмяФайлаРасходнойНакладной(СсылкаНакладной, "xlsx");
			Результат.ТипСодержимого = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
		Иначе
			Результат.Ошибка = "Неподдерживаемый format. Допустимые значения: pdf, excel.";
			Возврат Результат;
		КонецЕсли;
	Исключение
		Результат.Ошибка = "Не удалось сформировать файл накладной: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// serials=with|without (по умолчанию with). Также принимает true/false, 1/0, yes/no.
Функция ПараметрВыгрузкиССериями(Запрос)
	
	Возврат StockAPI_Утилиты.ПараметрSerialsЗапроса(Запрос, Истина);
	
КонецФункции

Функция НайтиРасходнуюНакладную(НомерНакладной, ДатаНакладной = '00010101')
	
	Если СокрЛП(НомерНакладной) = "" Тогда
		Возврат Документы.РасходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	
	Если ДатаНакладной <> '00010101' Тогда
		Ссылка = Документы.РасходнаяНакладная.НайтиПоНомеру(НомерНакладной, ДатаНакладной);
		Если ЗначениеЗаполнено(Ссылка) И НЕ Ссылка.ПометкаУдаления Тогда
			Возврат Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РН.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РН
	|ГДЕ
	|	РН.Номер = &Номер
	|	И НЕ РН.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	РН.Дата УБЫВ";
	Зап.УстановитьПараметр("Номер", СокрЛП(НомерНакладной));
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Документы.РасходнаяНакладная.ПустаяСсылка();
	
КонецФункции

Функция СформироватьPDFРасходнойНакладной(СсылкаНакладной, ССериями = Истина)
	
	ТабДок = Новый ТабличныйДокумент;
	ВариантПечати = ?(ССериями, "ПоСериям", "БезСерий");
	Документы.РасходнаяНакладная.ПечатьДокумента(СсылкаНакладной, ВариантПечати, ТабДок);
	Возврат ТабличныйДокументВДвоичныеДанные(ТабДок, ТипФайлаТабличногоДокумента.PDF, "pdf");
	
КонецФункции

Функция СформироватьExcelРасходнойНакладной(СсылкаНакладной, ССериями = Истина)
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Ложь;
	ТабДок.ОтображатьСетку = Ложь;
	
	КолонокВсего = ?(ССериями, 6, 5);
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	РН.Номер КАК Номер,
	|	РН.Дата КАК Дата,
	|	РН.Контрагент.Наименование КАК Контрагент,
	|	РН.Склад.Наименование КАК Склад,
	|	РН.Валюта.Наименование КАК Валюта,
	|	РН.Сумма КАК Сумма,
	|	РН.ДокументОснование.Номер КАК НомерЗаказа
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РН
	|ГДЕ
	|	РН.Ссылка = &Ссылка";
	Зап.УстановитьПараметр("Ссылка", СсылкаНакладной);
	
	ВыборкаШапки = Зап.Выполнить().Выбрать();
	Если НЕ ВыборкаШапки.Следующий() Тогда
		ВызватьИсключение "Не удалось прочитать расходную накладную.";
	КонецЕсли;
	
	ТабДок.Область(1, 1, 1, КолонокВсего).Текст = СтрШаблон("Расходная накладная № %1 от %2",
		ВыборкаШапки.Номер, Формат(ВыборкаШапки.Дата, "ДЛФ=D"));
	ТабДок.Область(2, 1, 2, КолонокВсего).Текст = СтрШаблон("Покупатель: %1 | Склад: %2 | Валюта: %3",
		ВыборкаШапки.Контрагент, ВыборкаШапки.Склад, ВыборкаШапки.Валюта);
	Если ЗначениеЗаполнено(ВыборкаШапки.НомерЗаказа) Тогда
		ТабДок.Область(3, 1, 3, КолонокВсего).Текст = "Заказ: " + ВыборкаШапки.НомерЗаказа;
	КонецЕсли;
	
	СтрокаЗаголовков = 5;
	ТабДок.Область(СтрокаЗаголовков, 1).Текст = "Номенклатура";
	ТабДок.Область(СтрокаЗаголовков, 2).Текст = "Код";
	ТабДок.Область(СтрокаЗаголовков, 3).Текст = "Количество";
	ТабДок.Область(СтрокаЗаголовков, 4).Текст = "Цена продажи";
	ТабДок.Область(СтрокаЗаголовков, 5).Текст = "Сумма";
	Если ССериями Тогда
		ТабДок.Область(СтрокаЗаголовков, 6).Текст = "Серийный номер";
	КонецЕсли;
	
	ЗапТовары = Новый Запрос;
	Если ССериями Тогда
		ЗапТовары.Текст =
		"ВЫБРАТЬ
		|	Товары.Номенклатура.Наименование КАК Номенклатура,
		|	Товары.Номенклатура.Код КАК Код,
		|	Товары.Количество КАК Количество,
		|	Товары.ЦенаПродажи КАК ЦенаПродажи,
		|	Товары.СуммаПродажи КАК СуммаПродажи,
		|	Товары.Серия КАК Серия,
		|	Товары.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	Товары.НомерСтроки";
	Иначе
		ЗапТовары.Текст =
		"ВЫБРАТЬ
		|	Товары.Номенклатура.Наименование КАК Номенклатура,
		|	Товары.Номенклатура.Код КАК Код,
		|	СУММА(Товары.Количество) КАК Количество,
		|	Товары.ЦенаПродажи КАК ЦенаПродажи,
		|	СУММА(Товары.СуммаПродажи) КАК СуммаПродажи,
		|	МИНИМУМ(Товары.НомерСтроки) КАК НомерСтроки
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура,
		|	Товары.Номенклатура.Наименование,
		|	Товары.Номенклатура.Код,
		|	Товары.ЦенаПродажи
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
	КонецЕсли;
	ЗапТовары.УстановитьПараметр("Ссылка", СсылкаНакладной);
	
	НомерСтроки = СтрокаЗаголовков + 1;
	ВыборкаТовары = ЗапТовары.Выполнить().Выбрать();
	Пока ВыборкаТовары.Следующий() Цикл
		ТабДок.Область(НомерСтроки, 1).Текст = ВыборкаТовары.Номенклатура;
		ТабДок.Область(НомерСтроки, 2).Текст = Формат(ВыборкаТовары.Код, "ЧГ=0");
		ТабДок.Область(НомерСтроки, 3).Текст = ВыборкаТовары.Количество;
		ТабДок.Область(НомерСтроки, 4).Текст = ВыборкаТовары.ЦенаПродажи;
		ТабДок.Область(НомерСтроки, 5).Текст = ВыборкаТовары.СуммаПродажи;
		Если ССериями Тогда
			ТабДок.Область(НомерСтроки, 6).Текст = СокрЛП(ВыборкаТовары.Серия);
		КонецЕсли;
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	ТабДок.Область(НомерСтроки, 4).Текст = "Итого:";
	ТабДок.Область(НомерСтроки, 5).Текст = ВыборкаШапки.Сумма;
	
	Возврат ТабличныйДокументВДвоичныеДанные(ТабДок, ТипФайлаТабличногоДокумента.XLSX, "xlsx");
	
КонецФункции

Функция ТабличныйДокументВДвоичныеДанные(ТабДок, ТипФайла, Расширение)
	
	ИмяФайла = ПолучитьИмяВременногоФайла("." + Расширение);
	ТабДок.Записать(ИмяФайла, ТипФайла);
	ДвоичныеДанные = Новый ДвоичныеДанные(ИмяФайла);
	Попытка
		УдалитьФайлы(ИмяФайла);
	Исключение
	КонецПопытки;
	Возврат ДвоичныеДанные;
	
КонецФункции

Функция ИмяФайлаРасходнойНакладной(СсылкаНакладной, Расширение)
	
	БезопасныйНомер = СтрЗаменить(СокрЛП(СсылкаНакладной.Номер), "/", "-");
	БезопасныйНомер = СтрЗаменить(БезопасныйНомер, "\", "-");
	Возврат "delivery-note-" + БезопасныйНомер + "." + Расширение;
	
КонецФункции
