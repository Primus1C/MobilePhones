// Заказы StockAPI: создание/изменение/получение исходящих инвойсов (проформ) с резервом.
// Расходные накладные создаются вручную в 1С на основании проформы.
// Зависимости: StockAPI_Утилиты, StockAPI_Справочники, StockAPI_Контрагенты, StockAPI_Цены

// ─── Точки входа (POST/PATCH/PUT/DELETE/GET /orders) ─────────────────────────

// POST /orders — создание проформы ИнвойсПродажи с резервированием остатков.
Функция СоздатьЗаказПокупателя(ДанныеЗапроса, КонтекстАвторизации) Экспорт
	
	Результат = Новый Структура("success, error, incomingNumber, orderNumber, orderDate, reserved", Ложь, "", "", "", Ложь);
	
	Если НЕ ДанныеЗапроса.Свойство("orderNo") Тогда
		Результат.Ошибки.Добавить("В запросе нет входящего номера заказа orderNo.");
		Возврат Результат;
	КонецЕсли;
	НайденныйДок = Документы.ИнвойсПродажи.НайтиПоРеквизиту("НомерВходящий", ДанныеЗапроса.orderNo);
	Если НайденныйДок <> Документы.ИнвойсПродажи.ПустаяСсылка() Тогда
		Результат.error = СтрШаблон("В 1С уже зарегистрирован заказ %1 (%2) под номером %3.", ДанныеЗапроса.orderNo, НайденныйДок.Дата, НайденныйДок.Номер);
		Возврат Результат;
	КонецЕсли;
	
	Контрагент = StockAPI_Контрагенты.НайтиКонтрагента(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись, Результат.error);
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Результат.error = "Не найден покупатель. Укажите customer (наименование) или customerCode (код).";
		Возврат Результат;
	КонецЕсли;
	
	Фирма = ПараметрыСеанса.Фирма; 
	
	Склад = StockAPI_Справочники.НайтиСклад(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись, Результат.error);
	Если Результат.error <> "" Тогда
		Возврат Результат;
	КонецЕсли;
	//Если НЕ ЗначениеЗаполнено(Склад) Тогда
	//	Возврат Результат;
	//КонецЕсли;
	
	// +++
	ПроверятьОстатки = ЛОЖЬ;
	// ---
	СтрокиЗаказа = СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Фирма, Склад, ПроверятьОстатки);
	Если СтрокиЗаказа.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СтрокиЗаказа.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиЗаказа.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст.";
		Возврат Результат;
	КонецЕсли;
	
	//ВидЦены = StockAPI_Цены.ВидЦеныИзПараметра(?(ДанныеЗапроса.Свойство("priceType"), ДанныеЗапроса.priceType, ""));
	ВидЦены = Контрагент.ВидЦены;
	Если НЕ ЗначениеЗаполнено(ВидЦены) Тогда
		Результат.error = "В 1С у контрагента не указан вид цен.";
		Возврат Результат;
	КонецЕсли;
	
	ИмяВидаЦены = Строка(ВидЦены);   
	Валюта = ВидЦены.Валюта;
	ЦеныПродажи = StockAPI_Цены.ЗагрузитьЦеныПродажи(НоменклатураИзСтрокЗаказа(СтрокиЗаказа.Строки), ВидЦены);
	
	ОшибкиЦен = StockAPI_Цены.ПроверитьЦеныСтрокЗаказа(СтрокиЗаказа.Строки, ЦеныПродажи, ИмяВидаЦены);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	//Валюта = ?(ДанныеЗапроса.Свойство("currency") И ЗначениеЗаполнено(ДанныеЗапроса.currency),
	//	Справочники.Валюты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.currency), Истина),
	//	Фирма.Валюта);
	//Если НЕ ЗначениеЗаполнено(Валюта) Тогда
	//	Валюта = Фирма.Валюта;
	//КонецЕсли;
	
	Док = Документы.ИнвойсПродажи.СоздатьДокумент();
	Док.Дата 				= ТекущаяДатаСеанса(); 
	Док.НомерВходящий		= ДанныеЗапроса.orderNo;
	Док.Фирма 				= Фирма;
	Док.Контрагент 			= Контрагент;
	//Док.Получатель 			= Контрагент;
	Док.Валюта 				= Валюта;
	Док.Склад 				= Склад;
	Док.Проформа 			= Перечисления.ВидыИнвойса.ЗаказПокупателя;
	Док.РезервироватьТовар 	= РезервированиеИзЗапроса(ДанныеЗапроса);
	ЗаполнитьТоварыИнвойса(Док, СтрокиЗаказа.Строки);
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Результат.error = "Не удалось провести инвойс: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success 			= Истина;
	Результат.incomingNumber	= Док.НомерВходящий;
	Результат.orderNumber 		= Док.Номер;
	Результат.orderDate 		= StockAPI_Утилиты.ДатаВСтроку(Док.Дата);
	Результат.reserved 			= Док.РезервироватьТовар И Док.Проведен;
	Возврат Результат;
	
КонецФункции

// PATCH /orders — полное редактирование проформы (заголовок + полная замена items).
Функция ИзменитьЗаказПокупателя(ДанныеЗапроса) Экспорт
	
	Результат = РезультатИзмененияЗаказа();
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсДляРедактирования(ДанныеЗапроса, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.error = "В теле запроса нет массива items.";
		Возврат Результат;
	КонецЕсли;
	
	Док = СсылкаЗаказа.ПолучитьОбъект();
	БылПроведен = Док.Проведен;
	СтарыеТовары = Док.Товары.Выгрузить();
	
	Если НЕ ПрименитьЗаголовокИнвойсаИзЗапроса(Док, ДанныеЗапроса, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Фирма = Док.Фирма;
	Склад = Док.Склад;
	
	СтрокиЗаказа = СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Фирма, Склад);
	Если СтрокиЗаказа.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СтрокиЗаказа.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиЗаказа.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	ОшибкиЦен = ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиЗаказа.Строки, ДанныеЗапроса, Склад);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ СнятьПроведениеИнвойса(Док, БылПроведен, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЗаполнитьТоварыИнвойса(Док, СтрокиЗаказа.Строки);
	
	Возврат ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен);
	
КонецФункции

// PUT /orders — добавление позиций в существующую проформу.
Функция ДобавитьПозицииВЗаказ(ДанныеЗапроса) Экспорт
	
	Результат = РезультатИзмененияЗаказа();
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсДляРедактирования(ДанныеЗапроса, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.error = "В теле запроса нет массива items.";
		Возврат Результат;
	КонецЕсли;
	
	Док = СсылкаЗаказа.ПолучитьОбъект();
	Фирма = Док.Фирма;
	Склад = Док.Склад;
	БылПроведен = Док.Проведен;
	СтарыеТовары = Док.Товары.Выгрузить();
	
	СтрокиНовые = СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Фирма, Склад, Ложь);
	Если СтрокиНовые.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СтрокиНовые.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиНовые.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	ТребуемыеКоличества = ТребуемыеКоличестваИзТабличнойЧасти(Док.Товары);
	ДобавитьТребуемыеКоличества(ТребуемыеКоличества, СтрокиНовые.Строки);
	ОшибкиОстатков = ПроверитьОстаткиНоменклатуры(ТребуемыеКоличества, Фирма, Склад);
	Если ОшибкиОстатков.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиОстатков);
		Возврат Результат;
	КонецЕсли;
	
	ОшибкиЦен = ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиНовые.Строки, ДанныеЗапроса, Склад);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ СнятьПроведениеИнвойса(Док, БылПроведен, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого СтрЗаказа Из СтрокиНовые.Строки Цикл
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрЗаказа.Номенклатура;
		НовСтр.Количество = СтрЗаказа.Количество;
		НовСтр.Цена = СтрЗаказа.Цена;
		НовСтр.Сумма = СтрЗаказа.Цена * НовСтр.Количество;
	КонецЦикла;
	
	Возврат ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен);
	
КонецФункции

// DELETE /orders — удаление позиций; если позиций не осталось — удаление инвойса целиком.
Функция УдалитьПозицииИзЗаказа(ДанныеЗапроса) Экспорт
	
	Результат = РезультатИзмененияЗаказа();
	Результат.Вставить("deleted", Ложь);
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсДляРедактирования(ДанныеЗапроса, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	НоменклатурыУдаления = НоменклатурыДляУдаленияИзЗапроса(ДанныеЗапроса);
	Если НоменклатурыУдаления.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(НоменклатурыУдаления.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если НоменклатурыУдаления.Номенклатуры.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	НомерЗаказа = СсылкаЗаказа.Номер;
	УдалениеВсегоИнвойса = ВсеПозицииИнвойсаВЗапросе(СсылкаЗаказа, НоменклатурыУдаления.Номенклатуры);
	
	// Все позиции инвойса — только пометка на удаление, табличную часть не меняем.
	Если УдалениеВсегоИнвойса Тогда
		Возврат ПометитьИнвойсНаУдаление(СсылкаЗаказа, НомерЗаказа, Результат);
	КонецЕсли;
	
	Док = СсылкаЗаказа.ПолучитьОбъект();
	БылПроведен = Док.Проведен;
	СтарыеТовары = Док.Товары.Выгрузить();
	
	Если НЕ СнятьПроведениеИнвойса(Док, БылПроведен, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Номенклатура Из НоменклатурыУдаления.Номенклатуры Цикл
		СтрокиДляУдаления = Док.Товары.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
		Для Каждого СтрокаТЧ Из СтрокиДляУдаления Цикл
			Док.Товары.Удалить(СтрокаТЧ);
		КонецЦикла;
	КонецЦикла;
	
	Если Док.Товары.Количество() = 0 Тогда
		Результат.error = "Нельзя оставить инвойс без позиций. Для удаления заказа укажите все позиции в items.";
		Возврат Результат;
	КонецЕсли;
	
	РезультатПроведения = ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен);
	РезультатПроведения.deleted = Ложь;
	Возврат РезультатПроведения;
	
КонецФункции

// GET /orders — список проформ по номеру (один) или по покупателю + дате (с пагинацией). 
//
Функция ПолучитьЗаказы(Запрос, ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура("Тело, Ошибка, НеНайден", Неопределено, "", Ложь);
	Фильтр = ПараметрыПоискаЗаказов(Запрос, ДанныеЗапроса, УчетнаяЗапись);
	Если Фильтр.Ошибка <> "" Тогда
		Результат.Ошибка = Фильтр.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Результат.Ошибка = Пагинация.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Если Фильтр.Режим = "single" Тогда
		
		СсылкаЗаказа = НайтиИнвойсПродажи(Фильтр.orderNumber, Фильтр.orderDate, Результат.Ошибка);
		Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
			Результат.Ошибка = СтрШаблон("Заказ %1 не найден.", Фильтр.orderNumber);
			Результат.НеНайден = Истина;
			Возврат Результат;
		КонецЕсли;
		
		МассивЗаказов = Новый Массив;
		МассивЗаказов.Добавить(СтруктураЗаказаJSON(СсылкаЗаказа, СтрокиЗаказовПоДокументам(СсылкаЗаказа)));
		
		ТелоОтвета = Новый Структура;
		ТелоОтвета.Вставить("page", 1);
		ТелоОтвета.Вставить("pageSize", Пагинация.pageSize);
		ТелоОтвета.Вставить("totalItems", 1);
		ТелоОтвета.Вставить("totalPages", 1);
		ТелоОтвета.Вставить("items", МассивЗаказов);
		Результат.Тело = ТелоОтвета;
		Возврат Результат;
		
	КонецЕсли;
	
	ВсегоЗаказов = КоличествоЗаказовПокупателя(Фильтр.Контрагент, Фильтр.dateFrom, Фильтр.dateTo);
	ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоЗаказов, Пагинация.pageSize);
	Пропустить = (Пагинация.page - 1) * Пагинация.pageSize;
	СсылкиЗаказов = ЗаказыПокупателяСтраница(Фильтр.Контрагент, Фильтр.dateFrom, Фильтр.dateTo, Пагинация.pageSize, Пропустить);
	СтрокиПоЗаказам = СтрокиЗаказовПоДокументам(СсылкиЗаказов);
	
	МассивЗаказов = Новый Массив;
	Для Каждого СсылкаЗаказа Из СсылкиЗаказов Цикл
		МассивЗаказов.Добавить(СтруктураЗаказаJSON(СсылкаЗаказа, СтрокиПоЗаказам));
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("page", Пагинация.page);
	ТелоОтвета.Вставить("pageSize", Пагинация.pageSize);
	ТелоОтвета.Вставить("totalItems", ВсегоЗаказов);
	ТелоОтвета.Вставить("totalPages", ВсегоСтраниц);
	ТелоОтвета.Вставить("items", МассивЗаказов);
	Результат.Тело = ТелоОтвета;
	Возврат Результат;
	
КонецФункции

// ─── Параметры поиска и чтение заказов ───────────────────────────────────────

Функция ПараметрыПоискаЗаказов(Запрос, ДанныеЗапроса, УчетнаяЗапись)
	
	Результат = Новый Структура("Режим, orderNumber, orderDate, Контрагент, dateFrom, dateTo, Ошибка", "list", "", '00010101', Справочники.Контрагенты.ПустаяСсылка(), '00010101', '00010101', "");
	
	НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "orderNumber");
	Если НомерЗаказа = "" Тогда
		НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "number");
	КонецЕсли;
	
	Если НомерЗаказа <> "" Тогда 
		Результат.Режим = "single";
		Результат.orderNumber = НомерЗаказа;
		ДатаЗаказа = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "orderDate");
		Если ДатаЗаказа = Неопределено Тогда
			ДатаЗаказа = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "date");
		КонецЕсли;
		Если ДатаЗаказа <> Неопределено Тогда
			Результат.orderDate = ДатаЗаказа;
		КонецЕсли;   
		Возврат Результат;
	КонецЕсли;
	
	//////Результат = Новый Структура("Режим, orderNumber, Контрагент, dateFrom, dateTo, Ошибка", "list", "", '00010101', Справочники.Контрагенты.ПустаяСсылка(), '00010101', '00010101', "");
	//////
	//////НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "orderNumber");
	//////Если НомерЗаказа = "" Тогда
	//////	Результат.Режим = "multy";
	//////	Контрагент = StockAPI_Контрагенты.НайтиКонтрагента(ДанныеЗапроса, УчетнаяЗапись, Результат.Ошибка); 
	//////	
	//////Иначе
	//////	Результат.Режим = "single";
	//////	Результат.orderNumber = НомерЗаказа;  
	//////	
	//////КонецЕсли;	
	
	
	
	
	
	Результат.Режим = "multiple";
	
	Контрагент = КонтрагентИзПараметровЗапроса(Запрос); 
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Результат.Ошибка = "Укажите orderNumber, либо customer (или customerCode) вместе с dateFrom и dateTo.";
		Возврат Результат;
	КонецЕсли;
	
	ДатаНачала = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "dateFrom");
	Если ДатаНачала = Неопределено Тогда
		ДатаНачала = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "from");
	КонецЕсли;
	ДатаОкончания = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "dateTo");
	Если ДатаОкончания = Неопределено Тогда
		ДатаОкончания = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "to");
	КонецЕсли;
	
	Если ДатаНачала = Неопределено Или ДатаОкончания = Неопределено Тогда
		Результат.Ошибка = "Для поиска по покупателю укажите dateFrom и dateTo (формат yyyy-MM-dd).";
		Возврат Результат;
	КонецЕсли;
	
	Если ДатаНачала > ДатаОкончания Тогда
		Результат.Ошибка = "dateFrom не может быть позже dateTo.";
		Возврат Результат;
	КонецЕсли;
	
	Результат.Контрагент = Контрагент;
	Результат.dateFrom = НачалоДня(ДатаНачала);
	Результат.dateTo = КонецДня(ДатаОкончания);
	Возврат Результат;
	
КонецФункции

Функция КонтрагентИзПараметровЗапроса(Запрос)
	
	КодСтрока = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "customerCode");
	Если КодСтрока = "" Тогда
		КодСтрока = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "code");
	КонецЕсли;
	
	Если КодСтрока <> "" Тогда
		Попытка
			Контрагент = Справочники.Контрагенты.НайтиПоКоду(Число(КодСтрока));
			Если ЗначениеЗаполнено(Контрагент) И НЕ Контрагент.ЭтоГруппа Тогда
				Возврат Контрагент;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	ИмяПокупателя = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "customer");
	Если ИмяПокупателя <> "" Тогда
		Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(ИмяПокупателя, Истина);
		Если ЗначениеЗаполнено(Контрагент) Тогда
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция ДатаЗаказаИзДанных(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат '00010101';
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("orderDate") И СокрЛП(Строка(ДанныеЗапроса.orderDate)) <> "" Тогда
		СтрокаДаты = СокрЛП(Строка(ДанныеЗапроса.orderDate));
		Если СтрДлина(СтрокаДаты) >= 10 Тогда
			СтрокаДаты = Лев(СтрокаДаты, 10);
		КонецЕсли;
		Попытка
			Возврат Дата(СтрокаДаты);
		Исключение
			Возврат '00010101';
		КонецПопытки;
	КонецЕсли;
	
	Возврат '00010101';
	
КонецФункции

Функция НомерЗаказаИзДанных(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("orderNumber") Тогда
		Возврат СокрЛП(Строка(ДанныеЗапроса.orderNumber));
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("number") Тогда
		Возврат СокрЛП(Строка(ДанныеЗапроса.number));
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

