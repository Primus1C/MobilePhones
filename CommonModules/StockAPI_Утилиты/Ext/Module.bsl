// Общие утилиты StockAPI: разбор параметров запроса, пагинация, форматирование ошибок.

Функция СтрокаПараметраЗапроса(Запрос, ИмяПараметра) Экспорт
	
	Значение = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СокрЛП(Строка(Значение));
	
КонецФункции

Функция ДатаПараметраЗапроса(Запрос, ИмяПараметра) Экспорт
	
	СтрокаДаты = СтрокаПараметраЗапроса(Запрос, ИмяПараметра);
	Если СтрокаДаты = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Если СтрДлина(СтрокаДаты) >= 10 Тогда
			СтрокаДаты = Лев(СтрокаДаты, 10);
		КонецЕсли;
		Возврат Дата(СтрокаДаты);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Функция ЦелоеПараметраЗапроса(СтрокаЗначения, ЗначениеПоУмолчанию) Экспорт
	
	Если СтрокаЗначения = Неопределено Или СокрЛП(СтрокаЗначения) = "" Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Попытка
		ЧислоЗначения = Число(СтрокаЗначения);
	Исключение
		Возврат -1;
	КонецПопытки;
	
	Если ЧислоЗначения <> Цел(ЧислоЗначения) Тогда
		Возврат -1;
	КонецЕсли;
	
	Возврат Цел(ЧислоЗначения);
	
КонецФункции

Функция ВсегоСтраницПагинации(ВсегоЭлементов, РазмерСтраницы) Экспорт
	
	Если ВсегоЭлементов = 0 Или РазмерСтраницы <= 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Цел((ВсегоЭлементов - 1) / РазмерСтраницы) + 1;
	
КонецФункции

// Разбор параметров пагинации: page (с 1), pageSize/limit (макс. 500).
Функция ПараметрыПагинацииОстатков(Запрос) Экспорт
	
	МаксРазмерСтраницы = 500;
	РазмерПоУмолчанию = 500;
	Результат = Новый Структура("page, pageSize, Ошибка", 1, РазмерПоУмолчанию, "");
	
	СтрокаСтраницы = Запрос.ПараметрыЗапроса.Получить("page");
	СтрокаРазмера = Запрос.ПараметрыЗапроса.Получить("pageSize");
	Если СтрокаРазмера = Неопределено Или СокрЛП(СтрокаРазмера) = "" Тогда
		СтрокаРазмера = Запрос.ПараметрыЗапроса.Получить("limit");
	КонецЕсли;
	
	НомерСтраницы = ЦелоеПараметраЗапроса(СтрокаСтраницы, 1);
	Если НомерСтраницы < 0 Тогда
		Результат.Ошибка = "Параметр page должен быть целым числом >= 1.";
		Возврат Результат;
	КонецЕсли;
	Если НомерСтраницы = 0 Тогда
		НомерСтраницы = 1;
	КонецЕсли;
	
	РазмерСтраницы = ЦелоеПараметраЗапроса(СтрокаРазмера, РазмерПоУмолчанию);
	Если РазмерСтраницы < 0 Тогда
		Результат.Ошибка = "Параметр pageSize (или limit) должен быть целым числом от 1 до 500.";
		Возврат Результат;
	КонецЕсли;
	Если РазмерСтраницы = 0 Тогда
		РазмерСтраницы = РазмерПоУмолчанию;
	КонецЕсли;
	Если РазмерСтраницы > МаксРазмерСтраницы Тогда
		Результат.Ошибка = СтрШаблон("pageSize не может превышать %1.", МаксРазмерСтраницы);
		Возврат Результат;
	КонецЕсли;
	
	Результат.page = НомерСтраницы;
	Результат.pageSize = РазмерСтраницы;
	Возврат Результат;
	
КонецФункции

// Собирает все строки из СписокЗначений в одну строку с переносами.
Функция ТекстОшибокСписка(Ошибки) Экспорт
	
	Текст = "";
	Для Каждого Ошибка Из Ошибки Цикл
		Текст = Текст + Ошибка.Значение + Символы.ПС;
	КонецЦикла;
	Возврат СокрЛП(Текст);
	
КонецФункции

// serials=with|without. ПоУмолчаниюССериями — если параметр не передан.
Функция ПараметрSerialsЗапроса(Запрос, ПоУмолчаниюССериями = Истина) Экспорт
	
	Результат = Новый Структура("ССериями, Ошибка", ПоУмолчаниюССериями, "");
	СтрокаПараметра = НРег(СтрокаПараметраЗапроса(Запрос, "serials"));
	Если СтрокаПараметра = "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокаПараметра = "with"
		Или СтрокаПараметра = "true"
		Или СтрокаПараметра = "1"
		Или СтрокаПараметра = "yes" Тогда
		Результат.ССериями = Истина;
	ИначеЕсли СтрокаПараметра = "without"
		Или СтрокаПараметра = "false"
		Или СтрокаПараметра = "0"
		Или СтрокаПараметра = "no" Тогда
		Результат.ССериями = Ложь;
	Иначе
		Результат.Ошибка = "Неподдерживаемый serials. Допустимые значения: with, without.";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
