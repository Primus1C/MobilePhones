// Возвращает криптографически стойкий хеш SHA-256 (строка 64 символа в нижнем регистре)   
//
Функция СгенерироватьТокенSHA256() Экспорт
	
	// 1. Формируем уникальную исходную строку (соль)
	// Комбинация GUID и времени до миллисекунд исключает совпадения даже теоретически
	УникальнаяСтрока = Строка(Новый УникальныйИдентификатор) 
	                 + Строка(ТекущаяУниверсальнаяДатаВМиллисекундах());
	
	// 2. Инициализируем объект хеширования алгоритмом SHA-256
	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	
	// 3. Вычисляем хеш для нашей строки
	Хеширование.Добавить(УникальнаяСтрока);
	
	// 4. Получаем результат в виде двоичных данных
	ДвоичныеДанныеХеша = Хеширование.ХешСумма;
	
	// 5. Конвертируем в шестнадцатеричную строку (Hex)
	СтрокаHex = НРег(ПолучитьHexСтрокуИзДвоичныхДанных(ДвоичныеДанныеХеша));
	
	Возврат СтрокаHex;
	
КонецФункции

Функция ПроверитьКлючAPI(ЗапросАПИ, КонтекстАвторизации) Экспорт
	
	// Ожидаем, что клиент присылает ключ в заголовке X-Api-Key
	КлючКлиента = ЗапросАПИ.Заголовки.Получить("X-Api-Key");

	Если Не ЗначениеЗаполнено(КлючКлиента) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗапросБД = Новый Запрос;
	ЗапросБД.Текст = 
		"ВЫБРАТЬ
		|	УчетныеЗаписиИнтеграции.Контрагент КАК Контрагент,
		|	УчетныеЗаписиИнтеграции.Ссылка КАК УчетнаяЗапись
		|ИЗ
		|	Справочник.УчетныеЗаписиИнтеграции КАК УчетныеЗаписиИнтеграции
		|ГДЕ
		|	УчетныеЗаписиИнтеграции.ТокенАвторизации = &КлючAPI
		|	И УчетныеЗаписиИнтеграции.Активен";
		
	ЗапросБД.УстановитьПараметр("КлючAPI", КлючКлиента);
	Выборка = ЗапросБД.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		КонтекстАвторизации.Вставить("Контрагент", Выборка.Контрагент);
		КонтекстАвторизации.Вставить("УчетнаяЗапись", Выборка.УчетнаяЗапись);  
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция КодВСтроку(Код) Экспорт
	
	Если Код = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Формат(Код, "ЧГ=0");
	
КонецФункции

Процедура ЗаписатьВПротокол(Запрос, Ответ, ПользовательИнтеграции, ДлительностьМс, ТекстОшибкиВнутр = "") Экспорт
	
	Попытка
		МЗ = РегистрыСведений.ПротоколОбменов.СоздатьМенеджерЗаписи();
		
		// Измерения и базовые реквизиты
		МЗ.ИдентификаторЗапроса = Новый УникальныйИдентификатор;
		МЗ.Дата = ТекущаяДатаСеанса();
		МЗ.ИмяСервиса = "StockAPI";
		//МЗ.ШаблонURL = Запрос.ШаблонURL;
		
		Попытка
			// Запись перечисления (GET, POST и т.д.)
			МЗ.HTTPМетод = Перечисления.HTTPМетод[Запрос.HTTPМетод];
		Исключение
		КонецПопытки;
		
		МЗ.КодСостояния = Ответ.КодСостояния;
		МЗ.Длительность = ДлительностьМс;
		МЗ.Пользователь = ПользовательИнтеграции;
		МЗ.ТекстОшибки = Лев(ТекстОшибкиВнутр, 200);
		
		// Определение IP адреса
		IP = Запрос.Заголовки.Получить("X-Forwarded-For");
		Если IP = Неопределено Тогда
			IP = Запрос.Заголовки.Получить("Remote-Addr");
		КонецЕсли;
		МЗ.IPАдрес = ?(IP = Неопределено, "", Лев(IP, 50));
		
		// Запись ресурсов (ХранилищеЗначения)
		МЗ.ЗаголовкиЗапроса = Новый ХранилищеЗначения(СтруктураВJSON(Запрос.Заголовки), Новый СжатиеДанных(9));
		МЗ.ТелоЗапроса = Новый ХранилищеЗначения(Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8), Новый СжатиеДанных(9));
		МЗ.ТелоОтвета = Новый ХранилищеЗначения(Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8), Новый СжатиеДанных(9));
		
		МЗ.Записать();
	Исключение
		// Ошибка записи лога не должна ронять сам API
		ЗаписьЖурналаРегистрации("StockAPI.Протоколирование", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры




#Область Неактуально

Функция АвторизоватьЗапрос(Запрос, ПользовательИнтеграции, Ответ) Экспорт
	
	ЗаголовокAuth = Запрос.Заголовки.Получить("Authorization");
	Если ЗаголовокAuth = Неопределено Или Не СтрНачинаетсяС(ЗаголовокAuth, "Basic ") Тогда
		УстановитьОшибкуАвторизации(Ответ, "Отсутствует или неверен заголовок Authorization");
		Возврат Ложь;
	КонецЕсли;
	
	СтрокаBase64 = СтрЗаменить(ЗаголовокAuth, "Basic ", "");
	Попытка
		// Декодируем учетные данные из Base64
		ДвоичныеДанныеAuth = Base64Значение(СтрокаBase64);
		УчетныеДанные = ПолучитьСтрокуИзДвоичныхДанных(ДвоичныеДанныеAuth, КодировкаТекста.UTF8);
	Исключение
		УстановитьОшибкуАвторизации(Ответ, "Ошибка декодирования Base64");
		Возврат Ложь;
	КонецПопытки;
	
	ПозицияДвоеточия = СтрНайти(УчетныеДанные, ":");
	Если ПозицияДвоеточия = 0 Тогда
		УстановитьОшибкуАвторизации(Ответ, "Неверный формат учетных данных (ожидается логин:пароль)");
		Возврат Ложь;
	КонецЕсли;
	
	Логин = Лев(УчетныеДанные, ПозицияДвоеточия - 1);
	Пароль = Сред(УчетныеДанные, ПозицияДвоеточия + 1);
	
	// Поиск активной учетной записи
	ЗапросБД = Новый Запрос;
	ЗапросБД.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	УЗ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.УчетныеЗаписиИнтеграции КАК УЗ
		|ГДЕ
		|	УЗ.Логин = &Логин
		|	И УЗ.Пароль = &Пароль
		|	И УЗ.Активен = ИСТИНА
		|	И НЕ УЗ.ПометкаУдаления";
	ЗапросБД.УстановитьПараметр("Логин", Логин);
	ЗапросБД.УстановитьПараметр("Пароль", Пароль);
	
	Выборка = ЗапросБД.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПользовательИнтеграции = Выборка.Ссылка;
		Возврат Истина;
	КонецЕсли;
	
	УстановитьОшибкуАвторизации(Ответ, "Неверный логин или пароль, либо учетная запись отключена");
	Возврат Ложь;
	
КонецФункции

Процедура УстановитьОшибкуАвторизации(Ответ, ТекстОшибки)
	Ответ = Новый HTTPСервисОтвет(401);
	Ответ.Заголовки.Вставить("WWW-Authenticate", "Basic realm=""StockAPI""");
	
	Тело = Новый Структура("error", ТекстОшибки);
	Ответ.УстановитьТелоИзСтроки(СтруктураВJSON(Тело), КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
КонецПроцедуры      

Функция ВыполнитьМетодAPI(Запрос, ИмяМетодаОбработчика) Экспорт
	
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ПользовательИнтеграции = Справочники.УчетныеЗаписиИнтеграции.ПустаяСсылка();
	Ответ = Неопределено;
	ТекстОшибкиВнутр = "";
	
	// Шаг 1. Аутентификация
	Если Не АвторизоватьЗапрос(Запрос, ПользовательИнтеграции, Ответ) Тогда
		ВремяВыполнения = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачала;
		ЗаписатьВПротокол(Запрос, Ответ, ПользовательИнтеграции, ВремяВыполнения, "Ошибка авторизации");
		Возврат Ответ;
	КонецЕсли;
	
	// Шаг 2. Выполнение бизнес-логики (например, StockAPI_Заказы.СоздатьЗаказПокупателя)
	Попытка
		// Вызываем метод, передавая Запрос. В метод можно добавить и передачу ПользовательИнтеграции,
		// чтобы определять Контрагента или доступные Склады прямо из учетной записи.
		РезультатОбработки = Вычислить(ИмяМетодаОбработчика + "(Запрос)");
		
		// Формируем финальный HTTP-ответ
		Ответ = Новый HTTPСервисОтвет(РезультатОбработки.КодОтвета);
		Ответ.УстановитьТелоИзСтроки(СтруктураВJSON(РезультатОбработки.Тело), КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		
	Исключение
		ИнфоОшибка = ИнформацияОбОшибке();
		ТекстОшибкиВнутр = КраткоеПредставлениеОшибки(ИнфоОшибка);
		
		Ответ = Новый HTTPСервисОтвет(500);
		ТелоОшибки = Новый Структура("error", "Внутренняя ошибка сервера API");
		Ответ.УстановитьТелоИзСтроки(СтруктураВJSON(ТелоОшибки), КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	КонецПопытки;
	
	// Шаг 3. Запись в Регистр Сведений
	ВремяВыполнения = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачала;
	ЗаписатьВПротокол(Запрос, Ответ, ПользовательИнтеграции, ВремяВыполнения, ТекстОшибкиВнутр);
	
	Возврат Ответ;
	
КонецФункции

// Вспомогательная функция для JSON
//
Функция СтруктураВJSON(Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

