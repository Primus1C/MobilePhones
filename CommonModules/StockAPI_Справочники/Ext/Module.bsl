// Справочники StockAPI: форматирование кодов, поиск фирмы/склада/контрагента, списки складов и валют.

Функция КодВСтроку(Код) Экспорт
	
	Если Код = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Формат(Код, "ЧГ=0");
	
КонецФункции

