Процедура ПроверитьНаТолькоТовары(ТаблицаТовары, Ошибки) Экспорт

	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("ТЗ", ТаблицаТовары);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.НомерСтроки КАК НомерСтрокиТЧ,
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.ТипНоменклатуры КАК ТипНоменклатуры
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |ГДЕ
	               |	ТЗ.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
	               |	ВТ.Номенклатура КАК Номенклатура,
	               |	ВТ.ТипНоменклатуры КАК ТипНоменклатуры
	               |ИЗ
	               |	ВТ КАК ВТ";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Ошибки.Добавить(СтрШаблон(НСтр("ru = 'Строка %1: номенклатура %2 с видом %3!'; en = 'Line %1: good %2 has kind %3!'"), 
						Выборка.НомерСтрокиТЧ, Выборка.Номенклатура, Выборка.ТипНоменклатуры));
	КонецЦикла;

КонецПроцедуры

Процедура ПроверитьНаОстаткиТоваров(ТаблицаТовары, Дата, Склад, Ошибки, Фирма = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЗ", ТаблицаТовары);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Фирма", ?(Фирма = Неопределено, ПараметрыСеанса.Фирма, Фирма));
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.НомерСтроки КАК НомерСтрокиТЧ,
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.Партия КАК Партия,
	               |	ТЗ.Серия КАК Серия,
	               |	ТЗ.Количество КАК Количество
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |ГДЕ
	               |	ТЗ.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
	               |	ВТ.Номенклатура КАК Номенклатура,
	               |	ВТ.Партия КАК Партия,
	               |	ВТ.Серия КАК Серия,
	               |	ВТ.Количество КАК Количество,
	               |	ЕСТЬNULL(ОстаткиПартий.ОстатокОстаток, 0) КАК Остаток
	               |ИЗ
	               |	ВТ КАК ВТ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(
	               |				,
	               |				Партия В
	               |						(ВЫБРАТЬ
	               |							Т.Партия
	               |						ИЗ
	               |							ВТ КАК Т)
	               |					И Склад = &Склад
	               |					И Фирма = &Фирма) КАК ОстаткиПартий
	               |		ПО ВТ.Партия = ОстаткиПартий.Партия";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

	КонецЦикла;

КонецПроцедуры
