Функция ПрочитатьТелоJSON(Запрос)
	
	Тело = Запрос.ПолучитьТелоКакСтроку();
	Если СокрЛП(Тело) = "" Тогда
		Возврат Новый Структура;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Тело);
	Возврат ПрочитатьJSON(ЧтениеJSON);
	
КонецФункции

Функция ОтветJSON(КодСостояния, Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть());
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Возврат Ответ;
	
КонецФункции

Функция СоздатьЗаказПокупателя(ДанныеЗапроса)
	
	Результат = Новый Структура("success, error, orderNumber, orderDate, reserved", Ложь, "", "", "", Ложь);
	
	Контрагент = НайтиКонтрагента(ДанныеЗапроса);
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Результат.error = "Не найден покупатель. Укажите customer (наименование) или customerCode (код).";
		Возврат Результат;
	КонецЕсли;
	
	Фирма = НайтиФирму(ДанныеЗапроса);
	Склад = НайтиСклад(ДанныеЗапроса, Фирма);
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Результат.error = "Не найден склад. Укажите warehouse (наименование склада).";
		Возврат Результат;
	КонецЕсли;
	
	СтрокиЗаказа = СтрокиЗаказаИзЗапроса(ДанныеЗапроса, Фирма, Склад);
	Если СтрокиЗаказа.Ошибки.Количество() > 0 Тогда
		Результат.error = ТекстОшибокСписка(СтрокиЗаказа.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиЗаказа.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	ВидЦены = ВидЦеныИзПараметра(?(ДанныеЗапроса.Свойство("priceType"), ДанныеЗапроса.priceType, ""));
	ИмяВидаЦены = Строка(ВидЦены);
	ЦеныПродажи = ЗагрузитьЦеныПродажи(КонецДня(ТекущаяДатаСеанса()), НоменклатураИзСтрокЗаказа(СтрокиЗаказа.Строки), ВидЦены);
	
	ОшибкиЦен = ПроверитьЦеныСтрокЗаказа(СтрокиЗаказа.Строки, ЦеныПродажи, ИмяВидаЦены);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	Валюта = ?(ДанныеЗапроса.Свойство("currency") И ЗначениеЗаполнено(ДанныеЗапроса.currency),
		Справочники.Валюты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.currency), Истина),
		Фирма.Валюта);
	Если НЕ ЗначениеЗаполнено(Валюта) Тогда
		Валюта = Фирма.Валюта;
	КонецЕсли;
	
	Док = Документы.РасходнаяНакладная.СоздатьДокумент();
	Док.Дата = ТекущаяДатаСеанса();
	Док.Фирма = Фирма;
	Док.Склад = Склад;
	Док.Контрагент = Контрагент;
	Док.Валюта = Валюта;
	Док.Окончательно = Ложь;
	
	Для Каждого СтрЗаказа Из СтрокиЗаказа.Строки Цикл
		
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрЗаказа.Номенклатура;
		НовСтр.Партия = СтрЗаказа.Партия;
		НовСтр.Серия = СтрЗаказа.Серия;
		НовСтр.Количество = СтрЗаказа.Количество;
		
		НовСтр.ЦенаПродажи = СтрЗаказа.Цена;
		НовСтр.СуммаПродажи = СтрЗаказа.Цена * НовСтр.Количество;
		
	КонецЦикла;
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Результат.error = "Не удалось провести заказ: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success = Истина;
	Результат.orderNumber = Док.Номер;
	Результат.orderDate = Формат(Док.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss");
	Результат.reserved = Истина;
	Возврат Результат;
	
КонецФункции

