// HTTP-роутинг StockAPI — тонкий слой, вся бизнес-логика в общих модулях:
//   StockAPI_Остатки, StockAPI_Заказы, StockAPI_Контрагенты,
//   StockAPI_Справочники, StockAPI_Цены, StockAPI_Утилиты

// GET /balances — остатки товаров с ценами; serials=with для серийных номеров.
Функция balancesGET(Запрос)
	
	КонтекстАвторизации = Новый Структура;
	Если Не StockAPI_Утилиты.ПроверитьКлючAPI(Запрос, КонтекстАвторизации) Тогда
		Возврат ОтветJSON(401, Новый Структура("error", "Unauthorized: Invalid or missing API Key"));
	КонецЕсли;

	Попытка
		Рез = StockAPI_Остатки.ПолучитьОстатки(Запрос);
		Возврат ОтветJSON(Рез.КодОтвета, Рез.Тело);
	Исключение
		Возврат ОтветJSON(500, Новый Структура("error", ОписаниеОшибки()));
	КонецПопытки;
	
КонецФункции

// POST /orders — создание проформы ИнвойсПродажи с резервированием остатков.
Функция ordersPOST(Запрос)
	
	Попытка
		ДанныеЗапроса = ПрочитатьТелоJSON(Запрос);
		РезультатСоздания = StockAPI_Заказы.СоздатьЗаказПокупателя(ДанныеЗапроса);
		Возврат ОтветJSON(?(РезультатСоздания.success, 200, 400), РезультатСоздания);
	Исключение
		Возврат ОтветJSON(500, Новый Структура("success, error", Ложь, ОписаниеОшибки()));
	КонецПопытки;
	
КонецФункции

// GET /orders — список заказов: по orderNumber — один; по customer + dateFrom/dateTo — с пагинацией.
