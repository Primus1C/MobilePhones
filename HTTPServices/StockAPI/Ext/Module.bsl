КонецФункции

Функция ИменаГруппДляПоиска(ТипКонтрагента)
	
	МассивИмен = Новый Массив;
	МассивИмен.Добавить(ИмяГруппыПоУмолчанию(ТипКонтрагента));
	
	Если ТипКонтрагента = "supplier" Тогда
		МассивИмен.Добавить("Поставщики");
		МассивИмен.Добавить("Контрагенты поставщики");
	Иначе
		МассивИмен.Добавить("Покупатели");
		МассивИмен.Добавить("Контрагенты покупатели");
	КонецЕсли;
	
	Возврат МассивИмен;
	
КонецФункции

Функция НайтиГруппуКонтрагентовПоИмени(ИмяГруппы)
	
	Имя = СокрЛП(ИмяГруппы);
	Если Имя = "" Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Конт.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|	И Конт.Наименование = &Наименование";
	Зап.УстановитьПараметр("Наименование", Имя);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция НайтиГруппуКонтрагентовПоКоду(КодГруппы)
	
	КодСтрока = СокрЛП(Строка(КодГруппы));
	Если КодСтрока = "" Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Группа = Справочники.Контрагенты.НайтиПоКоду(Число(КодСтрока));
	Если ЗначениеЗаполнено(Группа) И Группа.ЭтоГруппа Тогда
		Возврат Группа;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция ИмяГруппыИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("group") И СокрЛП(ДанныеЗапроса.group) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.group);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("parent") И СокрЛП(ДанныеЗапроса.parent) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.parent);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("groupName") И СокрЛП(ДанныеЗапроса.groupName) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.groupName);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("name") И СокрЛП(ДанныеЗапроса.name) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.name);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция АвтоСозданиеГруппыРазрешено(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("autoCreateGroup") Тогда
		Возврат ДанныеЗапроса.autoCreateGroup = Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура УстановитьГруппуВНастройках(ТипКонтрагента, Группа)
	
	РегистрыСведений.НастройкиПользователей.Установить(Группа, ИмяНастройкиГруппыКонтрагентов(ТипКонтрагента));
	
КонецПроцедуры

Функция СоздатьГруппуКонтрагентовВСправочнике(ИмяГруппы)
	
	Объект = Справочники.Контрагенты.СоздатьГруппу();
	Объект.Наименование = СокрЛП(ИмяГруппы);
	Объект.Записать();
	Возврат Объект.Ссылка;
	
КонецФункции

Функция СтруктураГруппыКонтрагентов(Группа, ТипКонтрагента, ЭтоГруппаПоУмолчанию = Ложь)
	
	Результат = Новый Структура;
	Результат.Вставить("group", "");
	Результат.Вставить("groupCode", "");
	Результат.Вставить("type", ТипКонтрагента);
	Результат.Вставить("isDefault", ЭтоГруппаПоУмолчанию);
	Результат.Вставить("configured", Ложь);
	
	Если ЗначениеЗаполнено(Группа) Тогда
		Результат.group = Строка(Группа);
		Результат.groupCode = КодКонтрагентаВСтроку(Группа.Код);
		Результат.configured = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РазрешитьГруппуКонтрагентов(ДанныеЗапроса, АвтоСоздать = Ложь)
	
	ТипКонтрагента = ТипКонтрагентаИзЗапроса(ДанныеЗапроса);
	
	Если ДанныеЗапроса <> Неопределено И ДанныеЗапроса.Свойство("groupCode") Тогда
		Группа = НайтиГруппуКонтрагентовПоКоду(ДанныеЗапроса.groupCode);
		Если ЗначениеЗаполнено(Группа) Тогда
			Возврат Группа;
		КонецЕсли;
	КонецЕсли;
	
	ИмяГруппы = ИмяГруппыИзЗапроса(ДанныеЗапроса);
	Если ИмяГруппы <> "" Тогда
		Группа = НайтиГруппуКонтрагентовПоИмени(ИмяГруппы);
		Если ЗначениеЗаполнено(Группа) Тогда
			Возврат Группа;
		КонецЕсли;
	КонецЕсли;
	
	Группа = ГруппаКонтрагентовИзНастройки(ТипКонтрагента);
	Если ЗначениеЗаполнено(Группа) Тогда
		Возврат Группа;
	КонецЕсли;
	
	Для Каждого ИмяПоиска Из ИменаГруппДляПоиска(ТипКонтрагента) Цикл
		Группа = НайтиГруппуКонтрагентовПоИмени(ИмяПоиска);
		Если ЗначениеЗаполнено(Группа) Тогда
			УстановитьГруппуВНастройках(ТипКонтрагента, Группа);
			Возврат Группа;
		КонецЕсли;
	КонецЦикла;
	
	Если АвтоСоздать Тогда
		Группа = СоздатьГруппуКонтрагентовВСправочнике(ИмяГруппыПоУмолчанию(ТипКонтрагента));
		УстановитьГруппуВНастройках(ТипКонтрагента, Группа);
		Возврат Группа;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция ГруппаКонтрагентовПоТипу(ДанныеЗапроса)
	
	Возврат РазрешитьГруппуКонтрагентов(ДанныеЗапроса, АвтоСозданиеГруппыРазрешено(ДанныеЗапроса));
	
КонецФункции

Функция ПолучитьСписокГруппКонтрагентов()
	
	Массив = Новый Массив;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Конт.Наименование КАК group,
	|	Конт.Код КАК Код
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Конт.Наименование";
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("group", Строка(Выборка.group));
		Элемент.Вставить("groupCode", КодКонтрагентаВСтроку(Выборка.Код));
		Массив.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Массив;
	
КонецФункции

Функция ПолучитьСведенияОГруппахКонтрагентов(Запрос)
	
	ТипКонтрагента = "customer";
	ПараметрТипа = Запрос.ПараметрыЗапроса.Получить("type");
	Если ПараметрТипа <> Неопределено Тогда
		ТипКонтрагента = ТипКонтрагентаИзПараметра(ПараметрТипа);
	КонецЕсли;
	
	ГруппаПоУмолчанию = ГруппаКонтрагентовИзНастройки(ТипКонтрагента);
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("type", ТипКонтрагента);
	ТелоОтвета.Вставить("settingName", ИмяНастройкиГруппыКонтрагентов(ТипКонтрагента));
	ТелоОтвета.Вставить("defaultGroup", СтруктураГруппыКонтрагентов(ГруппаПоУмолчанию, ТипКонтрагента, Истина));
	ТелоОтвета.Вставить("suggestedNames", ИменаГруппДляПоиска(ТипКонтрагента));
	
	Элементы = Новый Массив;
	Для Каждого СтрГруппы Из ПолучитьСписокГруппКонтрагентов() Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("group", СтрГруппы.group);
		Элемент.Вставить("groupCode", СтрГруппы.groupCode);
		Элемент.Вставить("type", ТипКонтрагента);
		Элемент.Вставить("isDefault", ЗначениеЗаполнено(ГруппаПоУмолчанию)
			И СтрГруппы.group = Строка(ГруппаПоУмолчанию));
		Элементы.Добавить(Элемент);
	КонецЦикла;
	ТелоОтвета.Вставить("items", Элементы);
	
	Возврат ТелоОтвета;
	
КонецФункции

Функция СоздатьГруппуКонтрагентовAPI(ДанныеЗапроса)
	
	Результат = Новый Структура("success, error, group, groupCode, type, settingName, configured",
		Ложь, "", "", "", "", "", Ложь);
	
	ИмяГруппы = ИмяГруппыИзЗапроса(ДанныеЗапроса);
	Если ИмяГруппы = "" Тогда
		Результат.error = "Укажите name или group (наименование группы).";
		Возврат Результат;
	КонецЕсли;
	
	ТипКонтрагента = ТипКонтрагентаИзЗапроса(ДанныеЗапроса);
	Существующая = НайтиГруппуКонтрагентовПоИмени(ИмяГруппы);
	Если ЗначениеЗаполнено(Существующая) Тогда
		Группа = Существующая;
	Иначе
		Попытка
			Группа = СоздатьГруппуКонтрагентовВСправочнике(ИмяГруппы);
		Исключение
			Результат.error = "Не удалось создать группу: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			Возврат Результат;
		КонецПопытки;
	КонецЕсли;
	
	УстановитьПоУмолчанию = Истина;
	Если ДанныеЗапроса.Свойство("setAsDefault") Тогда
		УстановитьПоУмолчанию = ДанныеЗапроса.setAsDefault = Истина;
	ИначеЕсли ДанныеЗапроса.Свойство("configure") Тогда
		УстановитьПоУмолчанию = ДанныеЗапроса.configure = Истина;
	КонецЕсли;
	
	Если УстановитьПоУмолчанию Тогда
		УстановитьГруппуВНастройках(ТипКонтрагента, Группа);
	КонецЕсли;
	
	Результат.success = Истина;
	Результат.group = Строка(Группа);
	Результат.groupCode = КодКонтрагентаВСтроку(Группа.Код);
	Результат.type = ТипКонтрагента;
	Результат.settingName = ИмяНастройкиГруппыКонтрагентов(ТипКонтрагента);
	Результат.configured = УстановитьПоУмолчанию;
	Возврат Результат;
	
КонецФункции

Функция НаименованиеКонтрагентаИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("customer") И СокрЛП(ДанныеЗапроса.customer) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.customer);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("counterparty") И СокрЛП(ДанныеЗапроса.counterparty) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.counterparty);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("name") И СокрЛП(ДанныеЗапроса.name) <> "" Тогда
		Возврат СокрЛП(ДанныеЗапроса.name);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ТипКонтрагентаДляОтвета(Группа, ТипКонтрагента = "customer")
	
	Если ТипКонтрагента = "supplier" Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Группа) И ЗначениеЗаполнено(ГруппаПоставщиков()) И Группа = ГруппаПоставщиков() Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Возврат "customer";
	
КонецФункции

Функция ПолучитьСписокПокупателей(Запрос)
	
	ГруппаПокупателей = РазрешитьГруппуКонтрагентов(Новый Структура("type", "customer"), Ложь);
	БезГруппы = НЕ ЗначениеЗаполнено(ГруппаПокупателей);
	
	СтрокаПоиска = "";
	ПараметрПоиска = Запрос.ПараметрыЗапроса.Получить("search");
	Если ПараметрПоиска <> Неопределено Тогда
		СтрокаПоиска = СокрЛП(ПараметрПоиска);
	КонецЕсли;
	БезПоиска = СтрокаПоиска = "";
	ШаблонПоиска = "%" + СтрокаПоиска + "%";
	
	СтрокаКода = "";
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("customerCode");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода <> Неопределено Тогда
		СтрокаКода = СокрЛП(Строка(ПараметрКода));
	КонецЕсли;
	БезКода = СтрокаКода = "";
	КодЧисло = 0;
	Если НЕ БезКода Тогда
		КодЧисло = Число(СтрокаКода);
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Конт.Код КАК Код,
	|	Конт.Наименование КАК customer,
	|	Конт.Псевдоним КАК alias,
	|	Конт.Email КАК email,
	|	Конт.Телефоны КАК phone,
	|	Конт.Город КАК city,
	|	Конт.Адрес КАК address
	|ИЗ
	|	Справочник.Контрагенты КАК Конт
	|ГДЕ
	|	НЕ Конт.ЭтоГруппа
	|	И НЕ Конт.ПометкаУдаления
	|	И (&БезГруппы
	|		ИЛИ Конт.Ссылка В ИЕРАРХИИ (&ГруппаПокупателей))
	|	И (&БезПоиска
	|		ИЛИ Конт.Наименование ПОДОБНО &ШаблонПоиска
	|		ИЛИ Конт.Псевдоним ПОДОБНО &ШаблонПоиска)
	|	И (&БезКода
	|		ИЛИ Конт.Код = &Код)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Конт.Наименование";
	Зап.УстановитьПараметр("БезГруппы", БезГруппы);
	Зап.УстановитьПараметр("ГруппаПокупателей", ГруппаПокупателей);
	Зап.УстановитьПараметр("БезПоиска", БезПоиска);
	Зап.УстановитьПараметр("ШаблонПоиска", ШаблонПоиска);
	Зап.УстановитьПараметр("БезКода", БезКода);
	Зап.УстановитьПараметр("Код", КодЧисло);
	
	Таблица = Зап.Выполнить().Выгрузить();
	Массив = Новый Массив;
	
	Для Каждого Стр Из Таблица Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("customer", Строка(Стр.customer));
		Элемент.Вставить("customerCode", КодКонтрагентаВСтроку(Стр.Код));
		Элемент.Вставить("alias", Строка(Стр.alias));
		Элемент.Вставить("email", Строка(Стр.email));
		Элемент.Вставить("phone", Строка(Стр.phone));
		Элемент.Вставить("city", Строка(Стр.city));
		Элемент.Вставить("address", Строка(Стр.address));
		Массив.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Массив;
	
КонецФункции

Функция ПолучитьСписокСкладов(Запрос)
	
	МассивДоступных = омСервер.МассивСкладов();
	ОграничитьПоДоступу = МассивДоступных.Количество() > 0;
	
	СтрокаПоиска = "";
	ПараметрПоиска = Запрос.ПараметрыЗапроса.Получить("search");
	Если ПараметрПоиска <> Неопределено Тогда
		СтрокаПоиска = СокрЛП(ПараметрПоиска);
	КонецЕсли;
	БезПоиска = СтрокаПоиска = "";
	ШаблонПоиска = "%" + СтрокаПоиска + "%";
	
	СтрокаКода = "";
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseCode");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода <> Неопределено Тогда
		СтрокаКода = СокрЛП(Строка(ПараметрКода));
	КонецЕсли;
	БезКода = СтрокаКода = "";
	КодЧисло = 0;
	Если НЕ БезКода Тогда
		КодЧисло = Число(СтрокаКода);
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Скл.Код КАК Код,
	|	Скл.Наименование КАК warehouse
	|ИЗ
	|	Справочник.Склады КАК Скл
	|ГДЕ
	|	НЕ Скл.ПометкаУдаления
	|	И (&ОграничитьПоДоступу = ЛОЖЬ
	|		ИЛИ Скл.Ссылка В (&МассивДоступных))
	|	И (&БезПоиска
	|		ИЛИ Скл.Наименование ПОДОБНО &ШаблонПоиска)
	|	И (&БезКода
	|		ИЛИ Скл.Код = &Код)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Скл.Наименование";
	Зап.УстановитьПараметр("ОграничитьПоДоступу", ОграничитьПоДоступу);
	Зап.УстановитьПараметр("МассивДоступных", МассивДоступных);
	Зап.УстановитьПараметр("БезПоиска", БезПоиска);
	Зап.УстановитьПараметр("ШаблонПоиска", ШаблонПоиска);
	Зап.УстановитьПараметр("БезКода", БезКода);
	Зап.УстановитьПараметр("Код", КодЧисло);
	
	Таблица = Зап.Выполнить().Выгрузить();
	Массив = Новый Массив;
	
	Для Каждого Стр Из Таблица Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("warehouse", Строка(Стр.warehouse));
		Элемент.Вставить("warehouseCode", КодСкладаВСтроку(Стр.Код));
		Массив.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Массив;
	
КонецФункции

Функция ПолучитьСписокВалют(Запрос)
	
	СтрокаПоиска = "";
	ПараметрПоиска = Запрос.ПараметрыЗапроса.Получить("search");
	Если ПараметрПоиска <> Неопределено Тогда
		СтрокаПоиска = СокрЛП(ПараметрПоиска);
	КонецЕсли;
	БезПоиска = СтрокаПоиска = "";
	ШаблонПоиска = "%" + СтрокаПоиска + "%";
	
	СтрокаКода = "";
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("currencyCode");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода <> Неопределено Тогда
		СтрокаКода = СокрЛП(Строка(ПараметрКода));
	КонецЕсли;
	БезКода = СтрокаКода = "";
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Вал.Код КАК Код,
	|	Вал.Наименование КАК currency,
	|	Вал.Обозначение КАК symbol,
	|	Вал.Символ КАК sign
	|ИЗ
	|	Справочник.Валюты КАК Вал
	|ГДЕ
	|	НЕ Вал.ПометкаУдаления
	|	И (&БезПоиска
	|		ИЛИ Вал.Наименование ПОДОБНО &ШаблонПоиска
	|		ИЛИ Вал.Код ПОДОБНО &ШаблонПоиска
	|		ИЛИ Вал.Обозначение ПОДОБНО &ШаблонПоиска)
	|	И (&БезКода
	|		ИЛИ Вал.Код = &Код)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вал.Наименование";
	Зап.УстановитьПараметр("БезПоиска", БезПоиска);
	Зап.УстановитьПараметр("ШаблонПоиска", ШаблонПоиска);
	Зап.УстановитьПараметр("БезКода", БезКода);
	Зап.УстановитьПараметр("Код", СтрокаКода);
	
	Таблица = Зап.Выполнить().Выгрузить();
	Массив = Новый Массив;
	
	Для Каждого Стр Из Таблица Цикл
		Элемент = Новый Структура;
		Элемент.Вставить("currency", Строка(Стр.currency));
		Элемент.Вставить("currencyCode", СокрЛП(Строка(Стр.Код)));
		Элемент.Вставить("symbol", Строка(Стр.symbol));
		Элемент.Вставить("sign", Строка(Стр.sign));
		Массив.Добавить(Элемент);
	КонецЦикла;
	
	Возврат Массив;
	
КонецФункции

Функция КодСкладаВСтроку(Код)
	
	Если Код = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Формат(Код, "ЧГ=0");
	
КонецФункции

Функция СоздатьКонтрагента(ДанныеЗапроса)
	
	Результат = Новый Структура("success, error, customer, customerCode, counterparty, counterpartyCode, type, group, groupCode",
		Ложь, "", "", "", "", "", "", "", "");
	
	Наименование = НаименованиеКонтрагентаИзЗапроса(ДанныеЗапроса);
	Если Наименование = "" Тогда
		Результат.error = "Укажите customer, counterparty или name (наименование контрагента).";
		Возврат Результат;
	КонецЕсли;
	
	Существующий = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина);
	Если ЗначениеЗаполнено(Существующий) Тогда
		Результат.error = СтрШаблон("Контрагент ""%1"" уже существует (код %2).",
			Наименование,
			КодКонтрагентаВСтроку(Существующий.Код));
		Возврат Результат;
	КонецЕсли;
	
	Группа = ГруппаКонтрагентовПоТипу(ДанныеЗапроса);
	Если НЕ ЗначениеЗаполнено(Группа) Тогда
		ТипЗапроса = ТипКонтрагентаИзЗапроса(ДанныеЗапроса);
		ИмяНастройки = ИмяНастройкиГруппыКонтрагентов(ТипЗапроса);
		Результат.error = СтрШаблон(
			"Не найдена группа контрагентов (настройка %1). Укажите group, POST /customer-groups или autoCreateGroup: true.",
			ИмяНастройки);
		Возврат Результат;
	КонецЕсли;
	
	Объект = Справочники.Контрагенты.СоздатьЭлемент();
	Объект.Наименование = Наименование;
	Объект.Родитель = Группа;
	
	Если ДанныеЗапроса.Свойство("alias") Тогда
		Объект.Псевдоним = СокрЛП(ДанныеЗапроса.alias);
	ИначеЕсли ДанныеЗапроса.Свойство("pseudonym") Тогда
		Объект.Псевдоним = СокрЛП(ДанныеЗапроса.pseudonym);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("email") Тогда
		Объект.Email = СокрЛП(ДанныеЗапроса.email);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("phone") Тогда
		Объект.Телефоны = СокрЛП(ДанныеЗапроса.phone);
	ИначеЕсли ДанныеЗапроса.Свойство("phones") Тогда
		Объект.Телефоны = СокрЛП(ДанныеЗапроса.phones);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("city") Тогда
		Объект.Город = СокрЛП(ДанныеЗапроса.city);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("address") Тогда
		Объект.Адрес = СокрЛП(ДанныеЗапроса.address);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("note") Тогда
		Объект.Примечание = СокрЛП(ДанныеЗапроса.note);
	ИначеЕсли ДанныеЗапроса.Свойство("comment") Тогда
		Объект.Примечание = СокрЛП(ДанныеЗапроса.comment);
	КонецЕсли;
	
	Попытка
		Объект.Записать();
	Исключение
		Результат.error = "Не удалось создать контрагента: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	КодСтрокой = КодКонтрагентаВСтроку(Объект.Код);
	ТипОтвета = ТипКонтрагентаДляОтвета(Группа, ТипКонтрагентаИзЗапроса(ДанныеЗапроса));
	
	Результат.success = Истина;
	Результат.customer = Объект.Наименование;
	Результат.customerCode = КодСтрокой;
	Результат.counterparty = Объект.Наименование;
	Результат.counterpartyCode = КодСтрокой;
	Результат.type = ТипОтвета;
	Результат.group = Строка(Группа);
	Результат.groupCode = КодКонтрагентаВСтроку(Группа.Код);
	Возврат Результат;
	
КонецФункции

Функция КодКонтрагентаВСтроку(Код)
	
	Если Код = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Формат(Код, "ЧГ=0");
	
КонецФункции

Функция НайтиКонтрагента(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("customerCode") И СокрЛП(ДанныеЗапроса.customerCode) <> "" Тогда
		Контрагент = Справочники.Контрагенты.НайтиПоКоду(СокрЛП(ДанныеЗапроса.customerCode));
		Если ЗначениеЗаполнено(Контрагент) Тогда
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("customer") И СокрЛП(ДанныеЗапроса.customer) <> "" Тогда
		Возврат Справочники.Контрагенты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.customer), Истина);
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция НайтиФирму(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("firm") И СокрЛП(ДанныеЗапроса.firm) <> "" Тогда
		Фирма = Справочники.Фирмы.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.firm), Истина);
		Если ЗначениеЗаполнено(Фирма) Тогда
			Возврат Фирма;
		КонецЕсли;
	КонецЕсли;
	
	Фирма = гоФирма();
	Если ЗначениеЗаполнено(Фирма) Тогда
		Возврат Фирма;
	КонецЕсли;
	
	Возврат омСервер.ПолучитьФирму();
	
КонецФункции

Функция НайтиСклад(ДанныеЗапроса, Фирма)
	
	Если ДанныеЗапроса.Свойство("warehouse") И СокрЛП(ДанныеЗапроса.warehouse) <> "" Тогда
		Склад = Справочники.Склады.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.warehouse), Истина);
		Если ЗначениеЗаполнено(Склад) Тогда
			Возврат Склад;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Фирма.Склад) Тогда
		Возврат Фирма.Склад;
	КонецЕсли;
	
	МассивСкладов = омСервер.МассивСкладов();
	Если МассивСкладов.Количество() > 0 Тогда
		Возврат МассивСкладов[0];
	КонецЕсли;
	
	Возврат Справочники.Склады.ПустаяСсылка();
	
КонецФункции

Функция СтрокиЗаказаИзЗапроса(ДанныеЗапроса, Фирма, Склад)
	
	Результат = Новый Структура("Строки, Ошибки", Новый Массив, Новый СписокЗначений);
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.Ошибки.Добавить("В теле запроса нет массива items.");
		Возврат Результат;
	КонецЕсли;
	
	Позиции = ДанныеЗапроса.items;
	Если ТипЗнч(Позиции) <> Тип("Массив") Тогда
		Результат.Ошибки.Добавить("Поле items должно быть массивом.");
		Возврат Результат;
	КонецЕсли;
	
	НомерПозиции = 0;
	Для Каждого Позиция Из Позиции Цикл
		
		НомерПозиции = НомерПозиции + 1;
		
		Если ТипЗнч(Позиция) <> Тип("Структура") Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: неверный формат позиции.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Количество = 1;
		Если Позиция.Свойство("qty") Тогда
			Количество = Число(Позиция.qty);
		КонецЕсли;
		Если Количество <= 0 Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: qty должно быть больше 0.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Цена = ЦенаИзПозицииЗапроса(Позиция);
		Если Цена <= 0 Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите price (должна совпадать с salePrice из /balances).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Если Позиция.Свойство("serial") И СокрЛП(Позиция.serial) <> "" Тогда
			
			СведенияПартии = СведенияПартииПоСерии(СокрЛП(Позиция.serial), Фирма, Склад);
			Если СведенияПартии = Неопределено Тогда
				Результат.Ошибки.Добавить(СтрШаблон("Строка %1: нет остатка по серии %2.", НомерПозиции, Позиция.serial));
				Продолжить;
			КонецЕсли;
			
			Если СведенияПартии.Остаток < Количество Тогда
				Результат.Ошибки.Добавить(СтрШаблон("Строка %1: остаток %2, требуется %3.",
					НомерПозиции, СведенияПартии.Остаток, Количество));
				Продолжить;
			КонецЕсли;
			
			Если ПартияУжеВЗаказе(Результат.Строки, СведенияПартии.Партия) Тогда
				Результат.Ошибки.Добавить(СтрШаблон("Строка %1: партия уже есть в заказе.", НомерПозиции));
				Продолжить;
			КонецЕсли;
			
			СтрЗаказа = Новый Структура("НомерПозиции, Номенклатура, Партия, Серия, Количество, Цена",
				НомерПозиции,
				СведенияПартии.Номенклатура,
				СведенияПартии.Партия,
				СокрЛП(СведенияПартии.Серия),
				Количество,
				Цена);
			Результат.Строки.Добавить(СтрЗаказа);
			
		Иначе
			
			Номенклатура = НайтиНоменклатуруПоПозиции(Позиция);
			Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
				Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите serial, itemCode или item (наименование).", НомерПозиции));
				Продолжить;
			КонецЕсли;
			
			ПодобранныеПартии = ПодобратьПартииПоТовару(Позиция, Номенклатура, Фирма, Склад, Количество, ПартииУжеВЗаказе(Результат.Строки));
			Если ПодобранныеПартии.Количество() = 0 Тогда
				Результат.Ошибки.Добавить(СтрШаблон("Строка %1: нет остатка для товара %2%3.",
					НомерПозиции,
					Строка(Номенклатура),
					ТекстФильтраПартииДляОшибки(Позиция)));
				Продолжить;
			КонецЕсли;
			
			Для Каждого СведенияПартии Из ПодобранныеПартии Цикл
				СтрЗаказа = Новый Структура("НомерПозиции, Номенклатура, Партия, Серия, Количество, Цена",
					НомерПозиции,
					СведенияПартии.Номенклатура,
					СведенияПартии.Партия,
					СокрЛП(СведенияПартии.Серия),
					СведенияПартии.Количество,
					Цена);
				Результат.Строки.Добавить(СтрЗаказа);
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СведенияПартииПоСерии(Серия, Фирма, Склад)
	
	МассивСерий = Новый Массив;
	МассивСерий.Добавить(Серия);
	Соотв = СведенияПартийПоСериям(МассивСерий, Фирма, Склад);
	Возврат Соотв.Получить(Серия);
	
КонецФункции

Функция НайтиНоменклатуруПоПозиции(Позиция)
	
	Если Позиция.Свойство("itemCode") И СокрЛП(Строка(Позиция.itemCode)) <> "" Тогда
		Номенклатура = Справочники.Номенклатура.НайтиПоКоду(СокрЛП(Строка(Позиция.itemCode)));
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Если Позиция.Свойство("item") И СокрЛП(Позиция.item) <> "" Тогда
		Наименование = СокрЛП(Позиция.item);
		Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Ложь);
		КонецЕсли;
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция ФильтрПартииИзПозиции(Позиция)
	
	Результат = Новый Структура("КодПартии, НаименованиеПартии", "", "");
	
	Если Позиция.Свойство("batchCode") И СокрЛП(Строка(Позиция.batchCode)) <> "" Тогда
		Результат.КодПартии = СокрЛП(Строка(Позиция.batchCode));
	ИначеЕсли Позиция.Свойство("batch") И СокрЛП(Позиция.batch) <> "" Тогда
		Результат.НаименованиеПартии = СокрЛП(Позиция.batch);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТекстФильтраПартииДляОшибки(Позиция)
	
	Фильтр = ФильтрПартииИзПозиции(Позиция);
	Если Фильтр.КодПартии <> "" Тогда
		Возврат СтрШаблон(" (партия %1)", Фильтр.КодПартии);
	ИначеЕсли Фильтр.НаименованиеПартии <> "" Тогда
		Возврат СтрШаблон(" (партия %1)", Фильтр.НаименованиеПартии);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ПартииУжеВЗаказе(СтрокиЗаказа)
	
	МассивПартий = Новый Массив;
	Для Каждого Стр Из СтрокиЗаказа Цикл
		МассивПартий.Добавить(Стр.Партия);
	КонецЦикла;
	Возврат МассивПартий;
	
КонецФункции

Функция ПартияУжеВЗаказе(СтрокиЗаказа, Партия)
	
	Для Каждого Стр Из СтрокиЗаказа Цикл
		Если Стр.Партия = Партия Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
	
КонецФункции

// Подбор одной или нескольких партий: в остатках каждая партия — отдельная запись (часто qty=1),
// а /balances суммирует по наименованию партии. Для qty>1 собираем количество с нескольких партий.
Функция ПодобратьПартииПоТовару(Позиция, Номенклатура, Фирма, Склад, Количество, ИсключитьПартии)
	
	Результат = Новый Массив;
	
	Фильтр = ФильтрПартииИзПозиции(Позиция);
	БезПартии = Фильтр.КодПартии = "" И Фильтр.НаименованиеПартии = "";
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Ост.Партия КАК Партия,
	|	Ост.Партия.Серия КАК Серия,
	|	Ост.Номенклатура КАК Номенклатура,
	|	Ост.ОстатокОстаток КАК Остаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(
	|		,
	|		Фирма = &Фирма
	|			И Склад = &Склад
	|			И Номенклатура = &Номенклатура
	|			И (&БезПартии
	|				ИЛИ Партия.Код = &КодПартии
	|				ИЛИ Партия.Наименование = &НаименованиеПартии)) КАК Ост
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И (&ИсключитьПартииПусто
	|		ИЛИ НЕ Ост.Партия В (&ИсключитьПартии))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ост.ОстатокОстаток УБЫВ";
	Зап.УстановитьПараметр("Фирма", Фирма);
	Зап.УстановитьПараметр("Склад", Склад);
	Зап.УстановитьПараметр("Номенклатура", Номенклатура);
	Зап.УстановитьПараметр("КодПартии", Фильтр.КодПартии);
	Зап.УстановитьПараметр("НаименованиеПартии", Фильтр.НаименованиеПартии);
	Зап.УстановитьПараметр("БезПартии", БезПартии);
	Зап.УстановитьПараметр("ИсключитьПартии", ИсключитьПартии);
	Зап.УстановитьПараметр("ИсключитьПартииПусто", ИсключитьПартии.Количество() = 0);
	
	ТаблицаПартий = Зап.Выполнить().Выгрузить();
	Если ТаблицаПартий.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	СуммаОстатка = ТаблицаПартий.Итог("Остаток");
	Если СуммаОстатка < Количество Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОсталосьПодобрать = Количество;
	Для Каждого Стр Из ТаблицаПартий Цикл
		
		Если ОсталосьПодобрать <= 0 Тогда
			Прервать;
		КонецЕсли;
		
		КоличествоИзПартии = Мин(ОсталосьПодобрать, Стр.Остаток);
		Результат.Добавить(Новый Структура("Партия, Номенклатура, Остаток, Серия, Количество",
			Стр.Партия, Стр.Номенклатура, Стр.Остаток, Стр.Серия, КоличествоИзПартии));
		ОсталосьПодобрать = ОсталосьПодобрать - КоличествоИзПартии;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СведенияПартийПоСериям(МассивСерий, Фирма, Склад)
	
	Результат = Новый Соответствие;
	Если МассивСерий.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивВРег = Новый Массив;
	МассивНРег = Новый Массив;
	Для Каждого Эл Из МассивСерий Цикл
		МассивВРег.Добавить(ВРег(Эл));
		МассивНРег.Добавить(НРег(Эл));
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Рег.Партия КАК Партия,
	|	Рег.ОстатокОстаток КАК Остаток,
	|	Рег.Партия.Серия КАК Серия,
	|	Рег.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки КАК Рег
	|ГДЕ
	|	Рег.Фирма = &Фирма
	|	И Рег.Склад = &Склад
	|	И Рег.ОстатокОстаток >= 1
	|	И (Рег.Партия.Серия В (&Серии)
	|		ИЛИ Рег.Партия.Серия В (&СерииНРег)
	|		ИЛИ Рег.Партия.Серия В (&СерииВРег))";
	Запрос.УстановитьПараметр("Серии", МассивСерий);
	Запрос.УстановитьПараметр("СерииНРег", МассивВРег);
	Запрос.УстановитьПараметр("СерииВРег", МассивНРег);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Фирма", Фирма);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СведенияПартии = Новый Структура("Партия, Номенклатура, Остаток, Серия",
			Выборка.Партия, Выборка.Номенклатура, Выборка.Остаток, Выборка.Серия);
		Серия = СокрЛП(Выборка.Серия);
		Результат.Вставить(Серия, СведенияПартии);
		Результат.Вставить(ВРег(Серия), СведенияПартии);
		Результат.Вставить(НРег(Серия), СведенияПартии);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция НоменклатураИзСтрокЗаказа(СтрокиЗаказа)
	
	Уникальные = Новый Соответствие;
	МассивНоменклатуры = Новый Массив;
	Для Каждого Стр Из СтрокиЗаказа Цикл
		Если Уникальные.Получить(Стр.Номенклатура) = Неопределено Тогда
			Уникальные.Вставить(Стр.Номенклатура, Истина);
			МассивНоменклатуры.Добавить(Стр.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	Возврат МассивНоменклатуры;
	
КонецФункции

Функция ТекстОшибокСписка(Ошибки)
	
	Текст = "";
	Для Каждого Ошибка Из Ошибки Цикл
		Текст = Текст + Ошибка.Значение + Символы.ПС;
