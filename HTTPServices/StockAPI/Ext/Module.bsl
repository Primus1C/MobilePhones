Функция ТипКонтрагентаИзПараметра(ЗначениеТипа)
	
	ТипКонтрагента = НРег(СокрЛП(Строка(ЗначениеТипа)));
	
	Если ТипКонтрагента = "supplier"
		Или ТипКонтрагента = "поставщик"
		Или ТипКонтрагента = "suppliers" Тогда
		Возврат "supplier";
	КонецЕсли;
	
	Возврат "customer";
	
КонецФункции

Функция ТипКонтрагентаИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат "customer";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("type") Тогда
		Возврат ТипКонтрагентаИзПараметра(ДанныеЗапроса.type);
	КонецЕсли;
	
	Возврат "customer";
	
КонецФункции

