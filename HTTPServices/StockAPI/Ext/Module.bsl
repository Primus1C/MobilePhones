		РезультатСоздания = СоздатьЗаказПокупателя(ДанныеЗапроса);
		Возврат ОтветJSON(?(РезультатСоздания.success, 200, 400), РезультатСоздания);
	Исключение
		Возврат ОтветJSON(500, Новый Структура("success, error", Ложь, ОписаниеОшибки()));
	КонецПопытки;
	
КонецФункции

