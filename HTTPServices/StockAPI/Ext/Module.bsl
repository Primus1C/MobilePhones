КонецФункции

// Фильтр /balances по складу: warehouseId, warehouseCode или code (числовой код из /warehouses).
Функция СкладОстатковИзЗапроса(Запрос)
	
	Результат = Новый Структура("Склад, warehouseCode, Ошибка", Справочники.Склады.ПустаяСсылка(), "", "");
	
	СтрокаКода = "";
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseId");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseCode");
	КонецЕсли;
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода <> Неопределено Тогда
		СтрокаКода = СокрЛП(Строка(ПараметрКода));
	КонецЕсли;
	
	Если СтрокаКода = "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		КодЧисло = Число(СтрокаКода);
	Исключение
		Результат.Ошибка = "Параметр warehouseId (или warehouseCode) должен быть числовым кодом склада.";
		Возврат Результат;
	КонецПопытки;
	
	Склад = Справочники.Склады.НайтиПоКоду(КодЧисло);
	Если НЕ ЗначениеЗаполнено(Склад) Или Склад.ПометкаУдаления Тогда
		Результат.Ошибка = СтрШаблон("Склад с кодом %1 не найден.", СтрокаКода);
		Возврат Результат;
	КонецЕсли;
	
	МассивДоступных = омСервер.МассивСкладов();
	Если МассивДоступных.Количество() > 0 Тогда
		Доступен = Ложь;
		Для Каждого ДоступныйСклад Из МассивДоступных Цикл
			Если ДоступныйСклад = Склад Тогда
				Доступен = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если НЕ Доступен Тогда
			Результат.Ошибка = "Нет доступа к указанному складу.";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Результат.Склад = Склад;
	Результат.warehouseCode = КодСкладаВСтроку(КодЧисло);
	Возврат Результат;
	
КонецФункции

// Пагинация /balances: page (с 1), pageSize (макс. 500). Считаем уникальную номенклатуру с остатком > 0.
Функция ПараметрыПагинацииОстатков(Запрос)
	
	МаксРазмерСтраницы = 500;
	РазмерПоУмолчанию = 500;
	Результат = Новый Структура("page, pageSize, Ошибка", 1, РазмерПоУмолчанию, "");
	
	СтрокаСтраницы = Запрос.ПараметрыЗапроса.Получить("page");
	СтрокаРазмера = Запрос.ПараметрыЗапроса.Получить("pageSize");
	Если СтрокаРазмера = Неопределено Или СокрЛП(СтрокаРазмера) = "" Тогда
		СтрокаРазмера = Запрос.ПараметрыЗапроса.Получить("limit");
	КонецЕсли;
	
	НомерСтраницы = ЦелоеПараметраЗапроса(СтрокаСтраницы, 1);
	Если НомерСтраницы < 0 Тогда
		Результат.Ошибка = "Параметр page должен быть целым числом >= 1.";
		Возврат Результат;
	КонецЕсли;
	Если НомерСтраницы = 0 Тогда
		НомерСтраницы = 1;
	КонецЕсли;
	
	РазмерСтраницы = ЦелоеПараметраЗапроса(СтрокаРазмера, РазмерПоУмолчанию);
	Если РазмерСтраницы < 0 Тогда
		Результат.Ошибка = "Параметр pageSize (или limit) должен быть целым числом от 1 до 500.";
		Возврат Результат;
	КонецЕсли;
	Если РазмерСтраницы = 0 Тогда
		РазмерСтраницы = РазмерПоУмолчанию;
	КонецЕсли;
	Если РазмерСтраницы > МаксРазмерСтраницы Тогда
		Результат.Ошибка = СтрШаблон("pageSize не может превышать %1.", МаксРазмерСтраницы);
		Возврат Результат;
	КонецЕсли;
	
	Результат.page = НомерСтраницы;
	Результат.pageSize = РазмерСтраницы;
	Возврат Результат;
	
КонецФункции

Функция ЦелоеПараметраЗапроса(СтрокаЗначения, ЗначениеПоУмолчанию)
	
	Если СтрокаЗначения = Неопределено Или СокрЛП(СтрокаЗначения) = "" Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Попытка
		ЧислоЗначения = Число(СтрокаЗначения);
	Исключение
		Возврат -1;
	КонецПопытки;
	
	Если ЧислоЗначения <> Цел(ЧислоЗначения) Тогда
		Возврат -1;
	КонецЕсли;
	
	Возврат Цел(ЧислоЗначения);
	
КонецФункции

Функция ВсегоСтраницПагинации(ВсегоЭлементов, РазмерСтраницы)
	
	Если ВсегоЭлементов = 0 Или РазмерСтраницы <= 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Цел((ВсегоЭлементов - 1) / РазмерСтраницы) + 1;
	
КонецФункции

Функция КоличествоНоменклатурыНаОстатках(ДатаОстатков, Склад = Неопределено)
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ост.Номенклатура) КАК Количество
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И Ост.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И (&БезСклада
	|		ИЛИ Ост.Склад = &Склад)";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Количество;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция НоменклатураНаОстаткахСтраница(ДатаОстатков, РазмерСтраницы, Пропустить, Склад = Неопределено)
	
	МассивНоменклатуры = Новый Массив;
	
	Если РазмерСтраницы <= 0 Тогда
		Возврат МассивНоменклатуры;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ " + РазмерСтраницы + ?(Пропустить > 0, " ПРОПУСТИТЬ " + Пропустить, "") + "
	|	Вложенный.Номенклатура КАК Номенклатура
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		Ост.Номенклатура КАК Номенклатура,
	|		Ост.Номенклатура.Код КАК КодСортировки,
	|		Ост.Номенклатура.Наименование КАК НаименованиеСортировки
	|	ИЗ
	|		РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|	ГДЕ
	|		Ост.ОстатокОстаток > 0
	|		И Ост.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|		И (&БезСклада
	|			ИЛИ Ост.Склад = &Склад)) КАК Вложенный
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вложенный.КодСортировки,
	|	Вложенный.НаименованиеСортировки";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивНоменклатуры.Добавить(Выборка.Номенклатура);
	КонецЦикла;
	
	Возврат МассивНоменклатуры;
	
КонецФункции

Функция ТаблицаОстатковПоНоменклатуре(ДатаОстатков, НоменклатураСтраницы, Склад = Неопределено)
	
	ПустаяТаблица = Новый ТаблицаЗначений;
	ПустаяТаблица.Колонки.Добавить("warehouse");
	ПустаяТаблица.Колонки.Добавить("item");
	ПустаяТаблица.Колонки.Добавить("itemCode");
	ПустаяТаблица.Колонки.Добавить("sku");
	ПустаяТаблица.Колонки.Добавить("itemType");
	ПустаяТаблица.Колонки.Добавить("manufacturer");
	ПустаяТаблица.Колонки.Добавить("Номенклатура");
	ПустаяТаблица.Колонки.Добавить("batch");
	ПустаяТаблица.Колонки.Добавить("batchCode");
	ПустаяТаблица.Колонки.Добавить("serialParty");
	ПустаяТаблица.Колонки.Добавить("Партия");
	ПустаяТаблица.Колонки.Добавить("qty", Новый ОписаниеТипов("Число"));
	ПустаяТаблица.Колонки.Добавить("reserve", Новый ОписаниеТипов("Число"));
	
	Если НоменклатураСтраницы.Количество() = 0 Тогда
		Возврат ПустаяТаблица;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Ост.Склад.Наименование КАК warehouse,
	|	Ост.Номенклатура.Наименование КАК item,
	|	Ост.Номенклатура.Код КАК itemCode,
	|	Ост.Номенклатура.Код КАК sku,
	|	Ост.Номенклатура.ВидНоменклатуры.Наименование КАК itemType,
	|	Ост.Номенклатура.Производитель.Наименование КАК manufacturer,
	|	Ост.Номенклатура КАК Номенклатура,
	|	Ост.Партия.Наименование КАК batch,
	|	Ост.Партия.Код КАК batchCode,
	|	Ост.Партия.Серия КАК serialParty,
	|	Ост.Партия КАК Партия,
	|	Ост.ОстатокОстаток КАК qty,
	|	Ост.РезервОстаток КАК reserve
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И Ост.Номенклатура В (&Номенклатура)
	|	И (&БезСклада
	|		ИЛИ Ост.Склад = &Склад)";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("Номенклатура", НоменклатураСтраницы);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Возврат Зап.Выполнить().Выгрузить();
	
КонецФункции

Функция КлючГруппыОстатков(Склад, КодТовара, Партия)
	Возврат Строка(Склад) + "|" + Строка(КодТовара) + "|" + Строка(Партия);
КонецФункции

Процедура ДобавитьСерийникВМассив(МассивСерий, ЗначениеСерии)
	
	Серия = СокрЛП(ЗначениеСерии);
	Если Серия = "" Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Существующая Из МассивСерий Цикл
		Если Существующая = Серия Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	МассивСерий.Добавить(Серия);
	
КонецПроцедуры

Функция СерииИзСтрокПриходных(ТаблицаОстатков)
	
	Результат = Новый Соответствие;
	МассивПартий = Новый Массив;
	
	Для Каждого Стр Из ТаблицаОстатков Цикл
		Если ЗначениеЗаполнено(Стр.Партия) Тогда
			МассивПартий.Добавить(Стр.Партия);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивПартий.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Товары.Партия КАК Партия,
	|	Товары.Серия КАК Серия
	|ИЗ
	|	Документ.ПриходнаяНакладная.Товары КАК Товары
	|ГДЕ
	|	Товары.Партия В (&Партии)
	|	И Товары.Серия <> """"
	|	И Товары.Ссылка.Проведен";
	Зап.УстановитьПараметр("Партии", МассивПартий);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивСерий = Результат.Получить(Выборка.Партия);
		Если МассивСерий = Неопределено Тогда
			МассивСерий = Новый Массив;
			Результат.Вставить(Выборка.Партия, МассивСерий);
		КонецЕсли;
		ДобавитьСерийникВМассив(МассивСерий, Выборка.Серия);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СерииИзСтрокПриходныхПоГруппе(ДатаОстатков, НоменклатураСтраницы = Неопределено, Склад = Неопределено)
	
	Результат = Новый Соответствие;
	
	Если НоменклатураСтраницы <> Неопределено И НоменклатураСтраницы.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Ост.Склад.Наименование КАК warehouse,
	|	Ост.Номенклатура.Код КАК itemCode,
	|	Ост.Партия.Наименование КАК batch,
	|	Товары.Серия КАК Серия
	|ИЗ
	|	РегистрНакопления.ОстаткиТовара.Остатки(&Дата, ) КАК Ост
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная.Товары КАК Товары
	|		ПО Ост.Партия = Товары.Партия
	|ГДЕ
	|	Ост.ОстатокОстаток > 0
	|	И Товары.Серия <> """"
	|	И Товары.Ссылка.Проведен
	|	И (&БезСклада
	|		ИЛИ Ост.Склад = &Склад)";
	
	Если НоменклатураСтраницы <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	И Ост.Номенклатура В (&Номенклатура)";
		Зап.УстановитьПараметр("Номенклатура", НоменклатураСтраницы);
	КонецЕсли;
	
	Зап.Текст = ТекстЗапроса;
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("БезСклада", НЕ ЗначениеЗаполнено(Склад));
	Зап.УстановитьПараметр("Склад", ?(ЗначениеЗаполнено(Склад), Склад, Справочники.Склады.ПустаяСсылка()));
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Ключ = КлючГруппыОстатков(Выборка.warehouse, Выборка.itemCode, Выборка.batch);
		МассивСерий = Результат.Получить(Ключ);
		Если МассивСерий = Неопределено Тогда
			МассивСерий = Новый Массив;
			Результат.Вставить(Ключ, МассивСерий);
		КонецЕсли;
		ДобавитьСерийникВМассив(МассивСерий, Выборка.Серия);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ВидЦеныИзПараметра(СтрокаВидаЦены)
	
	Если СтрокаВидаЦены = Неопределено Или СокрЛП(СтрокаВидаЦены) = "" Тогда
		Возврат Перечисления.ВидыЦен.МелкийОпт;
	КонецЕсли;
	
	Норм = ВРег(СокрЛП(СтрокаВидаЦены));
	
	Если Норм = "КРУПНЫЙОПТ" Или Норм = "LARGE" Или Норм = "WHOLESALE" Тогда
		Возврат Перечисления.ВидыЦен.КрупныйОпт;
	КонецЕсли;
	
	Возврат Перечисления.ВидыЦен.МелкийОпт;
	
КонецФункции

Функция УникальнаяНоменклатураИзТаблицы(ТаблицаОстатков)
	
	Уникальные = Новый Соответствие;
	МассивНоменклатуры = Новый Массив;
	
	Для Каждого Стр Из ТаблицаОстатков Цикл
		Если ЗначениеЗаполнено(Стр.Номенклатура) И Уникальные.Получить(Стр.Номенклатура) = Неопределено Тогда
			Уникальные.Вставить(Стр.Номенклатура, Истина);
			МассивНоменклатуры.Добавить(Стр.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивНоменклатуры;
	
КонецФункции

Функция ЗагрузитьЦеныПродажи(ДатаОстатков, МассивНоменклатуры, ВидЦены)
	
	Результат = Новый Соответствие;
	
	Если МассивНоменклатуры.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =
	"ВЫБРАТЬ
	|	Цены.Номенклатура КАК Номенклатура,
	|	Цены.Цена КАК Цена,
	|	Цены.ЦенаОтКоличества КАК ЦенаОтКоличества,
	|	Цены.Количество КАК КоличествоПорог,
	|	Цены.Валюта.Наименование КАК Валюта
	|ИЗ
	|	РегистрСведений.ЦеныПродажи.СрезПоследних(
	|		&Дата,
	|		Номенклатура В (&Номенклатура)
	|			И ВидЦены = &ВидЦены) КАК Цены";
	Зап.УстановитьПараметр("Дата", ДатаОстатков);
	Зап.УстановитьПараметр("Номенклатура", МассивНоменклатуры);
	Зап.УстановитьПараметр("ВидЦены", ВидЦены);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(
			Выборка.Номенклатура,
			Новый Структура("Цена, ЦенаОтКоличества, КоличествоПорог, Валюта",
				Выборка.Цена,
				Выборка.ЦенаОтКоличества,
				Выборка.КоличествоПорог,
				Выборка.Валюта));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЦенаИзПозицииЗапроса(Позиция)
	
	Если Позиция.Свойство("price") Тогда
		Возврат Число(Позиция.price);
	КонецЕсли;
	
	Если Позиция.Свойство("salePrice") Тогда
		Возврат Число(Позиция.salePrice);
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция ЦеныСовпадают(ЦенаЗапроса, ОжидаемаяЦена)
	
	Возврат Окр(ЦенаЗапроса, 2) = Окр(ОжидаемаяЦена, 2);
	
КонецФункции

Функция ПроверитьЦеныСтрокЗаказа(СтрокиЗаказа, ЦеныПродажи, ИмяВидаЦены)
	
	Ошибки = Новый СписокЗначений;
	
	Для Каждого СтрЗаказа Из СтрокиЗаказа Цикл
		
		ДанныеЦены = ЦеныПродажи.Получить(СтрЗаказа.Номенклатура);
		ОжидаемаяЦена = ЦенаПродажиПоКоличеству(ДанныеЦены, СтрЗаказа.Количество);
		
		Если ОжидаемаяЦена <= 0 Тогда
			Ошибки.Добавить(СтрШаблон("Строка %1: для товара %2 не задана цена продажи (вид %3).",
				СтрЗаказа.НомерПозиции,
				Строка(СтрЗаказа.Номенклатура),
				ИмяВидаЦены));
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЦеныСовпадают(СтрЗаказа.Цена, ОжидаемаяЦена) Тогда
			Ошибки.Добавить(СтрШаблон("Строка %1: неверная цена. Указано %2, ожидается %3 (salePrice, вид %4).",
				СтрЗаказа.НомерПозиции,
				Формат(СтрЗаказа.Цена, "ЧДЦ=2; ЧРД=.; ЧГ=0"),
				Формат(ОжидаемаяЦена, "ЧДЦ=2; ЧРД=.; ЧГ=0"),
				ИмяВидаЦены));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ошибки;
	
КонецФункции

Функция ЦенаПродажиПоКоличеству(ДанныеЦены, Количество)
	
	Если ДанныеЦены = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ДанныеЦены.КоличествоПорог > 0
		И Количество >= ДанныеЦены.КоличествоПорог
		И ДанныеЦены.ЦенаОтКоличества > 0 Тогда
		Возврат ДанныеЦены.ЦенаОтКоличества;
	КонецЕсли;
	
	Возврат ДанныеЦены.Цена;
	
КонецФункции

Процедура ДобавитьЦенуВСтруктуру(СтруктураЭлемента, ДанныеЦены, Количество, ИмяВидаЦены)
	
	СтруктураЭлемента.Вставить("salePrice", ЦенаПродажиПоКоличеству(ДанныеЦены, Количество));
	СтруктураЭлемента.Вставить("priceType", ИмяВидаЦены);
	
	Валюта = "";
	Если ДанныеЦены <> Неопределено Тогда
		Валюта = Строка(ДанныеЦены.Валюта);
	КонецЕсли;
	СтруктураЭлемента.Вставить("currency", Валюта);
	
КонецПроцедуры
